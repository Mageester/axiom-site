{
  "prefetch": [
    {
      "source": "document",
      "where": {
        "and": [
          { "href_matches": "/*" },
          { "not": { "href_matches": "/admin/*" } },
          { "not": { "href_matches": "/api/*" } },
          { "not": { "href_matches": "/start-a-project" } }
        ]
      },
      "eagerness": "moderate"
    }
  ],
  "prerender": [
    {
      "source": "document",
      "where": {
        "or": [
          { "href_matches": "/" },
          { "href_matches": "/work" },
          { "href_matches": "/pricing" },
          { "href_matches": "/services" },
          { "href_matches": "/about" },
          { "href_matches": "/process" },
          { "href_matches": "/contact" }
        ]
      },
      "eagerness": "moderate"
    }
  ]
}
