# Cloudflare Pages environment variables (set in Dashboard per environment).
# Do not commit real secrets.
# Local Wrangler usage:
# 1) copy this file to `.dev.vars`
# 2) fill required values for the flow you are testing
# 3) run `npm run dev:intake:api` (serves Pages Functions on :10000)

# Bootstrap controls (first deploy only)
BOOTSTRAP_ENABLED=false
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=

# Authentication / crypto
PBKDF2_ITERS=100000
ADMIN_ACCESS_TOKEN=

# Intake email delivery (required for live submissions)
RESEND_API_KEY=
INTAKE_EMAIL=aidan@getaxiom.ca,riley@getaxiom.ca
INTAKE_FROM_EMAIL=Axiom Intake <engine@getaxiom.ca>
INTAKE_CONFIRMATION_FROM_EMAIL=Axiom Infrastructure <engine@getaxiom.ca>

# Optional anti-spam hardening
TURNSTILE_SECRET_KEY=

# Optional CORS override (comma-separated origins)
INTAKE_ALLOWED_ORIGINS=https://getaxiom.ca,https://www.getaxiom.ca,https://hvac.getaxiom.ca,https://roofing.getaxiom.ca,https://landscaping.getaxiom.ca,http://localhost:5173,http://127.0.0.1:5173
