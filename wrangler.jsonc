{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "axiom-site",
  "compatibility_date": "2026-02-19",
  "pages_build_output_dir": "dist",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
