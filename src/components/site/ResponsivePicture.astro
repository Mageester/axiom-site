---
import type { ResponsiveSource } from '../../lib/responsiveImages';

type Props = {
  source: ResponsiveSource;
  alt: string;
  sizes: string;
  class?: string;
  style?: string | Record<string, any>;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'low' | 'auto';
  decoding?: 'async' | 'sync' | 'auto';
  objectPosition?: string;
};

const {
  source,
  alt,
  sizes,
  class: className = '',
  style: styleProp = '',
  loading = 'lazy',
  fetchpriority = 'auto',
  decoding = 'async',
  objectPosition,
} = Astro.props;

// Merge objectPosition into style if provided
const mergedStyle = [
  styleProp,
  objectPosition ? `object-position: ${objectPosition};` : ''
].filter(Boolean).join(' ');
---

<picture class={`block h-full w-full ${className}`.trim()}>
  <source type="image/avif" srcset={source.avifSrcSet} sizes={sizes} />
  <source type="image/webp" srcset={source.webpSrcSet} sizes={sizes} />
  <img
    src={source.fallbackSrc}
    alt={alt}
    class="block h-full w-full object-cover"
    loading={loading}
    fetchpriority={fetchpriority}
    decoding={decoding}
    style={mergedStyle}
  />
</picture>
