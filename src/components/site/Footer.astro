---
import { CTA } from '../../lib/cta';

const year = new Date().getFullYear();
const pathname = Astro.url.pathname;

const routeLinkClass = (to: string) => {
  const active = pathname === to || pathname.startsWith(`${to}/`);
  return active ? 'text-white/80' : 'text-white/40 hover:text-white/80';
};

const contactLinkClass =
  'inline-flex min-h-11 items-center py-1 font-axiomMono text-[15px] md:text-sm leading-6 text-white/40 transition-colors duration-200 hover:text-white/80';
---

<footer class="w-full border-t border-[#31363B] bg-[#090A0B]">
  <div class="axiom-container py-10 md:py-12 lg:py-14">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1.08fr)_repeat(3,minmax(0,0.78fr))] lg:gap-10 xl:gap-12">
      <div class="max-w-md">
        <p class="text-2xl font-black leading-[1.02] tracking-tight text-[#F2F4F7] md:text-4xl">AXIOM</p>
        <p class="mt-3 max-w-md text-[15px] md:text-sm leading-6 text-slate-300">
          Built for businesses that are serious about growth.
        </p>
        <p class="mt-6 text-[15px] md:text-xs uppercase tracking-[0.12em] text-slate-400">
          &copy; {year} Axiom Infrastructure. All rights reserved.
        </p>
      </div>

      <nav class="space-y-3" aria-label="Site pages">
        <p class="section-eyebrow">Pages</p>
        <div class="space-y-1.5">
          <a href="/" class={routeLinkClass('/')}>Home</a>
          <a href={CTA.work.to} class={routeLinkClass('/work')}>Work</a>
          <a href={CTA.process.to} class={routeLinkClass('/process')}>Process</a>
          <a href="/about" class={routeLinkClass('/about')}>About</a>
          <a href="/pricing" class={routeLinkClass('/pricing')}>Pricing</a>
        </div>
      </nav>

      <nav class="space-y-3" aria-label="Contact">
        <p class="section-eyebrow">Contact</p>
        <div class="space-y-1.5">
          <a href={CTA.contact.to} class={routeLinkClass('/start-a-project')}>Contact</a>
          <div class="flex flex-wrap items-center gap-x-4 gap-y-1">
            <a href="mailto:contact@getaxiom.ca" class={contactLinkClass}>
              contact@getaxiom.ca
            </a>
            <a href="tel:+12267531833" class={contactLinkClass}>
              (226) 753-1833
            </a>
          </div>
        </div>
      </nav>

      <nav class="space-y-3 border-t border-white/[0.08] pt-5" aria-label="Legal">
        <p class="section-eyebrow">Legal</p>
        <div class="space-y-1.5">
          <a href="/privacy" class={routeLinkClass('/privacy')}>Privacy Policy</a>
          <a href="/terms" class={routeLinkClass('/terms')}>Terms of Service</a>
        </div>
      </nav>
    </div>
  </div>
</footer>
