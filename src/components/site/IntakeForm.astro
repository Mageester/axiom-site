---
type Kind = 'contact' | 'project';

type Props = {
  kind: Kind;
  endpoint: '/api/contact' | '/api/intake';
  title: string;
  eyebrow: string;
  description: string;
  helper: string;
  submitLabel: string;
  successTitle: string;
  successText: string;
  noteLinkHref: string;
  noteLinkLabel: string;
  noteText: string;
};

const {
  kind,
  endpoint,
  title,
  eyebrow,
  description,
  helper,
  submitLabel,
  successTitle,
  successText,
  noteLinkHref,
  noteLinkLabel,
  noteText,
} = Astro.props;

const fieldLabelClass = 'axiom-eyebrow text-[10px] text-[var(--text-muted)] md:text-[11px]';
const fieldHelpClass = 'text-[13px] leading-5 text-[var(--text-secondary)] md:text-xs';
const fieldErrorClass = 'min-h-[1.1em] text-[13px] leading-5 text-[#E7B2A8] md:text-xs';
---

<article class="overflow-hidden rounded-[var(--radius-card)] border border-[color:var(--hairline)] bg-[var(--surface-1)] shadow-[inset_0_1px_0_rgba(255,255,255,0.04),0_20px_56px_rgba(0,0,0,0.24)]">
  <div class="border-b border-[color:var(--hairline)] p-6 md:p-7 lg:p-8">
    <div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="section-eyebrow">{eyebrow}</p>
        <h2 class="mt-2 text-[28px] font-semibold tracking-[-0.01em] text-[var(--text-primary)]">{title}</h2>
      </div>
      <p class="text-[15px] leading-[1.65] text-[var(--text-secondary)]">{description}</p>
    </div>
  </div>

  <div class="p-6 md:p-7 lg:p-8">
    <div data-intake-success class="hidden rounded-[var(--radius-card)] border border-[color:var(--hairline)] bg-[var(--surface-2)] p-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] md:p-7" role="status" aria-live="polite">
      <div class="flex items-start gap-4">
        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-[#d4a48e]/30 bg-[#d4a48e]/12 text-[#d4a48e] shadow-[0_0_0_1px_rgba(212,164,142,0.08)]" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M20 6L9 17L4 12" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </div>
        <div class="min-w-0 text-left">
          <p class="section-eyebrow text-[var(--accent)]">{successTitle}</p>
          <h3 class="mt-2 text-[clamp(1.45rem,2.2vw,1.9rem)] font-semibold text-[var(--text-primary)]">Here&apos;s what happens next</h3>
          <p class="mt-2 text-[15px] md:text-sm leading-7 text-[var(--text-secondary)]">{successText}</p>
        </div>
      </div>

      <ol class="mt-6 space-y-3">
        <li class="flex gap-4 rounded-[var(--radius-card)] border border-[color:var(--hairline)] bg-white/[0.03] p-4">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-[color:var(--hairline)] bg-white/[0.04] text-[var(--accent)]" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path d="M20 6L9 17L4 12" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </div>
          <div class="min-w-0">
            <p class="font-medium text-[var(--text-primary)]">We review your submission</p>
            <p class="mt-1 text-[15px] md:text-sm leading-6 text-[var(--text-secondary)]">Checked internally and marked complete.</p>
          </div>
        </li>
        <li class="flex gap-4 rounded-[var(--radius-card)] border border-[color:var(--hairline)] bg-white/[0.03] p-4">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-[color:var(--hairline)] bg-white/[0.04] text-[var(--text-primary)]" aria-hidden="true">
            <span class="font-axiomDisplay text-[1rem] leading-none">2</span>
          </div>
          <div class="min-w-0">
            <p class="font-medium text-[var(--text-primary)]">You get a reply within 1 business day with our initial assessment</p>
            <p class="mt-1 text-[15px] md:text-sm leading-6 text-[var(--text-secondary)]">We&apos;ll review the scope, the site, and the fastest path forward.</p>
          </div>
        </li>
        <li class="flex gap-4 rounded-[var(--radius-card)] border border-[color:var(--hairline)] bg-white/[0.03] p-4">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-[color:var(--hairline)] bg-white/[0.04] text-[var(--text-primary)]" aria-hidden="true">
            <span class="font-axiomDisplay text-[1rem] leading-none">3</span>
          </div>
          <div class="min-w-0">
            <p class="font-medium text-[var(--text-primary)]">If there&apos;s a fit, we scope and quote - no commitment</p>
            <p class="mt-1 text-[15px] md:text-sm leading-6 text-[var(--text-secondary)]">You&apos;ll know the next step before making any decision.</p>
          </div>
        </li>
      </ol>

      <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a href="/work" class="btn-secondary btn-md inline-flex w-full justify-center sm:w-auto">
          While you wait, see our work {'→'}
        </a>
        <button
          type="button"
          data-intake-reset
          class="inline-flex min-h-11 items-center justify-center text-[15px] md:text-sm text-[var(--text-secondary)] underline decoration-white/40 underline-offset-2 transition-colors hover:text-white sm:w-auto"
        >
          Send another message
        </button>
      </div>
    </div>

    <form
      data-axiom-intake-form
      data-intake-kind={kind}
      data-intake-endpoint={endpoint}
      class="flex flex-col gap-5 md:gap-6"
      aria-busy="false"
      noValidate
    >
      <div data-intake-alert class="hidden rounded-[var(--radius-component)] border border-red-400/35 bg-red-500/10 px-4 py-3 text-[15px] md:text-sm text-red-100" role="alert" aria-live="assertive"></div>

      <fieldset class="contents">
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 md:gap-6">
          <div class="flex flex-col gap-1.5 md:gap-2" data-intake-field-group>
            <label for={`${kind}-name`} class={fieldLabelClass}>Name</label>
            <p id={`${kind}-name-helper`} class={fieldHelpClass}>Who should we address?</p>
            <input
              id={`${kind}-name`}
              name="name"
              type="text"
              required
              minLength="2"
              autoComplete="name"
              enterkeyhint="next"
              autocapitalize="words"
              spellcheck="false"
              class="data-intake-field"
              data-intake-field
              data-intake-field-key="name"
              data-intake-helper-id={`${kind}-name-helper`}
              data-intake-error-id={`${kind}-name-error`}
              data-intake-required-message="Please enter your name."
              data-intake-too-short-message="Please use at least 2 characters."
              aria-describedby={`${kind}-name-helper`}
            />
            <p id={`${kind}-name-error`} data-intake-field-error class={fieldErrorClass} hidden></p>
          </div>

          <div class="flex flex-col gap-1.5 md:gap-2" data-intake-field-group>
            <label for={`${kind}-email`} class={fieldLabelClass}>Email</label>
            <p id={`${kind}-email-helper`} class={fieldHelpClass}>Where should we reply?</p>
            <input
              id={`${kind}-email`}
              name="email"
              type="email"
              required
              autoComplete="email"
              enterkeyhint="next"
              autocapitalize="none"
              autocorrect="off"
              spellcheck="false"
              class="data-intake-field"
              data-intake-field
              data-intake-field-key="email"
              data-intake-helper-id={`${kind}-email-helper`}
              data-intake-error-id={`${kind}-email-error`}
              data-intake-required-message="Please enter an email address."
              data-intake-type-message="Please enter a valid email address."
              aria-describedby={`${kind}-email-helper`}
            />
            <p id={`${kind}-email-error`} data-intake-field-error class={fieldErrorClass} hidden></p>
          </div>

          <div class="flex flex-col gap-1.5 md:gap-2" data-intake-field-group>
            <label for={`${kind}-business`} class={fieldLabelClass}>Business name</label>
            <p id={`${kind}-business-helper`} class={fieldHelpClass}>Optional, if the reply should use a company name.</p>
            <input
              id={`${kind}-business`}
              name="business_name"
              type="text"
              autoComplete="organization"
              enterkeyhint="next"
              autocapitalize="words"
              spellcheck="false"
              class="data-intake-field"
              data-intake-field
              data-intake-field-key="business_name"
              data-intake-helper-id={`${kind}-business-helper`}
              data-intake-error-id={`${kind}-business-error`}
              aria-describedby={`${kind}-business-helper`}
            />
            <p id={`${kind}-business-error`} data-intake-field-error class={fieldErrorClass} hidden></p>
          </div>

          {kind === 'project' ? (
            <div class="flex flex-col gap-1.5 md:gap-2" data-intake-field-group>
              <label for={`${kind}-website`} class={fieldLabelClass}>Website URL</label>
              <p id={`${kind}-website-helper`} class={fieldHelpClass}>Optional. Add it if there is already a site.</p>
              <input
                id={`${kind}-website`}
                name="current_website"
                type="url"
                placeholder="https://example.com"
                autoComplete="url"
                enterkeyhint="next"
                autocapitalize="none"
                autocorrect="off"
                spellcheck="false"
                class="data-intake-field"
                data-intake-field
                data-intake-field-key="current_website"
                data-intake-helper-id={`${kind}-website-helper`}
                data-intake-error-id={`${kind}-website-error`}
                data-intake-type-message="Please enter a valid website URL."
                aria-describedby={`${kind}-website-helper`}
              />
              <p id={`${kind}-website-error`} data-intake-field-error class={fieldErrorClass} hidden></p>
            </div>
          ) : (
            <div class="flex flex-col gap-1.5 md:gap-2" data-intake-field-group>
              <label for={`${kind}-website`} class={fieldLabelClass}>Website URL</label>
              <p id={`${kind}-website-helper`} class={fieldHelpClass}>Optional. Add it if you are following up on an existing site.</p>
              <input
                id={`${kind}-website`}
                name="current_website"
                type="url"
                placeholder="https://example.com"
                autoComplete="url"
                enterkeyhint="next"
                autocapitalize="none"
                autocorrect="off"
                spellcheck="false"
                class="data-intake-field"
                data-intake-field
                data-intake-field-key="current_website"
                data-intake-helper-id={`${kind}-website-helper`}
                data-intake-error-id={`${kind}-website-error`}
                data-intake-type-message="Please enter a valid website URL."
                aria-describedby={`${kind}-website-helper`}
              />
              <p id={`${kind}-website-error`} data-intake-field-error class={fieldErrorClass} hidden></p>
            </div>
          )}
        </div>

        <div class="flex flex-col gap-1.5 md:gap-2" data-intake-field-group>
          <label for={`${kind}-details`} class={fieldLabelClass}>
            {kind === 'project' ? 'Brief project description' : 'Message'}
          </label>
          <p id={`${kind}-details-helper`} class={fieldHelpClass}>
            {helper}
          </p>
          <textarea
            id={`${kind}-details`}
            name={kind === 'project' ? 'details' : 'message'}
            rows="5"
            required
            minLength="10"
            placeholder={kind === 'project' ? 'What does your business do, what is wrong with the current site, and when do you want to move?' : 'Tell us what you need help with.'}
            enterkeyhint="send"
            class="data-intake-field data-intake-textarea"
            data-intake-field
            data-intake-field-key={kind === 'project' ? 'details' : 'message'}
            data-intake-helper-id={`${kind}-details-helper`}
            data-intake-error-id={`${kind}-details-error`}
            data-intake-required-message={kind === 'project' ? 'Please share a little more detail.' : 'Please add a message.'}
            data-intake-too-short-message="Please share a little more detail."
            aria-describedby={`${kind}-details-helper`}
          ></textarea>
          <p id={`${kind}-details-error`} data-intake-field-error class={fieldErrorClass} hidden></p>
        </div>
      </fieldset>

      <input type="hidden" name="source_path" value={Astro.url.pathname + Astro.url.search} />

      <div class="flex flex-col gap-4">
        <button type="submit" class="btn-primary btn-lg w-full rounded-[1rem]">
          {submitLabel}
        </button>
        <p class="text-[13px] leading-5 text-slate-400 md:text-sm">{noteText} <a href={noteLinkHref} class="underline decoration-white/40 underline-offset-2 transition-colors hover:text-white">{noteLinkLabel}</a>.</p>
      </div>
    </form>
  </div>
</article>

<style>
  [data-axiom-intake-form] {
    --intake-field-border: var(--hairline);
    --intake-field-border-hover: rgba(255, 255, 255, 0.1);
    --intake-field-border-focus: rgba(232, 162, 123, 0.42);
    --intake-field-border-error: rgba(228, 130, 121, 0.42);
    --intake-field-bg: var(--surface-2);
    --intake-field-bg-hover: #1a1a20;
    --intake-field-bg-focus: #1d1d24;
  }

  [data-axiom-intake-form] [data-intake-field] {
    appearance: none;
    -webkit-appearance: none;
    width: 100%;
    min-height: 3.5rem;
    border-radius: 10px;
    border: 1px solid var(--intake-field-border);
    background: var(--intake-field-bg);
    padding: 0.875rem 1rem;
    color: #f2f4f7;
    font-size: 16px;
    line-height: 1.5;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.03),
      0 1px 0 rgba(255, 255, 255, 0.01);
    caret-color: #f2f4f7;
  }

  [data-axiom-intake-form] [data-intake-field].data-intake-textarea {
    min-height: 10.5rem;
    resize: vertical;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }

  [data-axiom-intake-form] [data-intake-field]::placeholder {
    color: rgba(148, 163, 184, 0.78);
    opacity: 1;
  }

  [data-axiom-intake-form] [data-intake-field]:hover:not(:disabled) {
    border-color: var(--intake-field-border-hover);
    background: var(--intake-field-bg-hover);
  }

  [data-axiom-intake-form] [data-intake-field]:focus-visible {
    border-color: var(--intake-field-border-focus);
    background: var(--intake-field-bg-focus);
    box-shadow:
      0 0 0 2px rgba(232, 162, 123, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    outline: none;
  }

  [data-axiom-intake-form] [data-intake-field][aria-invalid='true'] {
    border-color: var(--intake-field-border-error);
  }

  [data-axiom-intake-form] [data-intake-field][aria-invalid='true']:focus-visible {
    border-color: var(--intake-field-border-focus);
    box-shadow:
      0 0 0 3px rgba(212, 164, 142, 0.14),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  [data-axiom-intake-form] [data-intake-field]:disabled {
    cursor: not-allowed;
    opacity: 0.72;
  }

  [data-axiom-intake-form] [data-intake-field-error]:not([hidden]) {
    display: block;
  }

  [data-axiom-intake-form] [data-intake-alert]:not([hidden]) {
    display: block;
  }

  [data-axiom-intake-form] [data-intake-success] {
    scroll-margin-top: 6rem;
  }

  [data-axiom-intake-form] input:-webkit-autofill,
  [data-axiom-intake-form] input:-webkit-autofill:hover,
  [data-axiom-intake-form] input:-webkit-autofill:focus,
  [data-axiom-intake-form] textarea:-webkit-autofill,
  [data-axiom-intake-form] textarea:-webkit-autofill:hover,
  [data-axiom-intake-form] textarea:-webkit-autofill:focus {
    -webkit-text-fill-color: #f2f4f7;
    caret-color: #f2f4f7;
    box-shadow: 0 0 0px 1000px rgba(12, 17, 27, 0.98) inset;
    transition: background-color 9999s ease-in-out 0s, color 9999s ease-in-out 0s;
  }

  [data-axiom-intake-form] button[type='submit']:focus-visible {
    box-shadow:
      0 0 0 2px rgba(232, 162, 123, 0.2),
      0 8px 24px rgba(0, 0, 0, 0.28);
  }
</style>

<script is:inline>
  const initIntakeForms = () => {
    const forms = document.querySelectorAll('[data-axiom-intake-form]');
    const FIELD_CONFIG = {
      name: {
        required: 'Please enter your name.',
        tooShort: 'Please use at least 2 characters.'
      },
      email: {
        required: 'Please enter an email address.',
        typeMismatch: 'Please enter a valid email address.'
      },
      business_name: {},
      current_website: {
        typeMismatch: 'Please enter a valid website URL.'
      },
      details: {
        required: 'Please share a little more detail.',
        tooShort: 'Please share a little more detail.'
      },
      message: {
        required: 'Please add a message.',
        tooShort: 'Please share a little more detail.'
      }
    };

    const updateFieldState = (form, field, force = false) => {
      if (!(field instanceof HTMLElement)) return true;

      const key = field.dataset.intakeFieldKey || '';
      const helperId = field.dataset.intakeHelperId || '';
      const errorId = field.dataset.intakeErrorId || '';
      const errorEl = errorId ? form.querySelector(`#${errorId}`) : null;
      const isTouched = force || field.dataset.touched === 'true' || form.dataset.validationAttempted === 'true';
      let error = '';

      if (isTouched && 'validity' in field) {
        const config = FIELD_CONFIG[key] || {};
        if (field.validity.valueMissing) {
          error = config.required || 'Please complete this field.';
        } else if (field.validity.typeMismatch) {
          error = config.typeMismatch || 'Please enter a valid value.';
        } else if (field.validity.tooShort) {
          error = config.tooShort || 'Please use a longer value.';
        }
      }

      if (errorEl instanceof HTMLElement) {
        errorEl.textContent = error;
        errorEl.hidden = !error;
      }

      if (field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement) {
        if (error) {
          field.setAttribute('aria-invalid', 'true');
          field.dataset.fieldState = 'invalid';
        } else {
          field.removeAttribute('aria-invalid');
          delete field.dataset.fieldState;
        }

        if (helperId) {
          field.setAttribute('aria-describedby', error ? `${helperId} ${errorId}` : helperId);
        }
      }

      return error.length === 0;
    };

    forms.forEach((form) => {
      if (!(form instanceof HTMLFormElement)) return;
      if (form.dataset.intakeInitialized === 'true') return;
      form.dataset.intakeInitialized = 'true';
      form.dataset.validationAttempted = 'false';

      const endpoint = form.dataset.intakeEndpoint || '/api/contact';
      const alertBox = form.querySelector('[data-intake-alert]');
      const successBox = form.closest('article')?.querySelector('[data-intake-success]');
      const resetButton = form.closest('article')?.querySelector('[data-intake-reset]');
      const submitButton = form.querySelector('button[type="submit"]');
      const fields = Array.from(form.querySelectorAll('[data-intake-field]'));

      const showAlert = (message) => {
        if (!(alertBox instanceof HTMLElement)) return;
        alertBox.textContent = message;
        alertBox.classList.remove('hidden');
      };

      const clearAlert = () => {
        if (!(alertBox instanceof HTMLElement)) return;
        alertBox.textContent = '';
        alertBox.classList.add('hidden');
      };

      const syncAllFieldStates = (force = false) => {
        let firstInvalidField = null;
        let hasErrors = false;

        fields.forEach((field) => {
          const isValid = updateFieldState(form, field, force);
          if (!isValid && !firstInvalidField) {
            firstInvalidField = field;
          }
          if (!isValid) {
            hasErrors = true;
          }
        });

        return { firstInvalidField, hasErrors };
      };

      const setBusy = (busy) => {
        form.setAttribute('aria-busy', String(busy));
        form.dataset.submitting = String(busy);
        fields.forEach((field) => {
          if (field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement) {
            field.disabled = busy;
          }
        });
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = busy;
          submitButton.textContent = busy ? 'Sending...' : form.dataset.intakeKind === 'project' ? 'Send it →' : 'Send message →';
        }
      };

      const resetToForm = () => {
        form.reset();
        clearAlert();
        form.dataset.validationAttempted = 'false';
        delete form.dataset.submitting;
        fields.forEach((field) => {
          if (field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement) {
            field.disabled = false;
            field.dataset.touched = 'false';
            field.removeAttribute('aria-invalid');
            delete field.dataset.fieldState;
            const errorId = field.dataset.intakeErrorId || '';
            const errorEl = errorId ? form.querySelector(`#${errorId}`) : null;
            if (errorEl instanceof HTMLElement) {
              errorEl.textContent = '';
              errorEl.hidden = true;
            }
          }
        });
        if (successBox instanceof HTMLElement) {
          successBox.classList.add('hidden');
        }
        form.classList.remove('hidden');
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
        }
      };

      if (resetButton instanceof HTMLButtonElement) {
        resetButton.addEventListener('click', resetToForm);
      }

      fields.forEach((field) => {
        if (!(field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement)) return;

        field.addEventListener('blur', () => {
          field.dataset.touched = 'true';
          updateFieldState(form, field);
        });

        field.addEventListener('input', () => {
          if (field.dataset.touched === 'true' || form.dataset.validationAttempted === 'true') {
            updateFieldState(form, field);
          }
        });
      });

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        form.dataset.validationAttempted = 'true';
        clearAlert();
        const { firstInvalidField, hasErrors } = syncAllFieldStates(true);

        if (hasErrors) {
          showAlert('Please review the highlighted fields.');
          if (firstInvalidField instanceof HTMLElement) {
            window.requestAnimationFrame(() => {
              firstInvalidField.focus({ preventScroll: false });
            });
          }
          return;
        }

        setBusy(true);

        const formData = new FormData(form);
        const payload = Object.fromEntries(formData.entries());

        const body = form.dataset.intakeKind === 'project'
          ? {
              name: String(payload.name || '').trim(),
              email: String(payload.email || '').trim(),
              business_name: String(payload.business_name || '').trim(),
              current_website: String(payload.current_website || '').trim(),
              details: String(payload.details || '').trim(),
              primary_goal: 'new_site',
              source_path: String(payload.source_path || '').trim(),
            }
          : {
              name: String(payload.name || '').trim(),
              email: String(payload.email || '').trim(),
              business_name: String(payload.business_name || '').trim(),
              message: String(payload.message || '').trim(),
              source_path: String(payload.source_path || '').trim(),
            };

        try {
          const response = await fetch(endpoint, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json',
            },
            body: JSON.stringify(body),
          });

          const result = await response.json().catch(() => null);
          if (!response.ok || !result || result.ok === false) {
            const message = result?.details ? `${result.error || 'Submission failed'} ${result.details}` : result?.error || 'Submission failed';
            showAlert(message);
            setBusy(false);
            return;
          }

          if (successBox instanceof HTMLElement) {
            successBox.classList.remove('hidden');
          }
          form.classList.add('hidden');
          setBusy(false);
        } catch (error) {
          showAlert('Something went wrong. Please email contact@getaxiom.ca.');
          setBusy(false);
        }
      });

      syncAllFieldStates(false);
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initIntakeForms, { once: true });
  } else {
    initIntakeForms();
  }
</script>

