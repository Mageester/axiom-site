---
interface Props {
  name: 'eye' | 'shield-check' | 'bolt' | 'key' | 'target' | 'crown' | 'refresh';
  className?: string;
}

const { name, className = "" } = Astro.props;
---

<svg
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={`draw-icon h-[22px] w-[22px] text-white ${className}`}
  data-draw-icon
  aria-hidden="true"
>
  {name === 'eye' && (
    <>
      <path pathLength="1" d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" />
      <circle pathLength="1" cx="12" cy="12" r="3" />
    </>
  )}
  {name === 'shield-check' && (
    <>
      <path pathLength="1" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" />
      <path pathLength="1" d="m9 12 2 2 4-4" />
    </>
  )}
  {name === 'bolt' && (
    <path pathLength="1" d="M13 2 3 14h9l-1 8 10-12h-9l1-8Z" />
  )}
  {name === 'key' && (
    <>
      <circle pathLength="1" cx="7.5" cy="15.5" r="5.5" />
      <path pathLength="1" d="m21 2-9.6 9.6" />
      <path pathLength="1" d="m15.5 7.5 3 3" />
      <path pathLength="1" d="m17.5 5.5 3 3" />
    </>
  )}
  {name === 'target' && (
    <>
      <circle pathLength="1" cx="12" cy="12" r="10" />
      <circle pathLength="1" cx="12" cy="12" r="6" />
      <circle pathLength="1" cx="12" cy="12" r="2" />
    </>
  )}
  {name === 'crown' && (
    <path pathLength="1" d="m2 4 3 12h14L22 4l-5 6-5-10-5 10-5-6Z" />
  )}
  {name === 'refresh' && (
    <>
      <path pathLength="1" d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8" />
      <path pathLength="1" d="M21 3v5h-5" />
    </>
  )}
</svg>

<style is:global>
  .draw-icon path,
  .draw-icon circle {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    transition: stroke-dashoffset 1.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .draw-icon.is-active path,
  .draw-icon.is-active circle {
    stroke-dashoffset: 0;
  }
</style>
