---
import SiteLayout from '../layouts/SiteLayout.astro';
import { CTA_PATHS } from '../lib/cta';
import { SEO_ROUTES, WORK_JSON_LD, breadcrumbSchema, SITE_URL } from '../lib/seo';
import { getWorkProofImage } from '../lib/workProofImages';
import { FadeIn } from '../components/ui/FadeIn';
import { Button } from '../components/ui/button';
import { Card } from '../components/ui/card';
import { Eyebrow } from '../components/ui/Eyebrow';
import { MotionHeading } from '../components/motion/MotionHeading';
import { SectionDivider } from '../components/motion/SectionDivider';
import { WorkShowcase } from '../components/motion/WorkShowcase';

const featuredBuilds = [
  {
    eyebrow: 'CONCEPT BUILD / LEGAL SERVICES',
    title: 'Harrow & Calloway',
    category: 'legal',
    originalWeakness: 'Most law firm sites are walls of text. Visitors bounce before they find the offer.',
    axiomChanged: 'Cleaner hierarchy, shorter copy, one obvious path to a consultation.',
    whyItWorks: 'Clients land on a page they can actually read. The consult button is never more than a scroll away.',
    image: getWorkProofImage('concept-law-demo').source,
    alt: getWorkProofImage('concept-law-demo').alt || 'Harrow & Calloway',
    position: 'center 40%',
    href: 'https://law.getaxiom.ca',
  },
  {
    eyebrow: 'CONCEPT BUILD / HEALTHCARE & MEDICAL',
    title: 'Aurelia Dental Studio',
    category: 'other',
    originalWeakness: 'Most medical sites feel cold and clinical - and make booking harder than it should be.',
    axiomChanged: 'Warmer presentation, trust-forward layout, one-tap booking from every page.',
    whyItWorks: 'New patients book without second-guessing. Returning patients find what they need in seconds.',
    image: getWorkProofImage('concept-dental-demo').source,
    alt: getWorkProofImage('concept-dental-demo').alt || 'Aurelia Dental Studio',
    position: 'center 40%',
    href: 'https://dental.getaxiom.ca',
  },
  {
    eyebrow: 'CONCEPT BUILD / PERSONAL SERVICES & GROOMING',
    title: 'Blackline Barber Co.',
    category: 'sales-beauty',
    originalWeakness: 'Most barbershop sites look dated and bury the booking link.',
    axiomChanged: 'Sharp branding, big photos, one-tap booking at the top of every page.',
    whyItWorks: 'Clients book in a tap. The brand looks like the shop actually feels.',
    image: getWorkProofImage('concept-barber-demo').source,
    alt: getWorkProofImage('concept-barber-demo').alt || 'Blackline Barber Co.',
    position: 'center 40%',
    href: 'https://barber.getaxiom.ca',
  },
  {
    eyebrow: 'CONCEPT BUILD / SALON & BEAUTY',
    title: 'Nails Studio Demo',
    category: 'sales-beauty',
    originalWeakness: 'Most salon sites hide the booking button and undersell the service.',
    axiomChanged: 'Booking is front and center. Clean photography. Premium positioning without the fluff.',
    whyItWorks: 'Clients book faster. The brand reads as higher-end at a glance.',
    image: getWorkProofImage('concept-salon-demo').source,
    alt: getWorkProofImage('concept-salon-demo').alt || 'Nails Studio Demo',
    position: 'center 40%',
    href: 'https://nails.getaxiom.ca',
  },
  {
    eyebrow: 'CONCEPT BUILD / RESTAURANT & HOSPITALITY',
    title: 'Restaurant reservation concept.',
    category: 'food-hospitality',
    originalWeakness: 'Guests had to hunt for the reservation link, and the menu was hard to read on a phone.',
    axiomChanged: 'Menu and reservation path both live above the fold. Fast mobile load.',
    whyItWorks: 'Guests book or check the menu without digging. Decisions happen faster, usually at the table.',
    image: getWorkProofImage('demonstration-restaurant-reservation-site').source,
    alt: getWorkProofImage('demonstration-restaurant-reservation-site').alt || 'Restaurant reservation site',
    position: 'center 24%',
    href: 'https://restaurant.getaxiom.ca',
  },
  {
    eyebrow: 'CONCEPT BUILD / LANDSCAPING & OUTDOOR SERVICES',
    title: 'Landscaping concept.',
    category: 'home-services',
    originalWeakness: 'Past work was buried, and the quote form took too many clicks.',
    axiomChanged: 'Project photos come forward. Quote form is two fields and a button.',
    whyItWorks: 'Homeowners judge the quality fast and request a quote without friction.',
    image: getWorkProofImage('concept-landscaping-authority-site').source,
    alt: getWorkProofImage('concept-landscaping-authority-site').alt || 'Landscaping authority site',
    position: 'center 52%',
    href: 'https://landscaping.getaxiom.ca',
  },
  {
    eyebrow: 'CONCEPT BUILD / ROOFING & EXTERIORS',
    title: 'Roofing concept.',
    category: 'home-services',
    originalWeakness: 'Storm traffic needs a fast path to inspection and estimate - most sites make them dig.',
    axiomChanged: 'Urgent calls and planned estimates get separate, obvious paths.',
    whyItWorks: 'Emergency jobs book by phone. Planned jobs submit online. No one reads the same page twice.',
    image: getWorkProofImage('concept-roofing-conversion-site').source,
    alt: getWorkProofImage('concept-roofing-conversion-site').alt || 'Roofing conversion site',
    position: 'center 36%',
    href: 'https://roofing.getaxiom.ca',
  },
] as const;

const workFilters = [
  { label: 'All', value: 'all' },
  { label: 'Sales & Beauty', value: 'sales-beauty' },
  { label: 'Legal', value: 'legal' },
  { label: 'Food & Hospitality', value: 'food-hospitality' },
  { label: 'Home Services', value: 'home-services' },
  { label: 'Other', value: 'other' },
] as const;
---

<SiteLayout
  title={SEO_ROUTES.work.title}
  description={SEO_ROUTES.work.description}
  canonicalPath="/work"
  schema={[WORK_JSON_LD, breadcrumbSchema([{ name: 'Home', url: SITE_URL }, { name: 'Work', url: `${SITE_URL}/work` }])]}
>
  <main id="main-content" tabindex="-1" class="-mt-28 pb-0 md:-mt-32">
    <section class="axiom-container pt-20 md:pt-28">
      <div class="max-w-3xl">
        <FadeIn motion="eyebrow">
          <Eyebrow>WORK</Eyebrow>
          <SectionDivider className="mt-6" />
        </FadeIn>
        <FadeIn motion="sceneOpen" delay={180}>
          <MotionHeading as="h1" text="Concept builds. Same standard. Every sector." className="mt-4" />
        </FadeIn>
        <FadeIn motion="editorialMaskReveal" delay={500}>
          <p class="section-copy mt-5 md:text-[17px]">
            These are concept builds, not live client work. Each one shows how we'd rebuild a typical site in that
            industry - cleaner offer, faster load, and a path to booking that actually converts.
          </p>
        </FadeIn>
        <FadeIn motion="sceneOpen" delay={720}>
          <div class="mt-7">
            <Button asChild size="lg">
              <a href={CTA_PATHS.startProject}>Start a project</a>
            </Button>
          </div>
        </FadeIn>
      </div>
    </section>

    <section class="py-10 md:py-12 section-shell">
      <div class="axiom-container">
        <WorkShowcase client:visible builds={featuredBuilds} filters={workFilters} />
      </div>
    </section>

    <section class="py-10 md:py-12">
      <div class="axiom-container">
        <FadeIn as="div" motion="editorialMaskReveal" className="mx-auto grid max-w-5xl gap-5 border-y border-[color:var(--hairline)] py-8 md:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)] md:items-center">
          <p class="font-accent text-[clamp(1.35rem,2vw,2rem)] leading-[1.14] text-[var(--text-primary)]">
            These aren't real client outcomes — they're how we'd build it. Same approach every time: sharper hierarchy, faster decisions, one clear path to action. No invented results.
          </p>
          <p class="section-copy md:justify-self-end">
            Each build shows the same operating pattern: sharper hierarchy, faster decisions, and one clear path to action without inventing results.
          </p>
        </FadeIn>
      </div>
    </section>

    <section class="page-section-tight section-shell">
      <div class="axiom-container">
        <FadeIn as="div" motion="finalFrameFooter">
          <Card className="mx-auto max-w-5xl p-0">
            <div class="px-6 py-8 sm:px-8 sm:py-10 md:px-10 md:py-12">
              <Eyebrow>THE GUARANTEE</Eyebrow>
              <SectionDivider className="mt-6" />
              <MotionHeading as="h2" text="Ready to stop losing jobs to a weaker site?" className="section-heading mt-4" />
              <p class="section-copy mt-4">
                That is the floor we build to.
              </p>
              <div class="mt-7 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                <Button asChild>
                  <a href={CTA_PATHS.startProject}>See if we're a fit</a>
                </Button>
                <p class="axiom-metric text-[var(--text-muted)]">Review &rarr; Scope &rarr; Build &rarr; Launch</p>
              </div>
            </div>
          </Card>
        </FadeIn>
      </div>
    </section>
  </main>
</SiteLayout>
