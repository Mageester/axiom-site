---
import ResponsivePicture from '../components/site/ResponsivePicture.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { SEO_ROUTES } from '../lib/seo';
import { getWorkProofImage } from '../lib/workProofImages';
import { Button } from '../components/ui/button';
import { Card } from '../components/ui/card';
import { Eyebrow } from '../components/ui/Eyebrow';
import type { CSSProperties } from 'react';

const featuredBuilds = [
  {
    eyebrow: 'BUILD CONCEPT · RESTAURANT & HOSPITALITY',
    title: 'A reservation site that does not hide the booking.',
    originalWeakness: 'Guests had to hunt for the booking link, and the menu was hard to read on phones.',
    axiomChanged: 'The reservation path stays visible and the menu reads cleanly on mobile.',
    whyItWorks:
      'People can book or check the menu without digging through the page, which matters when the decision happens fast.',
    image: getWorkProofImage('demonstration-restaurant-reservation-site').source,
    alt: getWorkProofImage('demonstration-restaurant-reservation-site').alt ?? 'Restaurant reservation site',
    position: 'center 24%',
    href: 'https://restaurant.getaxiom.ca',
  },
  {
    eyebrow: 'BUILD CONCEPT · LANDSCAPING & OUTDOOR SERVICES',
    title: 'A landscaping site that puts the work in front.',
    originalWeakness: 'Past work was buried, and quote requests took too many clicks.',
    axiomChanged: 'Project photos come forward and the quote path is shorter.',
    whyItWorks: 'Buyers can judge the quality first and request a quote without digging through pages.',
    image: getWorkProofImage('concept-landscaping-authority-site').source,
    alt: getWorkProofImage('concept-landscaping-authority-site').alt ?? 'Landscaping authority site',
    position: 'center 52%',
    href: 'https://landscaping.getaxiom.ca',
  },
  {
    eyebrow: 'BUILD CONCEPT · ROOFING & EXTERIORS',
    title: 'A roofing site that separates urgent from planned.',
    originalWeakness: 'Storm traffic needs a fast path to inspection and estimate requests.',
    axiomChanged: 'Urgent calls and planned estimates have separate paths.',
    whyItWorks: 'Different visitors need different actions, so the page removes friction instead of making everyone read the same route.',
    image: getWorkProofImage('concept-roofing-conversion-site').source,
    alt: getWorkProofImage('concept-roofing-conversion-site').alt ?? 'Roofing conversion site',
    position: 'center 36%',
    href: 'https://roofing.getaxiom.ca',
  },
] as const;

const conceptProjects = [
  {
    eyebrow: 'HVAC PERFORMANCE',
    subtitle: 'Apex Climate Systems',
    title: 'Dispatch-first infrastructure for urgent HVAC demand.',
    outcome: 'Designed to lift emergency dispatch rates during peak weather events.',
    bullets: ['Emergency dispatch banner', 'Diagnostic intake routing', 'Dispatch qualification filter'],
    href: 'https://hvac.getaxiom.ca',
  },
  {
    eyebrow: 'ROOFING PERFORMANCE',
    subtitle: 'Summit Roofing Co.',
    title: 'Storm protocol conversion system for inspection demand.',
    outcome: "Designed to capture storm-season leads while competitors' sites go down.",
    bullets: ['Storm protocol timeline', 'Material selector', 'Inspection funnel'],
    href: 'https://roofing.getaxiom.ca',
  },
  {
    eyebrow: 'LANDSCAPING PERFORMANCE',
    subtitle: 'Verdant Landscapes',
    title: 'Portfolio-grade consultation system for premium outdoor projects.',
    outcome: 'Designed to position premium design work with a portfolio that matches the craft.',
    bullets: ['Featured project portfolio', 'Seasonal program flow', 'Design consultation funnel'],
    href: 'https://landscaping.getaxiom.ca',
  },
] as const;
---

<SiteLayout title={SEO_ROUTES.work.title} description={SEO_ROUTES.work.description} canonicalPath="/work">
  <main id="main-content" tabindex="-1" class="-mt-28 md:-mt-32 pb-24 md:pb-32">
    <section class="axiom-container pt-12 md:pt-20">
      <div class="max-w-3xl">
        <Eyebrow>WORK</Eyebrow>
        <h1 class="mt-4">The standard we build to.</h1>
        <p class="mt-5 max-w-2xl text-[15px] leading-[1.65] text-[var(--text-secondary)] md:text-[17px]">
          Every project is built to convert, load fast, and stay easy to run. These are the concepts that show what that
          looks like.
        </p>
        <div class="mt-7">
          <Button asChild size="lg">
            <a href="/start">Start a project</a>
          </Button>
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container space-y-8 md:space-y-10">
        {featuredBuilds.map((build, index) => {
          const imageFirst = index % 2 === 0;

          return (
            <article class="overflow-hidden rounded-[var(--radius-card)] border border-[color:var(--hairline)] bg-[var(--surface-1)] shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
              <div class={`grid gap-0 lg:grid-cols-2 ${imageFirst ? '' : ''}`}>
                <figure class={`relative overflow-hidden border-[color:var(--hairline)] ${imageFirst ? 'lg:border-r' : 'lg:order-2 lg:border-l'}`}>
                  <ResponsivePicture
                    source={build.image}
                    alt={build.alt}
                    sizes="(min-width: 1280px) 50vw, 100vw"
                    class="aspect-[4/3] h-full w-full object-cover transition-transform duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] hover:scale-[1.03]"
                    loading={index === 0 ? 'eager' : 'lazy'}
                    fetchpriority={index === 0 ? 'high' : 'low'}
                    objectPosition={build.position}
                  />
                  <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/18 via-transparent to-transparent" />
                </figure>

                <div class={`flex h-full flex-col p-6 sm:p-8 lg:p-10 ${imageFirst ? '' : 'lg:order-1'}`}>
                  <Eyebrow>{build.eyebrow}</Eyebrow>
                  <h2 class="mt-4 max-w-xl text-[clamp(32px,4vw,52px)] font-[500] leading-[1.08] tracking-[-0.025em] text-[var(--text-primary)]">
                    {build.title}
                  </h2>

                  <dl class="mt-8 space-y-5">
                    <div class="space-y-2">
                      <dt class="axiom-metric text-[var(--text-muted)]">ORIGINAL WEAKNESS</dt>
                      <dd class="text-[15px] leading-[1.65] text-[var(--text-secondary)]">{build.originalWeakness}</dd>
                    </div>
                    <div class="space-y-2 border-t border-[color:var(--hairline)] pt-5">
                      <dt class="axiom-metric text-[var(--text-muted)]">AXIOM CHANGED</dt>
                      <dd class="text-[15px] leading-[1.65] text-[var(--text-secondary)]">{build.axiomChanged}</dd>
                    </div>
                    <div class="space-y-2 border-t border-[color:var(--hairline)] pt-5">
                      <dt class="axiom-metric text-[var(--text-muted)]">WHY IT WORKS</dt>
                      <dd class="text-[15px] leading-[1.65] text-[var(--text-secondary)]">{build.whyItWorks}</dd>
                    </div>
                  </dl>

                  <div class="mt-8">
                    <Button asChild variant="ghost" className="px-0">
                      <a href={build.href} target="_blank" rel="noopener noreferrer">
                        View the build ->
                      </a>
                    </Button>
                  </div>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <div class="max-w-3xl">
          <Eyebrow>CONCEPT LIBRARY</Eyebrow>
          <h2 class="mt-4 max-w-2xl">More concepts. Same standard.</h2>
        </div>

        <div class="mt-10 grid gap-5 lg:grid-cols-3">
          {conceptProjects.map((project, index) => (
            <Card
              data-reveal
              data-reveal-item
              data-reveal-state="hidden"
              style={{ '--reveal-delay': `${index * 80}ms` } as CSSProperties}
              className="h-full p-0"
            >
              <div class="flex h-full flex-col p-6 sm:p-7">
                <Eyebrow>{project.eyebrow}</Eyebrow>
                <p class="mt-4 text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--text-muted)]">
                  {project.subtitle}
                </p>
                <h3 class="mt-3 text-[22px] font-semibold tracking-[-0.01em] text-[var(--text-primary)]">
                  {project.title}
                </h3>
                <p class="mt-4 text-[15px] leading-[1.65] text-[var(--text-secondary)]">{project.outcome}</p>

                <ul class="mt-5 space-y-3">
                  {project.bullets.map((bullet) => (
                    <li class="flex items-start gap-2 text-[15px] leading-[1.65] text-[var(--text-secondary)]">
                      <span class="mt-[0.55rem] h-1.5 w-1.5 rounded-full bg-[var(--accent)]" />
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>

                <div class="mt-auto pt-6">
                  <Button asChild variant="ghost" className="px-0">
                    <a href={project.href} target="_blank" rel="noopener noreferrer">
                      Open project ->
                    </a>
                  </Button>
                </div>
              </div>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <Card className="mx-auto max-w-5xl p-0">
          <div class="px-6 py-8 sm:px-8 sm:py-10 md:px-10 md:py-12">
            <Eyebrow>THE GUARANTEE</Eyebrow>
            <h2 class="mt-4 max-w-4xl">Ready to stop losing jobs to a weaker site?</h2>
            <p class="mt-4 max-w-2xl text-[15px] leading-[1.65] text-[var(--text-secondary)]">
              No asterisks. That is the floor we build to.
            </p>
            <div class="mt-7 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
              <Button asChild>
                <a href="/start">Start a project</a>
              </Button>
              <p class="axiom-metric text-[var(--text-muted)]">Review -> Scope -> Build -> Launch</p>
            </div>
          </div>
        </Card>
      </div>
    </section>
  </main>
</SiteLayout>
