---
import ResponsivePicture from '../components/site/ResponsivePicture.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { SEO_ROUTES } from '../lib/seo';
import { getWorkProofImage } from '../lib/workProofImages';
import { FadeIn } from '../components/ui/FadeIn';
import { Button } from '../components/ui/button';
import { Card } from '../components/ui/card';
import { Eyebrow } from '../components/ui/Eyebrow';

const featuredBuilds = [
  {
    eyebrow: 'CONCEPT BUILD \u00b7 LEGAL SERVICES',
    title: 'Harrow & Calloway',
    category: 'legal',
    originalWeakness: 'Legal websites are often text-heavy and fail to establish immediate trust before the first scroll.',
    axiomChanged: 'Created a calm, professional environment with stronger hierarchy and a clear path to consultation.',
    whyItWorks: 'A premium law firm concept built around trust, a readable offer, and a consultation path that stays obvious.',
    image: getWorkProofImage('concept-law-demo').source,
    alt: getWorkProofImage('concept-law-demo').alt || 'Harrow & Calloway',
    position: 'center 40%',
    href: 'https://law.getaxiom.ca',
  },
  {
    eyebrow: 'CONCEPT BUILD \u00b7 HEALTHCARE & MEDICAL',
    title: 'Aurelia Dental Studio',
    category: 'other',
    originalWeakness: 'Dental sites often feel clinical, cold, and make booking feel more difficult than it should.',
    axiomChanged: 'A calm, trust-focused presentation paired with a polished, high-speed booking experience.',
    whyItWorks: 'A premium dental clinic concept built to reduce anxiety, surface trust early, and keep booking easy.',
    image: getWorkProofImage('concept-dental-demo').source,
    alt: getWorkProofImage('concept-dental-demo').alt || 'Aurelia Dental Studio',
    position: 'center 40%',
    href: 'https://dental.getaxiom.ca',
  },
  {
    eyebrow: 'CONCEPT BUILD \u00b7 PERSONAL SERVICES & GROOMING',
    title: 'Blackline Barber Co.',
    category: 'sales-beauty',
    originalWeakness: 'Traditional barbershop sites often lack a modern, editorial feel and make booking harder than needed.',
    axiomChanged: 'Implemented sharp editorial branding and a frictionless, high-speed booking flow.',
    whyItWorks: 'A premium barbershop concept built around sharp branding, an easy booking path, and a more considered first impression.',
    image: getWorkProofImage('concept-barber-demo').source,
    alt: getWorkProofImage('concept-barber-demo').alt || 'Blackline Barber Co.',
    position: 'center 40%',
    href: 'https://barber.getaxiom.ca',
  },
  {
    eyebrow: 'CONCEPT BUILD \u00b7 SALON & BEAUTY',
    title: 'Nails Studio Demo',
    category: 'sales-beauty',
    originalWeakness: 'Standard salon sites often bury the booking button and make the experience feel less premium than the service.',
    axiomChanged: 'The booking flow is clean and direct, paired with modern trust cues.',
    whyItWorks: 'A premium salon concept focused on cleaner booking, more trust at a glance, and a polished luxury feel.',
    image: getWorkProofImage('concept-salon-demo').source,
    alt: getWorkProofImage('concept-salon-demo').alt || 'Nails Studio Demo',
    position: 'center 40%',
    href: 'https://nails.getaxiom.ca',
  },
  {
    eyebrow: 'CONCEPT BUILD \u00b7 RESTAURANT & HOSPITALITY',
    title: 'Restaurant reservation concept.',
    category: 'food-hospitality',
    originalWeakness: 'Guests had to hunt for the booking link, and the menu was hard to read on phones.',
    axiomChanged: 'The reservation path stays visible and the menu reads cleanly on mobile.',
    whyItWorks:
      'People can book or check the menu without digging through the page, which matters when the decision happens fast.',
    image: getWorkProofImage('demonstration-restaurant-reservation-site').source,
    alt: getWorkProofImage('demonstration-restaurant-reservation-site').alt || 'Restaurant reservation site',
    position: 'center 24%',
    href: 'https://restaurant.getaxiom.ca',
  },
  {
    eyebrow: 'CONCEPT BUILD \u00b7 LANDSCAPING & OUTDOOR SERVICES',
    title: 'Landscaping concept.',
    category: 'home-services',
    originalWeakness: 'Past work was buried, and quote requests took too many clicks.',
    axiomChanged: 'Project photos come forward and the quote path is shorter.',
    whyItWorks: 'Buyers can judge the quality first and request a quote without digging through pages.',
    image: getWorkProofImage('concept-landscaping-authority-site').source,
    alt: getWorkProofImage('concept-landscaping-authority-site').alt || 'Landscaping authority site',
    position: 'center 52%',
    href: 'https://landscaping.getaxiom.ca',
  },
  {
    eyebrow: 'CONCEPT BUILD \u00b7 ROOFING & EXTERIORS',
    title: 'Roofing concept.',
    category: 'home-services',
    originalWeakness: 'Storm traffic needs a fast path to inspection and estimate requests.',
    axiomChanged: 'Urgent calls and planned estimates have separate paths.',
    whyItWorks: 'Different visitors need different actions, so the page removes friction instead of making everyone read the same route.',
    image: getWorkProofImage('concept-roofing-conversion-site').source,
    alt: getWorkProofImage('concept-roofing-conversion-site').alt || 'Roofing conversion site',
    position: 'center 36%',
    href: 'https://roofing.getaxiom.ca',
  },
] as const;

const workFilters = [
  { label: 'All', value: 'all' },
  { label: 'Sales & Beauty', value: 'sales-beauty' },
  { label: 'Legal', value: 'legal' },
  { label: 'Food & Hospitality', value: 'food-hospitality' },
  { label: 'Home Services', value: 'home-services' },
  { label: 'Other', value: 'other' },
] as const;

const buildLinkClass =
  'group inline-flex items-center gap-2 text-[14px] font-medium text-white/50 transition-colors duration-200 hover:text-white';
const buildArrowClass = 'inline-block transition-transform duration-200 motion-safe:group-hover:translate-x-1';
---

<SiteLayout title={SEO_ROUTES.work.title} description={SEO_ROUTES.work.description} canonicalPath="/work">
  <main id="main-content" tabindex="-1" class="-mt-28 pb-24 md:-mt-32 md:pb-32">
    <section class="axiom-container pt-24 md:pt-32">
      <FadeIn client:load className="max-w-3xl">
        <Eyebrow>WORK</Eyebrow>
        <h1 class="mt-4">Concept builds that show the standard.</h1>
        <p class="section-copy mt-5 md:text-[17px]">
          These are concept builds, not live client case studies. Each one shows the same outcome: clearer structure,
          faster decisions, and a stronger path to action.
        </p>
        <div class="mt-7">
          <Button asChild size="lg">
            <a href="/start">Start a project</a>
          </Button>
        </div>
      </FadeIn>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <div data-work-filter-row class="mb-8 flex flex-wrap items-center gap-x-6 gap-y-3 md:mb-10">
          {workFilters.map((filter) => (
            <button
              type="button"
              data-work-filter={filter.value}
              aria-pressed={filter.value === 'all' ? 'true' : 'false'}
              class="axiom-eyebrow border-b border-transparent pb-1 text-[11px] font-medium uppercase tracking-[0.2em] text-white/40 transition-colors duration-150 hover:text-white/70 focus-visible:outline-none"
            >
              {filter.label}
            </button>
          ))}
        </div>

        <div class="space-y-8 md:space-y-10">
          {featuredBuilds.map((build, index) => {
            const imageFirst = index % 2 === 0;

            return (
              <article
                data-work-card
                data-category={build.category}
                className="group overflow-hidden rounded-[var(--radius-card)] border border-[color:var(--hairline)] border-b border-white/5 bg-[var(--surface-1)] shadow-[var(--shadow-card)]"
              >
                <div class="grid gap-0 lg:grid-cols-2">
                  <figure
                    class={`relative flex flex-col bg-[#141414] ${imageFirst ? 'lg:border-r' : 'lg:order-2 lg:border-l'} border-[color:var(--hairline)] transform-gpu transition-shadow duration-500 group-hover:shadow-[0_0_40px_rgba(201,169,110,0.06)]`}
                  >
                    {/* Browser Header */}
                    <div class="flex items-center gap-1.5 px-4 h-9 border-b border-white/5 bg-[#1a1a1a]/50">
                      <div class="flex gap-1.5">
                        <div class="w-2.5 h-2.5 rounded-full bg-white/10"></div>
                        <div class="w-2.5 h-2.5 rounded-full bg-white/10"></div>
                        <div class="w-2.5 h-2.5 rounded-full bg-white/10"></div>
                      </div>
                    </div>

                    <div class="relative aspect-[4/3] overflow-hidden">
                      <ResponsivePicture
                        source={build.image}
                        alt={build.alt}
                        sizes="(min-width: 1280px) 50vw, 100vw"
                        class="h-full w-full motion-safe:transform-gpu motion-safe:transition-transform motion-safe:duration-700 motion-safe:ease-out motion-safe:group-hover:scale-[1.03]"
                        style="filter: contrast(1.02) saturate(0.95) brightness(1.02);"
                        loading="eager"
                        fetchpriority="high"
                        objectPosition={build.position}
                      />
                      <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/40 to-transparent opacity-60" />
                    </div>
                  </figure>

                  <div class={`flex h-full flex-col justify-center p-6 sm:p-8 lg:p-10 ${imageFirst ? '' : 'lg:order-1'}`}>
                    <Eyebrow className="text-[13px] tracking-[0.15em]">{build.eyebrow}</Eyebrow>
                    <h2 class="section-heading mt-4 text-[clamp(32px,4vw,52px)] font-[500] text-[var(--text-primary)]">
                      {build.title}
                    </h2>

                    <dl class="mt-8 space-y-5">
                      <div class="space-y-2">
                        <dt class="axiom-metric text-[var(--text-muted)]">ORIGINAL WEAKNESS</dt>
                        <dd class="section-copy">{build.originalWeakness}</dd>
                      </div>
                      <div class="space-y-2 border-t border-[color:var(--hairline)] pt-5">
                        <dt class="axiom-metric text-[var(--text-muted)]">AXIOM CHANGED</dt>
                        <dd class="section-copy">{build.axiomChanged}</dd>
                      </div>
                      <div class="space-y-2 border-t border-[color:var(--hairline)] pt-5">
                        <dt class="axiom-metric text-[var(--text-muted)]">WHY IT WORKS</dt>
                        <dd class="section-copy">{build.whyItWorks}</dd>
                      </div>
                    </dl>

                    <div class="mt-8">
                      <a class={buildLinkClass} href={build.href} target="_blank" rel="noopener noreferrer">
                        <span>View concept</span>
                        <span class={buildArrowClass}>→</span>
                      </a>
                    </div>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <FadeIn client:load as="div" className="flex flex-col items-center text-center">
          <p class="font-axiomDisplay text-[clamp(1.5rem,2.2vw,2.3rem)] leading-[1.08] tracking-[-0.04em] text-[var(--text-primary)]">
            More concepts available on request.
          </p>
          <a class="mt-5 inline-flex items-center gap-2 text-[14px] font-medium text-white/65 transition-colors duration-200 hover:text-white" href="/start">
            <span>Start a project</span>
            <span class={buildArrowClass}>→</span>
          </a>
        </FadeIn>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <FadeIn client:load as="div">
          <Card className="mx-auto max-w-5xl p-0">
            <div class="px-6 py-8 sm:px-8 sm:py-10 md:px-10 md:py-12">
              <Eyebrow>THE GUARANTEE</Eyebrow>
              <h2 class="section-heading mt-4">Ready to stop losing jobs to a weaker site?</h2>
              <p class="section-copy mt-4">
                No asterisks. That is the floor we build to.
              </p>
              <div class="mt-7 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                <Button asChild>
                  <a href="/start">Start a project</a>
                </Button>
                <p class="axiom-metric text-[var(--text-muted)]">Review &rarr; Scope &rarr; Build &rarr; Launch</p>
              </div>
            </div>
          </Card>
        </FadeIn>
      </div>
    </section>
  </main>
</SiteLayout>

<script>
  const initWorkFilters = () => {
    const filterRow = document.querySelector('[data-work-filter-row]');

    if (!filterRow || filterRow.getAttribute('data-work-filters-ready') === 'true') {
      return;
    }

    filterRow.setAttribute('data-work-filters-ready', 'true');

    const buttons = Array.from(filterRow.querySelectorAll('[data-work-filter]'));
    const cards = Array.from(document.querySelectorAll('[data-work-card]'));

    const applyFilter = (filter) => {
      buttons.forEach((button) => {
        const isActive = button.dataset.workFilter === filter;
        button.setAttribute('aria-pressed', String(isActive));
      });

      cards.forEach((card) => {
        const matches = filter === 'all' || card.dataset.category === filter;
        card.style.display = matches ? '' : 'none';
        card.setAttribute('aria-hidden', String(!matches));
      });
    };

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        applyFilter(button.dataset.workFilter ?? 'all');
      });
    });

    applyFilter('all');
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initWorkFilters, { once: true });
  } else {
    initWorkFilters();
  }
</script>

<style>
  [data-work-filter-row] [data-work-filter][aria-pressed='true'] {
    color: #b89a5e;
    border-bottom-color: #b89a5e;
  }
</style>
