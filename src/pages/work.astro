---
import SiteLayout from '../layouts/SiteLayout.astro';
import { CTA_PATHS } from '../lib/cta';
import { SEO_ROUTES, WORK_JSON_LD, breadcrumbSchema, SITE_URL } from '../lib/seo';
import { getWorkProofImage } from '../lib/workProofImages';
import { FadeIn } from '../components/ui/FadeIn';
import { Button } from '../components/ui/button';
import { Eyebrow } from '../components/ui/Eyebrow';
import { MotionHeading } from '../components/motion/MotionHeading';
import { SectionDivider } from '../components/motion/SectionDivider';
import { WorkCoverflow } from '../components/work/WorkCoverflow';

const projects = [
  {
    id: 'salon-nails',
    title: 'Nails Studio',
    niche: 'Salon & Beauty',
    outcome: 'Booking pulled above the fold so clients tap once instead of hunting through a menu.',
    meta: ['Website redesign', 'Local business', 'Conversion-focused'],
    image: getWorkProofImage('concept-salon-demo').source,
    alt: getWorkProofImage('concept-salon-demo').alt || 'Nails Studio concept site',
    position: 'center 40%',
    href: 'https://nails.getaxiom.ca',
    ctaLabel: 'Open demo',
  },
  {
    id: 'barber-blackline',
    title: 'Blackline Barber Co.',
    niche: 'Personal Services',
    outcome: 'Sharp brand, big photography, booking link locked into every screen.',
    meta: ['Website redesign', 'Local business'],
    image: getWorkProofImage('concept-barber-demo').source,
    alt: getWorkProofImage('concept-barber-demo').alt || 'Blackline Barber Co. concept site',
    position: 'center 40%',
    href: 'https://barber.getaxiom.ca',
    ctaLabel: 'Open demo',
  },
  {
    id: 'dental-aurelia',
    title: 'Aurelia Dental Studio',
    niche: 'Healthcare',
    outcome: 'Warmer tone, fewer clicks to a booking — built for new patients who decide in seconds.',
    meta: ['Website redesign', 'Local business', 'Conversion-focused'],
    image: getWorkProofImage('concept-dental-demo').source,
    alt: getWorkProofImage('concept-dental-demo').alt || 'Aurelia Dental Studio concept site',
    position: 'center 40%',
    href: 'https://dental.getaxiom.ca',
    ctaLabel: 'Open demo',
  },
  {
    id: 'restaurant-reservation',
    title: 'Restaurant Reservation',
    niche: 'Food & Hospitality',
    outcome: 'Menu and reservation live above the fold. Mobile loads fast, decisions happen at the table.',
    meta: ['Website redesign', 'Hospitality'],
    image: getWorkProofImage('demonstration-restaurant-reservation-site').source,
    alt: getWorkProofImage('demonstration-restaurant-reservation-site').alt || 'Restaurant reservation concept site',
    position: 'center 24%',
    href: 'https://restaurant.getaxiom.ca',
    ctaLabel: 'Open demo',
  },
  {
    id: 'physio-clinic',
    title: 'Physio Clinic',
    niche: 'Health & Wellness',
    outcome: 'Treatment paths, practitioner trust and booking collapsed into one first-screen flow.',
    meta: ['Website redesign', 'Local business'],
    image: getWorkProofImage('concept-physio-demo').source,
    alt: getWorkProofImage('concept-physio-demo').alt || 'Physiotherapy clinic concept site',
    position: 'center top',
    href: 'https://physio.getaxiom.ca',
    ctaLabel: 'Open demo',
  },
  {
    id: 'law-harrow',
    title: 'Harrow & Calloway',
    niche: 'Legal Services',
    outcome: 'Cleaner hierarchy, shorter copy, one obvious path to a consultation.',
    meta: ['Website redesign', 'Professional services'],
    image: getWorkProofImage('concept-law-demo').source,
    alt: getWorkProofImage('concept-law-demo').alt || 'Harrow & Calloway concept site',
    position: 'center 40%',
    href: 'https://law.getaxiom.ca',
    ctaLabel: 'Open demo',
  },
  {
    id: 'landscaping',
    title: 'Landscaping Studio',
    niche: 'Home Services',
    outcome: 'Project photography forward, quote form down to two fields and a button.',
    meta: ['Website redesign', 'Local business'],
    image: getWorkProofImage('concept-landscaping-authority-site').source,
    alt: getWorkProofImage('concept-landscaping-authority-site').alt || 'Landscaping concept site',
    position: 'center 52%',
    href: 'https://landscaping.getaxiom.ca',
    ctaLabel: 'Open demo',
  },
  {
    id: 'roofing',
    title: 'Roofing Conversion',
    niche: 'Home Services',
    outcome: 'Urgent calls and planned estimates split into separate, unmissable paths.',
    meta: ['Website redesign', 'Local business', 'Conversion-focused'],
    image: getWorkProofImage('concept-roofing-conversion-site').source,
    alt: getWorkProofImage('concept-roofing-conversion-site').alt || 'Roofing concept site',
    position: 'center 36%',
    href: 'https://roofing.getaxiom.ca',
    ctaLabel: 'Open demo',
  },
];
---

<SiteLayout
  title={SEO_ROUTES.work.title}
  description={SEO_ROUTES.work.description}
  canonicalPath="/work"
  schema={[WORK_JSON_LD, breadcrumbSchema([{ name: 'Home', url: SITE_URL }, { name: 'Work', url: `${SITE_URL}/work` }])]}
>
  <main id="main-content" tabindex="-1" class="-mt-28 pb-0 md:-mt-32">
    <section class="axiom-container pt-20 md:pt-28">
      <div class="max-w-3xl">
        <FadeIn motion="eyebrow">
          <Eyebrow>SELECTED WORK</Eyebrow>
          <SectionDivider className="mt-6" />
        </FadeIn>
        <FadeIn motion="sceneOpen" delay={180}>
          <MotionHeading
            as="h1"
            text="Websites built to make local businesses *look unavoidable*."
            className="mt-4"
          />
        </FadeIn>
        <FadeIn motion="editorialMaskReveal" delay={500}>
          <p class="section-copy mt-5 md:text-[17px]">
            A working portfolio of sector-specific platforms. Each one is built to the same structural and performance standard we deploy for clients &mdash; designed to make a serious business look like one at a glance.
          </p>
        </FadeIn>
        <FadeIn motion="sceneOpen" delay={720}>
          <div class="mt-6">
            <Button asChild size="lg">
              <a href={CTA_PATHS.startProject}>Start a project</a>
            </Button>
          </div>
        </FadeIn>
      </div>
    </section>

    <section class="relative pb-16 pt-10 md:pb-24 md:pt-16">
      <div class="absolute inset-x-0 top-1/2 h-px -translate-y-1/2 bg-[color:var(--hairline)] opacity-40" aria-hidden></div>
      <div class="axiom-container relative">
        <h2 class="sr-only">Project carousel</h2>
        <WorkCoverflow client:visible projects={projects} ctaHref={CTA_PATHS.startProject} />
      </div>
    </section>

    <section class="page-section-tight section-shell">
      <div class="axiom-container">
        <FadeIn as="div" motion="finalFrameFooter">
          <div class="mx-auto flex max-w-4xl flex-col items-start gap-8 border-t border-[color:var(--hairline)] py-14 md:flex-row md:items-center md:justify-between md:py-20">
            <div class="max-w-xl">
              <Eyebrow>BEFORE WE SHIP</Eyebrow>
              <MotionHeading
                as="h2"
                text="Want your business to *look this sharp*?"
                className="section-heading mt-4"
              />
              <p class="section-copy mt-4">
                A high-performance digital presence is a structural asset, not an expense. We design and build platforms that command authority and convert commercial interest into qualified inquiries.
              </p>
            </div>
            <div class="flex flex-col items-start gap-3 md:items-end">
              <Button asChild size="lg">
                <a href={CTA_PATHS.startProject}>Start a project</a>
              </Button>
              <p class="axiom-metric text-[var(--text-muted)]">Review &rarr; Scope &rarr; Build &rarr; Launch</p>
            </div>
          </div>
        </FadeIn>
      </div>
    </section>
  </main>
</SiteLayout>
