---
import { FadeIn } from '../components/ui/FadeIn';
import { Button } from '../components/ui/button';
import { Card } from '../components/ui/card';
import { Eyebrow } from '../components/ui/Eyebrow';
import DrawIcon from '../components/ui/DrawIcon.astro';
import { MotionHeading } from '../components/motion/MotionHeading';
import { SectionDivider } from '../components/motion/SectionDivider';
import SiteLayout from '../layouts/SiteLayout.astro';
import { CTA_PATHS } from '../lib/cta';
import { SEO_ROUTES, SITE_EMAIL, SITE_TELEPHONE, CONTACT_JSON_LD, breadcrumbSchema, SITE_URL } from '../lib/seo';

const nextSteps = [
  {
    number: '01',
    title: 'Submit the intake',
    detail: 'Five short steps. Takes about two minutes.',
  },
  {
    number: '02',
    title: 'Get a reply within one business day',
    detail: 'A real person reviews the brief and responds directly.',
  },
  {
    number: '03',
    title: 'We scope the path together',
    detail: 'If there is a fit, you get a clear scope, timeline, and price.',
  },
] as const;
---

<SiteLayout
  {...SEO_ROUTES.contact}
  schema={[CONTACT_JSON_LD, breadcrumbSchema([{ name: 'Home', url: SITE_URL }, { name: 'Contact', url: `${SITE_URL}/contact` }])]}
>
  <main id="main-content" tabindex="-1" class="-mt-28 pb-0 md:-mt-32">
    <section class="axiom-container pt-20 md:pt-28">
      <div class="mx-auto max-w-4xl text-center">
        <FadeIn motion="eyebrow">
          <Eyebrow>CONTACT</Eyebrow>
          <SectionDivider className="mx-auto mt-6" />
        </FadeIn>
        <FadeIn motion="sceneOpen" delay={180}>
          <MotionHeading as="h1" align="center" text="One clean path for serious project conversations." className="mt-4" />
        </FadeIn>
        <FadeIn motion="editorialMaskReveal" delay={460}>
          <p class="section-copy mx-auto mt-5 max-w-2xl md:text-[17px]">
            Project work starts with the intake so we can understand the business, the site, and the right next step. Email and phone stay open for direct notes.
          </p>
        </FadeIn>

        <FadeIn motion="sceneOpen" delay={680}>
          <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row sm:items-center">
            <Button asChild size="lg" className="w-full sm:w-auto">
              <a href={CTA_PATHS.startProject}>Start a project</a>
            </Button>
            <Button asChild variant="ghost" size="lg" className="w-full px-0 sm:w-auto">
              <a href="/services">See services</a>
            </Button>
          </div>
        </FadeIn>
      </div>
    </section>

    <div aria-hidden="true" class="section-glow section-glow-offset-top" />

    <section class="page-section section-shell">
      <div class="axiom-container">
        <FadeIn motion="editorialMaskReveal" className="max-w-3xl">
          <Eyebrow>WHAT HAPPENS NEXT</Eyebrow>
          <SectionDivider className="mt-6" />
          <MotionHeading as="h2" text="Three steps from here to scope." className="section-heading mt-4" />
        </FadeIn>

        <div class="mt-10 grid gap-5 md:grid-cols-3">
          {nextSteps.map((step, index) => (
            <FadeIn motion="timelineSequence" delay={Math.min(index * 140, 560)} as="div">
              <Card className="h-full p-0">
                <div class="flex h-full flex-col p-6 sm:p-7">
                  <div class="mb-4 flex items-center justify-between gap-4">
                    <DrawIcon name="check" size={14} className="text-[var(--accent-solid)]" />
                    <p class="font-mono text-[0.75rem] font-medium uppercase tracking-[0.08em] text-[var(--accent-solid)]">{step.number}</p>
                  </div>
                  <h3 class="text-[18px] font-semibold tracking-[-0.01em] text-[var(--text-primary)]">
                    {step.title}
                  </h3>
                  <p class="section-copy mt-3 text-[15px]">
                    {step.detail}
                  </p>
                </div>
              </Card>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <div aria-hidden="true" class="section-glow section-glow-offset-top" />

    <section class="page-section-tight section-shell">
      <div class="axiom-container">
        <FadeIn as="div" motion="formFocusMotion">
          <Card className="mx-auto max-w-4xl p-0">
            <div class="grid gap-6 p-6 text-left sm:p-7 md:grid-cols-2 md:p-8">
              <div>
                <Eyebrow>DIRECT</Eyebrow>
                <p class="section-copy mt-4">
                  For a quick note, partnership question, or follow-up that does not need the project intake.
                </p>
                <p class="mt-4 text-[14px] leading-[1.65] text-[var(--text-muted)]">
                  Typical response time: same business day.
                </p>
              </div>
              <div class="space-y-3 md:justify-self-end md:text-right">
                <a
                  href={`mailto:${SITE_EMAIL}`}
                  class="block min-h-11 text-[18px] font-medium text-[var(--text-primary)] underline decoration-[color:var(--hairline-strong)] underline-offset-4 transition-[color,text-decoration-color] duration-200 hover:text-[var(--accent-solid)] hover:decoration-current"
                >
                  {SITE_EMAIL}
                </a>
                <a
                  href={`tel:${SITE_TELEPHONE}`}
                  class="block min-h-11 text-[18px] font-medium text-[var(--text-primary)] underline decoration-[color:var(--hairline-strong)] underline-offset-4 transition-[color,text-decoration-color] duration-200 hover:text-[var(--accent-solid)] hover:decoration-current"
                >
                  (226) 753-1833
                </a>
                <p class="pt-2 text-[14px] leading-[1.65] text-[var(--text-muted)]">
                  Based in Kitchener-Waterloo, Ontario.
                </p>
              </div>
            </div>
          </Card>
        </FadeIn>
      </div>
    </section>
  </main>
</SiteLayout>
