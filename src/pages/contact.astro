---
import QuickContactWizard from '../components/site/QuickContactWizard';
import { FadeIn } from '../components/ui/FadeIn';
import { Eyebrow } from '../components/ui/Eyebrow';
import { MotionHeading } from '../components/motion/MotionHeading';
import { SectionDivider } from '../components/motion/SectionDivider';
import SiteLayout from '../layouts/SiteLayout.astro';
import { CTA_PATHS } from '../lib/cta';
import { SEO_ROUTES, SITE_EMAIL, SITE_TELEPHONE } from '../lib/seo';

const sourcePath = Astro.url.pathname + Astro.url.search;
---

<SiteLayout {...SEO_ROUTES.contact}>
  <main id="main-content" tabindex="-1" class="-mt-24 pb-24 md:-mt-28 md:pb-32">
    <section class="axiom-container pt-20 md:pt-28">
      <div class="mx-auto max-w-4xl">
        <div class="mx-auto max-w-2xl text-center">
          <FadeIn client:load motion="eyebrow">
            <Eyebrow>CONTACT</Eyebrow>
            <SectionDivider client:load className="mx-auto mt-6" />
          </FadeIn>
          <FadeIn client:load motion="cinematic" delay={160}>
            <MotionHeading client:load as="h1" align="center" text="Send a quick note." className="mt-4" />
          </FadeIn>
          <FadeIn client:load motion="editorial" delay={420}>
            <p class="section-copy mx-auto mt-5 max-w-xl md:text-[17px]">
              For questions, follow-ups, and short notes. If you&apos;re planning project work, use the project intake instead.
            </p>
          </FadeIn>

          <FadeIn client:load motion="system" delay={560}>
            <div class="mt-7 flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-[12px] font-medium uppercase tracking-[0.14em] text-[var(--text-secondary)]">
              <span>UNDER 1 MINUTE</span>
              <span aria-hidden="true" class="text-[var(--text-muted)]">&bull;</span>
              <span>REPLY WITHIN ONE BUSINESS DAY</span>
            </div>
          </FadeIn>

          <FadeIn client:load motion="cta" delay={700}>
            <p class="mt-5 text-[14px] leading-[1.7] text-[var(--text-secondary)]">
              Serious project inquiry?
              <a
                href={CTA_PATHS.startProject}
                class="ml-2 font-medium text-[var(--text-primary)] underline decoration-[color:var(--hairline-strong)] underline-offset-4 transition-[color,text-decoration-color] duration-[var(--duration-fast)] hover:text-[var(--accent-solid)] hover:decoration-current"
              >
                Start a project
              </a>
            </p>
          </FadeIn>
        </div>

        <div class="mt-10 flex justify-center md:mt-12">
          <div class="form-cinematic-shell w-full max-w-2xl" data-reveal data-motion="depth" style="--reveal-delay: 760ms;">
            <QuickContactWizard client:load sourcePath={sourcePath} />
          </div>
        </div>

        <FadeIn client:load as="div" motion="system" className="mx-auto mt-5 max-w-2xl">
          <div class="rounded-[22px] border border-[color:var(--hairline)] bg-[linear-gradient(180deg,rgba(255,255,255,0.022),rgba(255,255,255,0.008))] px-5 py-5 shadow-[0_18px_48px_rgba(0,0,0,0.18)] sm:px-6">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
              <p class="text-[12px] font-medium uppercase tracking-[0.16em] text-[var(--text-secondary)]">
                Prefer direct contact
              </p>

              <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-6">
                <a
                  href={`mailto:${SITE_EMAIL}`}
                  class="inline-flex min-h-10 items-center text-[15px] font-medium text-[var(--text-primary)] underline decoration-transparent underline-offset-4 transition-[color,text-decoration-color] duration-200 hover:text-[var(--accent-solid)] hover:decoration-current"
                >
                  {SITE_EMAIL}
                </a>
                <a
                  href={`tel:${SITE_TELEPHONE}`}
                  class="inline-flex min-h-10 items-center text-[15px] font-medium text-[var(--text-primary)] underline decoration-transparent underline-offset-4 transition-[color,text-decoration-color] duration-200 hover:text-[var(--accent-solid)] hover:decoration-current"
                >
                  (226) 753-1833
                </a>
              </div>
            </div>
          </div>
        </FadeIn>
      </div>
    </section>
  </main>

  <style is:global>
    .quick-contact-wizard [data-step-panel] {
      animation: quick-contact-step-in 360ms var(--ease-premium-soft);
      transform-origin: top center;
    }

    .quick-contact-wizard [data-step-panel].quick-contact-step-panel-backward {
      animation-name: quick-contact-step-in-backward;
    }

    @keyframes quick-contact-step-in {
      from {
        opacity: 0;
        transform: translate3d(0, 8px, 0);
      }

      to {
        opacity: 1;
        transform: translate3d(0, 0, 0);
      }
    }

    @keyframes quick-contact-step-in-backward {
      from {
        opacity: 0;
        transform: translate3d(0, -6px, 0);
      }

      to {
        opacity: 1;
        transform: translate3d(0, 0, 0);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .quick-contact-wizard [data-step-panel] {
        animation: none;
      }
    }
  </style>
</SiteLayout>
