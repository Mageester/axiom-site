---
import SiteLayout from '../layouts/SiteLayout.astro';
import { CTA_PATHS } from '../lib/cta';
import { FadeIn } from '../components/ui/FadeIn';
import { SEO_ROUTES } from '../lib/seo';
import { Button } from '../components/ui/button';
import { Card } from '../components/ui/card';
import { Eyebrow } from '../components/ui/Eyebrow';
import DrawIcon from '../components/ui/DrawIcon.astro';
import { MotionHeading } from '../components/motion/MotionHeading';
import { SectionDivider } from '../components/motion/SectionDivider';
import { Timeline } from '../components/motion/Timeline';

const processSteps = [
  {
    stageLabel: 'Review',
    title: 'Review',
    timelineDescription:
      "We audit the current site, the offer, and the points where you're losing trust. Then we decide what has to change first.",
    bullets: [] as const,
    icon: 'search',
  },
  {
    stageLabel: 'Scope',
    title: 'Scope',
    timelineDescription:
      'We lock the pages, the call paths, and the priorities before design starts. Decisions happen here, not mid-build.',
    bullets: [] as const,
    icon: 'document',
  },
  {
    stageLabel: 'Build',
    title: 'Build',
    timelineDescription:
      'We design, write, and test the full site. Layout and flow stay simple enough to ship clean.',
    bullets: [] as const,
    icon: 'code',
  },
  {
    stageLabel: 'Launch',
    title: 'Launch',
    timelineDescription:
      'We run launch checks, connect the domain, and hand over a live site. Monthly clients keep support from here on.',
    bullets: [] as const,
    icon: 'arrow-up',
  },
] as const;

const timelineSteps = processSteps.map((step) => ({
  kicker: step.stageLabel,
  title: step.title,
  description: step.timelineDescription,
}));

const launchChecklist = [
  { title: 'Pages to build', detail: 'Which pages matter most right now.' },
  { title: 'Proof to surface', detail: 'Reviews, photos, and past work worth showing early.' },
  { title: 'Quote and contact paths', detail: 'Where each button and form should go.' },
  { title: 'Domain and redirects', detail: 'Technical handoff so nothing breaks at launch.' },
] as const;
---

<SiteLayout title={SEO_ROUTES.process.title} description={SEO_ROUTES.process.description} canonicalPath="/process">
  <main id="main-content" tabindex="-1" class="-mt-28 md:-mt-32 pb-24 md:pb-32">
    <section class="axiom-container pt-24 md:pt-32">
      <FadeIn client:load className="max-w-3xl">
        <Eyebrow>PROCESS</Eyebrow>
        <SectionDivider client:load className="mt-6" />
        <MotionHeading client:load as="h1" text="Four stages. Then ongoing support." className="mt-4" />
        <p class="section-copy mt-5 md:text-[17px]">
          Typical launch is 2-4 weeks, depending on scope. Direct access to your team keeps decisions moving, and
          monthly clients keep support after the site goes live.
        </p>
        <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:items-center">
          <Button asChild size="lg" className="w-full sm:w-auto">
            <a href={CTA_PATHS.startProject}>Start a project</a>
          </Button>
          <Button asChild variant="ghost" size="lg" className="w-full px-0 sm:w-auto">
            <a href="/work">See real builds</a>
          </Button>
        </div>
      </FadeIn>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <Timeline client:load steps={timelineSteps} />
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <FadeIn client:load className="max-w-3xl">
          <Eyebrow>WHAT WE NEED FROM YOU</Eyebrow>
          <SectionDivider client:load className="mt-6" />
          <MotionHeading client:load as="h2" text="Four things from you. That's it." className="section-heading mt-4" />
        </FadeIn>

        <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          {launchChecklist.map((item, index) => (
            <FadeIn client:load delay={index * 100} distance={20} style={{ transitionDuration: '600ms' }} as="div">
              <div class="h-full rounded-[var(--radius-card)] border border-[color:var(--hairline)] bg-[var(--surface-1)] p-5 sm:p-6">
                <p class="flex items-center gap-2 text-[15px] font-semibold tracking-normal text-[var(--text-primary)]">
                  <DrawIcon name="check" size={14} className="text-[var(--accent-solid)]" />
                  {item.title}
                </p>
                <p class="section-copy mt-3 text-[15px]">
                  {item.detail}
                </p>
              </div>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container grid gap-6 lg:grid-cols-2">
        <FadeIn client:load as="div" direction="left">
          <Card className="h-full p-0">
            <div class="h-full px-6 py-8 sm:px-8 sm:py-10 md:px-10 md:py-12">
              <Eyebrow>AFTER LAUNCH</Eyebrow>
              <SectionDivider client:load className="mt-6" />
              <MotionHeading client:load as="h2" text="Subscription clients stay supported." className="section-heading mt-4" />
              <p class="section-copy mt-4">
                Once live, monthly clients keep edits, refinements, and priority support every month. Ownership clients
                get a clean handoff - and a separate support path if they want one.
              </p>
            </div>
          </Card>
        </FadeIn>

        <FadeIn client:load as="div" direction="right">
          <Card className="h-full p-0">
            <div class="h-full px-6 py-8 sm:px-8 sm:py-10 md:px-10 md:py-12">
              <Eyebrow>THE GUARANTEE</Eyebrow>
              <SectionDivider client:load className="mt-6" />
              <MotionHeading client:load as="h2" text="Ready to stop losing jobs to a weaker site?" className="section-heading mt-4" />
              <p class="section-copy mt-4">
                No asterisks. That is the floor we build to.
              </p>
              <div class="mt-7 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                <Button asChild>
                  <a href={CTA_PATHS.startProject}>Start a project</a>
                </Button>
                <p class="axiom-metric text-[var(--text-muted)]">Review &rarr; Scope &rarr; Build &rarr; Launch</p>
              </div>
            </div>
          </Card>
        </FadeIn>
      </div>
    </section>
  </main>
</SiteLayout>
