---
import SiteLayout from '../layouts/SiteLayout.astro';
import { FadeIn } from '../components/ui/FadeIn';
import { SEO_ROUTES } from '../lib/seo';
import { Button } from '../components/ui/button';
import { Card } from '../components/ui/card';
import { Eyebrow } from '../components/ui/Eyebrow';
import DrawIcon from '../components/ui/DrawIcon.astro';

const processSteps = [
  {
    dayLabel: 'Day 1',
    title: 'Review',
    timelineDescription:
      'We audit the current site, the offer, and the friction points that are costing trust. We also identify the pages and proof that should move first.',
    bullets: [] as const,
    icon: 'search',
  },
  {
    dayLabel: 'Day 3',
    title: 'Scope',
    timelineDescription:
      'We lock the page structure, the call paths, and the content priorities before design starts. That keeps the build focused and the decisions early.',
    bullets: [] as const,
    icon: 'document',
  },
  {
    dayLabel: 'Day 7',
    title: 'Build',
    timelineDescription:
      'We write, design, and test the site in production conditions. The layout, hierarchy, and interactions stay simple enough to ship cleanly.',
    bullets: [] as const,
    icon: 'code',
  },
  {
    dayLabel: 'Day 14',
    title: 'Launch',
    timelineDescription:
      'We run launch checks, connect the domain, and hand over the site with a clear technical finish. The result is predictable, not improvised.',
    bullets: [] as const,
    icon: 'arrow-up',
  },
] as const;

const launchChecklist = [
  { title: 'Pages to build', detail: 'Which pages matter most right now.' },
  { title: 'Proof to surface', detail: 'Reviews, photos, and past work that should show up early.' },
  { title: 'Quote and contact paths', detail: 'Where each call-to-action should go.' },
  { title: 'Domain and redirects', detail: 'Final technical handoff, redirects, and live launch checks.' },
] as const;
---

<SiteLayout title={SEO_ROUTES.process.title} description={SEO_ROUTES.process.description} canonicalPath="/process">
  <main id="main-content" tabindex="-1" class="-mt-28 md:-mt-32 pb-24 md:pb-32">
    <section class="axiom-container pt-24 md:pt-32">
      <FadeIn client:load className="max-w-3xl">
        <Eyebrow>PROCESS</Eyebrow>
        <h1 class="mt-4">Four stages. From review to launch.</h1>
        <p class="section-copy mt-5 md:text-[17px]">
          Every stage keeps the work clear, the decisions early, and the launch predictable.
        </p>
        <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:items-center">
          <Button asChild size="lg" className="w-full sm:w-auto">
            <a href="/start">Start a project</a>
          </Button>
          <Button asChild variant="ghost" size="lg" className="w-full px-0 sm:w-auto">
            <a href="/work">See the work</a>
          </Button>
        </div>
      </FadeIn>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4 xl:items-start">
          {processSteps.map((step, index) => (
            <FadeIn client:load delay={index * 100} distance={20} style={{ transitionDuration: '600ms' }} as="div">
              <div
                className="group h-full rounded-[var(--radius-card)] border border-transparent bg-[var(--surface-1)] shadow-[var(--shadow-card)] transition-[transform,border-color,box-shadow,background-color] duration-200 ease-out motion-safe:hover:-translate-y-1 motion-safe:hover:border-[color:rgba(201,122,78,0.2)] motion-safe:hover:shadow-[0_18px_40px_rgba(201,122,78,0.08)] motion-safe:hover:bg-[var(--surface-2)]"
              >
                <div class="flex flex-col p-6 sm:p-7">
                  <div class="flex items-center gap-3">
                    <DrawIcon name={step.icon} size={32} className="text-[var(--accent-solid)]" />
                    <p class="font-axiomMono text-[clamp(2.6rem,4vw,3.25rem)] leading-none tracking-[-0.06em] text-[var(--accent-solid)]">
                      {step.dayLabel}
                    </p>
                  </div>
                  <h2 class="section-heading mt-4 text-[18px] font-semibold text-[var(--text-primary)]">
                    {step.title}
                  </h2>
                  <p class="section-copy mt-3 text-[14px]">
                    {step.timelineDescription}
                  </p>
                </div>
              </div>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <FadeIn client:load className="max-w-3xl">
          <Eyebrow>LAUNCH CHECKLIST</Eyebrow>
          <h2 class="section-heading mt-4">What launch day actually looks like.</h2>
        </FadeIn>

        <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          {launchChecklist.map((item, index) => (
            <FadeIn client:load delay={index * 100} distance={20} style={{ transitionDuration: '600ms' }} as="div">
              <div class="h-full rounded-[var(--radius-card)] border border-[color:var(--hairline)] bg-[var(--surface-1)] p-5 sm:p-6">
                <p class="flex items-center gap-2 text-[15px] font-semibold tracking-[-0.01em] text-[var(--text-primary)]">
                  <DrawIcon name="check" size={14} className="text-[#C9A96E]" />
                  {item.title}
                </p>
                <p class="section-copy mt-3 text-[14px]">
                  {item.detail}
                </p>
              </div>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <FadeIn client:load as="div">
          <Card className="mx-auto max-w-5xl p-0">
            <div class="px-6 py-8 sm:px-8 sm:py-10 md:px-10 md:py-12">
              <Eyebrow>THE GUARANTEE</Eyebrow>
              <h2 class="section-heading mt-4">Ready to stop losing jobs to a weaker site?</h2>
              <p class="section-copy mt-4">
                No asterisks. That is the floor we build to.
              </p>
              <div class="mt-7 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                <Button asChild>
                  <a href="/start">Start a project</a>
                </Button>
                <p class="axiom-metric text-[var(--text-muted)]">Review &rarr; Scope &rarr; Build &rarr; Launch</p>
              </div>
            </div>
          </Card>
        </FadeIn>
      </div>
    </section>
  </main>
</SiteLayout>
