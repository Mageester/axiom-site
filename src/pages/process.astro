---
import SiteLayout from '../layouts/SiteLayout.astro';
import { CTA } from '../lib/cta';
import { SEO_ROUTES } from '../lib/seo';
import { Button } from '../components/ui/button';
import { Card } from '../components/ui/card';
import { Eyebrow } from '../components/ui/Eyebrow';

const processSteps = [
  {
    dayLabel: 'Day 1',
    title: 'Review',
    timelineDescription:
      'We audit the current site, the offer, and the friction points that are costing trust. We also identify the pages and proof that should move first.',
  },
  {
    dayLabel: 'Day 3',
    title: 'Scope',
    timelineDescription:
      'We lock the page structure, the call paths, and the content priorities before design starts. That keeps the build focused and the decisions early.',
  },
  {
    dayLabel: 'Day 7',
    title: 'Build',
    timelineDescription:
      'We write, design, and test the site in production conditions. The layout, hierarchy, and interactions stay simple enough to ship cleanly.',
  },
  {
    dayLabel: 'Day 14',
    title: 'Launch',
    timelineDescription:
      'We run launch checks, connect the domain, and hand over the site with a clear technical finish. The result is predictable, not improvised.',
  },
] as const;

const checklistItems = [
  { title: 'Pages to build', detail: 'Which pages matter most right now.' },
  { title: 'Proof to surface', detail: 'Reviews, photos, and past work that should show up early.' },
  { title: 'Quote and contact paths', detail: 'Where each call-to-action should go.' },
  { title: 'Domain and redirects', detail: 'Final technical handoff, redirects, and live launch checks.' },
] as const;
---

<SiteLayout title={SEO_ROUTES.process.title} description={SEO_ROUTES.process.description} canonicalPath="/process">
  <main id="main-content" tabindex="-1" class="-mt-28 md:-mt-32 pb-24 md:pb-32">
    <section class="axiom-container pt-12 md:pt-20">
      <div class="max-w-3xl">
        <Eyebrow>PROCESS</Eyebrow>
        <h1 class="mt-4">Four stages. From review to launch.</h1>
        <p class="mt-5 max-w-2xl text-[15px] leading-[1.65] text-[var(--text-secondary)] md:text-[17px]">
          Every stage keeps the work clear, the decisions early, and the launch predictable.
        </p>
        <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:items-center">
          <Button asChild size="lg" className="w-full sm:w-auto">
            <a href="/start">Start a project</a>
          </Button>
          <Button asChild variant="ghost" size="lg" className="w-full px-0 sm:w-auto">
            <a href="/work">See the work</a>
          </Button>
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container grid gap-6 xl:grid-cols-[minmax(0,1.15fr)_minmax(20rem,0.72fr)] xl:items-start xl:gap-8">
        <Card className="p-0">
          <div class="flex flex-col gap-4 p-6 sm:p-7 lg:flex-row lg:items-stretch lg:gap-0">
            {processSteps.map((step, index) => (
              <>
                <article class="relative flex min-w-[200px] flex-1 flex-col rounded-[var(--radius-card)] border border-[color:var(--hairline)] bg-white/[0.015] px-5 pb-6 pt-8 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
                  <span
                    aria-hidden="true"
                    class="absolute left-5 top-5 h-3 w-3 rounded-full bg-[var(--accent)] shadow-[0_0_0_4px_rgba(232,162,123,0.16)]"
                  />
                  <p class="font-axiomMono text-[clamp(3rem,5vw,3.5rem)] leading-none tracking-[-0.06em] text-[var(--accent)]">
                    {step.dayLabel}
                  </p>
                  <h2 class="mt-4 text-[18px] font-semibold leading-[1.4] tracking-[-0.015em] text-[var(--text-primary)]">
                    {step.title}
                  </h2>
                  <p class="mt-3 text-[14px] leading-[1.65] text-[var(--text-secondary)]">
                    {step.timelineDescription}
                  </p>
                </article>

                {index < processSteps.length - 1 ? (
                  <div
                    aria-hidden="true"
                    class="hidden lg:block relative flex-none self-center px-3"
                  >
                    <div class="h-px w-10 bg-[color:var(--hairline)]" />
                    <div class="absolute left-1/2 top-1/2 h-2.5 w-2.5 -translate-x-1/2 -translate-y-1/2 rounded-full bg-[var(--accent)] shadow-[0_0_0_4px_rgba(232,162,123,0.14)]" />
                  </div>
                ) : null}
              </>
            ))}
          </div>
        </Card>

        <Card className="self-start p-0 xl:sticky xl:top-28">
          <div class="p-6 sm:p-7">
            <Eyebrow>WHAT WE NEED BEFORE DAY 7</Eyebrow>
            <p class="mt-4 max-w-md text-[15px] leading-[1.65] text-[var(--text-secondary)]">
              The closer this is to the actual business, the cleaner the build becomes.
            </p>

            <ul class="mt-6 divide-y divide-[color:var(--hairline)]">
              {checklistItems.map((item) => (
                <li class="flex items-start gap-3 py-4 first:pt-0 last:pb-0">
                  <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-[var(--accent)] shadow-[0_0_0_4px_rgba(232,162,123,0.12)]" />
                  <div>
                    <p class="text-[15px] font-semibold leading-[1.4] text-[var(--text-primary)]">{item.title}</p>
                    <p class="mt-1 text-[14px] leading-[1.65] text-[var(--text-secondary)]">{item.detail}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </Card>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <Card className="mx-auto max-w-5xl p-0">
          <div class="px-6 py-8 sm:px-8 sm:py-10 md:px-10 md:py-12">
            <Eyebrow>THE GUARANTEE</Eyebrow>
            <h2 class="mt-4 max-w-4xl">Ready to stop losing jobs to a weaker site?</h2>
            <p class="mt-4 max-w-2xl text-[15px] leading-[1.65] text-[var(--text-secondary)]">
              No asterisks. That is the floor we build to.
            </p>
            <div class="mt-7 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
              <Button asChild>
                <a href="/start">Start a project</a>
              </Button>
              <p class="axiom-metric text-[var(--text-muted)]">Review -> Scope -> Build -> Launch</p>
            </div>
          </div>
        </Card>
      </div>
    </section>
  </main>
</SiteLayout>
