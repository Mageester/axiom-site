---
import LegalPage from '../components/site/LegalPage.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { SEO_ROUTES } from '../lib/seo';
---

<SiteLayout title={SEO_ROUTES.privacy.title} description={SEO_ROUTES.privacy.description} canonicalPath="/privacy">
  <LegalPage
    title="Privacy Policy"
    updated="April 17, 2026"
    sections={[
      {
        id: 'privacy-information-collection',
        number: '1',
        title: 'Information Collection',
        paragraphs: [
          'We collect several different types of information for various purposes to provide and improve our Service to you. This includes personal data provided exclusively via direct contact or scheduled consultation requests.',
        ],
      },
      {
        id: 'privacy-use-of-data',
        number: '2',
        title: 'Use of Data',
        paragraphs: ['Axiom uses the collected data for various purposes:'],
        bullets: [
          'To provide and maintain the Service',
          'To notify you about changes to our Service',
          'To provide customer care and support',
          'To provide analysis or valuable information so that we can improve the Service',
          'To monitor the usage of the Service',
        ],
      },
      {
        id: 'privacy-transfer-of-data',
        number: '3',
        title: 'Transfer Of Data',
        paragraphs: [
          'Your information, including Personal Data, may be transferred to - and maintained on - computers located outside of your state, province, country or other governmental jurisdiction where the data protection laws may differ than those from your jurisdiction.',
        ],
      },
      {
        id: 'privacy-security-of-data',
        number: '4',
        title: 'Security Of Data',
        paragraphs: [
          'The security of your data is important to us, but remember that no method of transmission over the Internet, or method of electronic storage is 100% secure. While we strive to use commercially acceptable means to protect your Personal Data, we cannot guarantee its absolute security.',
        ],
      },
      {
        id: 'privacy-analytics',
        number: '5',
        title: 'Analytics',
        paragraphs: [
          'We may use third-party Service Providers to monitor and analyze the use of our Service, such as Google Analytics, subject strictly to their respective privacy frameworks.',
        ],
      },
    ]}
  />
</SiteLayout>
