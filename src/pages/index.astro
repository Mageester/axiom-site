---
import ResponsivePicture from '../components/site/ResponsivePicture.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { CTA_PATHS } from '../lib/cta';
import { HOME_JSON_LD, WEBSITE_SCHEMA, SEO_ROUTES, breadcrumbSchema } from '../lib/seo';
import { getWorkProofImage } from '../lib/workProofImages';
import { FadeIn } from '../components/ui/FadeIn';
import { FeatureCarousel } from '../components/ui/FeatureCarousel';
import { Button } from '../components/ui/button';
import { Card } from '../components/ui/card';
import { Eyebrow } from '../components/ui/Eyebrow';
import DrawIcon from '../components/ui/DrawIcon.astro';
import { MotionHeading } from '../components/motion/MotionHeading';
import { ProofBar } from '../components/motion/ProofBar';
import { SectionDivider } from '../components/motion/SectionDivider';

const browserBars = [
  { width: '92%', delay: 0 },
  { width: '78%', delay: 0.4 },
  { width: '64%', delay: 0.8 },
] as const;

const workCards = [
  {
    tag: 'CONCEPT',
    eyebrow: 'CONVERSION STRATEGY',
    title: 'Aurelia Dental Studio',
    outcome: 'Clear, warm, and easy to navigate. New patients find what they need and book without second-guessing.',
    image: getWorkProofImage('concept-dental-demo').source,
    alt: getWorkProofImage('concept-dental-demo').alt || 'Aurelia Dental Studio',
    position: getWorkProofImage('concept-dental-demo').position || 'center 40%',
  },
  {
    tag: 'CONCEPT',
    eyebrow: 'LOCAL BUSINESS',
    title: 'Nails Studio Demo',
    outcome: 'Booking is visible early, services are easy to compare, and the brand reads as calm and polished.',
    image: getWorkProofImage('concept-salon-demo').source,
    alt: getWorkProofImage('concept-salon-demo').alt || 'Nails Studio Demo',
    position: getWorkProofImage('concept-salon-demo').position || 'center 40%',
  },
  {
    tag: 'CONCEPT',
    eyebrow: 'REBUILD',
    title: 'Blackline Barber Co.',
    outcome: 'Fast, sharp, and direct. Clients get to the booking button in seconds - no hunting required.',
    image: getWorkProofImage('concept-barber-demo').source,
    alt: getWorkProofImage('concept-barber-demo').alt || 'Blackline Barber Co.',
    position: getWorkProofImage('concept-barber-demo').position || 'center 40%',
  },
] as const;

const principles = [
  {
    number: '01',
    title: 'Absolute commercial alignment',
    description: 'We ensure visitors immediately comprehend your exact offer, target market, and the primary path to engagement. Zero ambiguity.',
    icon: 'eye',
  },
  {
    number: '02',
    title: 'Evidence-based authority',
    description: 'We place case outcomes, industry credentials, and verified testimonials exactly where buyers make critical evaluation decisions. We never fabricate metrics.',
    icon: 'shield-check',
  },
  {
    number: '03',
    title: 'Uncompromised performance',
    description: 'Every platform loads in under one second. We audit semantic HTML, responsive grids, and Core Web Vitals on every release to ensure flawless rendering.',
    icon: 'bolt',
  },
  {
    number: '04',
    title: 'Active platform guardianship',
    description: 'We handle hosting security, performance audits, and content updates. You retain direct partner support post-launch without agency ticketing queues.',
    icon: 'key',
  },
] as const;



const services = [
  {
    label: 'Conversion Sites',
    description:
      'For service businesses that need a clearer offer, stronger trust signals, and fewer steps from visit to inquiry.',
    href: '/services#conversion-sites',
    icon: 'target',
  },
  {
    label: 'Local Business Websites',
    description:
      'For companies whose reputation, service quality, and contact path need to be obvious on every device.',
    href: '/services#local-business-websites',
    icon: 'crown',
  },
  {
    label: 'Rebuilds',
    description:
      'Replace a dated or confusing site while protecting useful content, redirects, domains, and buyer trust.',
    href: '/services#rebuilds',
    icon: 'refresh',
  },
] as const;

const team = [
  {
    name: 'Aidan',
    monogram: 'aidan',
    roles: ['Client Strategy & Scope'],
    description: 'Architects the commercial message and content hierarchy. Ensures the site structure maps directly to how buyers evaluate your services.',
  },
  {
    name: 'Riley',
    monogram: 'riley',
    roles: ['Platform Architecture & Engineering'],
    description: 'Engineers the codebase and manages platform delivery. Focuses on rendering speeds, responsive integrity, and clean codebase handoffs.',
  },
] as const;

---

<SiteLayout
  title={SEO_ROUTES.home.title}
  description={SEO_ROUTES.home.description}
  canonicalPath="/"
  ogImageAlt="Axiom Web homepage – custom web development in Kitchener-Waterloo."
  schema={[HOME_JSON_LD, WEBSITE_SCHEMA]}
>
  <main id="main-content" tabindex="-1" class="-mt-28 md:-mt-32">
    <section class="hero-shell relative overflow-hidden pb-20 pt-32 md:pb-28 md:pt-40">
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 hero-aurora"
        style="
          background:
            radial-gradient(circle at 82% 12%, var(--accent-surface) 0%, var(--accent-surface-strong) 14%, transparent 36%),
            linear-gradient(180deg, var(--surface-panel-strong) 0%, transparent 18%);
        "
      />
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 hero-noise opacity-[0.04]"
        style="
          background-image:
            radial-gradient(circle at 20% 20%, var(--hero-noise-dot) 0.6px, transparent 0.6px),
            radial-gradient(circle at 80% 70%, var(--hero-noise-dot-alt) 0.6px, transparent 0.6px);
          background-size: 4px 4px, 5px 5px;
          background-position: 0 0, 1px 1px;
          mix-blend-mode: overlay;
        "
      />
      <div aria-hidden="true" class="hero-grid pointer-events-none absolute inset-0" />
      <div aria-hidden="true" class="hero-cursor-glow" />
      <div class="axiom-container relative">
        <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(22rem,30rem)] lg:items-center">
          <div class="max-w-3xl">
            <FadeIn motion="sceneOpen" className="hero-copy-primary">
              <MotionHeading as="h1" text="Websites built for companies with *reputations to protect*." className="max-w-4xl text-left" />
            </FadeIn>
            <FadeIn delay={520} motion="editorialMaskReveal">
              <p class="section-copy mt-6 max-w-2xl md:text-[1.1rem]">
                We deploy high-performance web platforms for firms that cannot afford to look second-rate. Sub-second load speeds, conversion-guided layout design, and direct partner execution from review to launch.
              </p>
            </FadeIn>

            <FadeIn delay={780} motion="sceneOpen">
              <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
                <Button asChild size="lg" className="w-full sm:w-auto">
                  <a href={CTA_PATHS.startProject}>Start a project</a>
                </Button>
                <Button asChild variant="ghost" size="lg" className="w-full px-0 sm:w-auto">
                  <a href="/services">See services</a>
                </Button>
              </div>
            </FadeIn>
          </div>

          <FadeIn delay={980} as="div" motion="depthCardReveal" className="hidden justify-self-end lg:block" aria-hidden="true">
            <div class="hero-browser-shell hero-visual">
              <svg viewBox="0 0 520 340" class="block h-auto w-full" fill="none" role="presentation">
                <rect x="0.75" y="0.75" width="518.5" height="338.5" rx="24" class="hero-browser-frame" />
                <rect x="0.75" y="0.75" width="518.5" height="52" rx="24" class="hero-browser-chrome" />
                <circle cx="36" cy="26" r="5.5" class="hero-browser-dot" />
                <circle cx="54" cy="26" r="5.5" class="hero-browser-dot" />
                <circle cx="72" cy="26" r="5.5" class="hero-browser-dot" />

                {browserBars.map((bar, index) => (
                  <rect
                    key={index}
                    x="42"
                    y={86 + index * 46}
                    width={bar.width}
                    height="16"
                    rx="8"
                    class="hero-browser-bar"
                    style={`--browser-delay: ${bar.delay}s;`}
                  />
                ))}
                <rect x="42" y="250" width="182" height="34" rx="17" class="hero-browser-chip" />
                <rect x="248" y="250" width="108" height="34" rx="17" class="hero-browser-chip hero-browser-chip-soft" />
                <path d="M405 116C431 142 444 170 444 200C444 230 428 255 396 276" class="hero-browser-arc" />
                <path d="M386 104C407 132 416 161 413 191C410 222 392 246 358 263" class="hero-browser-arc hero-browser-arc-muted" />
              </svg>
              <div class="hero-status-panel">
                <span>CORE WEB VITALS</span>
                <strong>Verified before launch</strong>
              </div>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>

    <ProofBar />

    <section class="page-section section-shell">
      <div class="axiom-container">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
          <FadeIn motion="editorialMaskReveal" className="max-w-3xl">
            <Eyebrow>SELECTED WORK</Eyebrow>
            <SectionDivider className="mt-6" />
            <MotionHeading as="h2" text="Structural demonstrations of *our standard*." className="section-heading mt-4" />
            <p class="section-copy mt-4 md:text-[17px]">
              A curated portfolio of sector-specific platforms engineered to our exact performance and message standards. We build and label these interactive models to demonstrate structural quality without compromising client privacy.
            </p>
          </FadeIn>

          <FadeIn delay={180} motion="sceneOpen" className="flex flex-wrap items-center gap-3 lg:justify-end lg:pb-1">
            <a
              href="/work"
              class="inline-flex min-h-11 items-center justify-center rounded-full border border-[color:var(--accent-border)] bg-[rgba(214,173,66,0.08)] px-5 font-mono text-[12px] font-medium uppercase tracking-[0.12em] text-[var(--accent-solid)] transition-[border-color,background-color,color] duration-200 hover:border-[color:var(--accent-solid)] hover:bg-[rgba(214,173,66,0.12)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--accent-solid)]"
            >
              View all work
            </a>
          </FadeIn>
        </div>

        <div
          id="selected-work-demos"
          class="mt-10 grid gap-6 grid-cols-1 md:grid-cols-3"
        >
          <!-- Card 1: Aurelia Dental Studio (Landscape, col-span-2) -->
          <FadeIn motion="depthCardReveal" delay={0} className="md:col-span-2" as="div">
            <Card
              className="premium-card group overflow-hidden p-0 transition-[transform,background-color,border-color,box-shadow] duration-200 ease-[var(--ease-premium)] hover:bg-[var(--surface-2)] hover:border-[color:var(--hairline-strong)] h-full flex flex-col md:flex-row"
            >
              <figure class="relative overflow-hidden border-b md:border-b-0 md:border-r border-[color:var(--hairline)] bg-white/5 md:w-3/5 h-full min-h-[240px]">
                <ResponsivePicture
                  source={workCards[0].image}
                  alt={workCards[0].alt}
                  sizes="(min-width: 1024px) 50vw, 100vw"
                  class="media-zoom absolute inset-0 h-full w-full object-cover"
                  loading="lazy"
                  fetchpriority="low"
                  objectPosition={workCards[0].position}
                />
                <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_top,var(--overlay-black-soft),transparent)]" />
              </figure>

              <div class="flex flex-col justify-center p-6 sm:p-8 md:w-2/5">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="rounded-full border border-[color:var(--hairline)] bg-[color:var(--surface-overlay)] px-3 py-1 font-mono text-[11px] font-medium uppercase tracking-[0.14em] text-[var(--accent-solid)]">
                    {workCards[0].tag}
                  </span>
                  <Eyebrow>{workCards[0].eyebrow}</Eyebrow>
                </div>
                <h3 class="mt-4 text-[clamp(1.25rem,2.2vw,1.75rem)] font-semibold tracking-tight text-[var(--text-primary)]">
                  {workCards[0].title}
                </h3>
                <p class="section-copy mt-3 text-[14px] leading-relaxed">
                  {workCards[0].outcome}
                </p>
              </div>
            </Card>
          </FadeIn>

          <!-- Card 2: Nails Studio Demo (Portrait, col-span-1) -->
          <FadeIn motion="depthCardReveal" delay={150} className="md:col-span-1" as="div">
            <Card
              className="premium-card group overflow-hidden p-0 transition-[transform,background-color,border-color,box-shadow] duration-200 ease-[var(--ease-premium)] hover:bg-[var(--surface-2)] hover:border-[color:var(--hairline-strong)] h-full flex flex-col"
            >
              <figure class="relative overflow-hidden border-b border-[color:var(--hairline)] bg-white/5 aspect-[4/3] w-full">
                <ResponsivePicture
                  source={workCards[1].image}
                  alt={workCards[1].alt}
                  sizes="(min-width: 1024px) 25vw, 100vw"
                  class="media-zoom absolute inset-0 h-full w-full object-cover"
                  loading="lazy"
                  fetchpriority="low"
                  objectPosition={workCards[1].position}
                />
                <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_top,var(--overlay-black-soft),transparent)]" />
              </figure>

              <div class="flex flex-col p-6 sm:p-7 flex-grow">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="rounded-full border border-[color:var(--hairline)] bg-[color:var(--surface-overlay)] px-3 py-1 font-mono text-[11px] font-medium uppercase tracking-[0.14em] text-[var(--accent-solid)]">
                    {workCards[1].tag}
                  </span>
                  <Eyebrow>{workCards[1].eyebrow}</Eyebrow>
                </div>
                <h3 class="mt-4 text-xl font-semibold tracking-tight text-[var(--text-primary)]">
                  {workCards[1].title}
                </h3>
                <p class="section-copy mt-3 text-[14px] leading-relaxed">
                  {workCards[1].outcome}
                </p>
              </div>
            </Card>
          </FadeIn>

          <!-- Card 3: Blackline Barber Co. (Portrait, col-span-1) -->
          <FadeIn motion="depthCardReveal" delay={300} className="md:col-span-1" as="div">
            <Card
              className="premium-card group overflow-hidden p-0 transition-[transform,background-color,border-color,box-shadow] duration-200 ease-[var(--ease-premium)] hover:bg-[var(--surface-2)] hover:border-[color:var(--hairline-strong)] h-full flex flex-col"
            >
              <figure class="relative overflow-hidden border-b border-[color:var(--hairline)] bg-white/5 aspect-[4/3] w-full">
                <ResponsivePicture
                  source={workCards[2].image}
                  alt={workCards[2].alt}
                  sizes="(min-width: 1024px) 25vw, 100vw"
                  class="media-zoom absolute inset-0 h-full w-full object-cover"
                  loading="lazy"
                  fetchpriority="low"
                  objectPosition={workCards[2].position}
                />
                <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_top,var(--overlay-black-soft),transparent)]" />
              </figure>

              <div class="flex flex-col p-6 sm:p-7 flex-grow">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="rounded-full border border-[color:var(--hairline)] bg-[color:var(--surface-overlay)] px-3 py-1 font-mono text-[11px] font-medium uppercase tracking-[0.14em] text-[var(--accent-solid)]">
                    {workCards[2].tag}
                  </span>
                  <Eyebrow>{workCards[2].eyebrow}</Eyebrow>
                </div>
                <h3 class="mt-4 text-xl font-semibold tracking-tight text-[var(--text-primary)]">
                  {workCards[2].title}
                </h3>
                <p class="section-copy mt-3 text-[14px] leading-relaxed">
                  {workCards[2].outcome}
                </p>
              </div>
            </Card>
          </FadeIn>

          <!-- Card 4: Technical Specifications Bento Block (Landscape, col-span-2) -->
          <FadeIn motion="depthCardReveal" delay={450} className="md:col-span-2" as="div">
            <Card
              className="premium-card group overflow-hidden p-6 sm:p-8 transition-[transform,background-color,border-color,box-shadow] duration-200 ease-[var(--ease-premium)] hover:bg-[var(--surface-2)] hover:border-[color:var(--hairline-strong)] h-full flex flex-col justify-between"
            >
              <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between">
                  <span class="rounded-full border border-[color:var(--hairline)] bg-[color:var(--surface-overlay)] px-3 py-1 font-mono text-[11px] font-medium uppercase tracking-[0.14em] text-[var(--accent-solid)]">
                    SPECIFICATIONS
                  </span>
                  <span class="font-mono text-[11px] tracking-[0.16em] text-[var(--text-muted)]">SYSTEM V3.0</span>
                </div>
                <h3 class="mt-4 text-2xl font-semibold tracking-tight text-[var(--text-primary)]">
                  Performance-first build quality.
                </h3>
                <p class="section-copy mt-2 text-[14px] leading-relaxed max-w-xl">
                  We verify core metrics on every deployment. Our sites load in under a second, use semantic layouts for optimal search indexing, and offer clear code ownership without SaaS lock-in.
                </p>
              </div>

              <div class="mt-8 grid grid-cols-2 gap-4 border-t border-[color:var(--hairline)] pt-6">
                <div>
                  <span class="block font-mono text-[10px] uppercase tracking-[0.16em] text-[var(--text-muted)]">LOAD SPEED TARGET</span>
                  <span class="text-2xl font-bold tracking-tight text-[var(--accent-solid)]">100/100</span>
                </div>
                <div>
                  <span class="block font-mono text-[10px] uppercase tracking-[0.16em] text-[var(--text-muted)]">CODE STRUCTURE</span>
                  <span class="text-2xl font-bold tracking-tight text-[var(--text-primary)]">Semantic HTML5</span>
                </div>
              </div>
            </Card>
          </FadeIn>
        </div>
      </div>
    </section>

    <section class="page-section section-shell">
      <div class="axiom-container">
        <FadeIn motion="editorialMaskReveal" className="max-w-3xl">
          <Eyebrow>SERVICES</Eyebrow>
          <SectionDivider className="mt-6" />
            <MotionHeading as="h2" text="Three ways to *strengthen* the site." className="section-heading mt-4" />
        </FadeIn>

        <div class="mt-12 flex flex-col border-t border-[color:var(--hairline)]">
          {services.map((service, index) => (
            <FadeIn motion="timelineSequence" delay={Math.min(index * 120, 480)} as="div">
              <div class="border-b border-[color:var(--hairline)]">
                <a
                  href={service.href}
                  class="group flex flex-col md:flex-row md:items-center justify-between py-8 px-6 transition-all duration-300 hover:bg-white/[0.01]"
                >
                  <div class="flex items-start md:items-center gap-6">
                    <span class="font-mono text-[14px] font-semibold text-[var(--accent-solid)] pt-1 md:pt-0">
                      0{index + 1}
                    </span>
                    <div class="flex items-center gap-4">
                      <DrawIcon name={service.icon} className="transition-transform duration-300 group-hover:rotate-90 group-hover:text-[var(--accent-solid)] text-[var(--text-muted)]" />
                      <div class="flex flex-col gap-1">
                        <h3 class="text-xl md:text-2xl font-medium tracking-tight text-[var(--text-primary)]">
                          {service.label}
                        </h3>
                        <p class="section-copy max-w-2xl text-[14px] md:text-[15px] mt-0.5">
                          {service.description}
                        </p>
                      </div>
                    </div>
                  </div>
                  <div class="mt-6 md:mt-0 flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--text-muted)] group-hover:text-[var(--accent-solid)] transition-colors duration-300">
                    Explore Service
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 transform group-hover:translate-x-1.5 transition-transform duration-300"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                  </div>
                </a>
              </div>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section section-shell">
      <div class="axiom-container">
        <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.3fr)] lg:items-start lg:gap-16">
          <FadeIn motion="editorialMaskReveal" className="space-y-4 lg:sticky lg:top-32">
            <Eyebrow>WHY AXIOM</Eyebrow>
            <SectionDivider className="mt-6" />
            <MotionHeading as="h2" text="Where reputation dictates *execution*." className="section-heading mt-4" />
            <p class="section-copy mt-4 md:text-[17px]">
              Established businesses. Higher-ticket services. If the site needs to look credible before a new client picks up the phone, this is built for you.
            </p>
          </FadeIn>

          <div class="flex flex-col border-t border-[color:var(--hairline)]">
            {principles.map((principle, index) => (
              <FadeIn motion="timelineSequence" delay={Math.min(index * 120, 480)} as="div">
                <div class="grid gap-4 py-8 border-b border-[color:var(--hairline)] sm:grid-cols-[3.5rem_minmax(0,1fr)]">
                  <div class="font-mono text-3xl font-light text-[var(--accent-solid)] leading-none pt-0.5">
                    {principle.number}
                  </div>
                  <div class="flex flex-col gap-2">
                    <div class="flex items-center gap-3">
                      <DrawIcon name={principle.icon} className="text-[var(--accent-solid)] w-5 h-5 shrink-0" />
                      <h3 class="text-[clamp(1.15rem,1.4vw,1.35rem)] font-semibold tracking-tight text-[var(--text-primary)]">
                        {principle.title}
                      </h3>
                    </div>
                    <p class="section-copy text-[14px] leading-relaxed mt-1">
                      {principle.description}
                    </p>
                  </div>
                </div>
              </FadeIn>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="page-section section-shell">
      <div class="axiom-container">
        <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.3fr)] lg:items-start lg:gap-16">
          <FadeIn motion="editorialMaskReveal" className="space-y-4 lg:sticky lg:top-32">
            <Eyebrow>PROCESS</Eyebrow>
            <SectionDivider className="mt-6" />
            <MotionHeading as="h2" text="A disciplined, *30-day* delivery." className="section-heading mt-4" />
            <p class="section-copy mt-4 md:text-[17px]">
              We run a strict, four-stage deployment process that removes the overhead, scope drift, and communication lag of traditional agency models.
            </p>
            <div class="pt-2">
              <Button asChild variant="ghost" className="px-0 text-[var(--accent-solid)]">
                <a href="/services#timeline" class="inline-flex items-center gap-2">
                  Explore our operating timeline
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </a>
              </Button>
            </div>
          </FadeIn>

          <FadeIn motion="precisionPricingReveal" as="div">
            <FeatureCarousel
              client:visible
              steps={[
                { id: '01', name: 'Stage 01', title: 'Diagnostics', description: 'We audit your current brand assets, copywriting, and user drop-off points to define the strategic blueprint.' },
                { id: '02', name: 'Stage 02', title: 'Blueprinting', description: 'We design the page hierarchy, layout flow, and exact copywriting draft. The entire architecture is approved before writing code.' },
                { id: '03', name: 'Stage 03', title: 'Custom Engineering', description: 'We develop the platform using lightweight, custom code. No templates, no bloated plugins, and zero performance compromises.' },
                { id: '04', name: 'Stage 04', title: 'Release & Handoff', description: 'We execute comprehensive DNS, speed, and responsive audits before release, handing over a clean repository with managed hosting options.' },
              ]}
              image={{
                step1light1: '/images/lighthouse-before.png',
                step1light2: '/images/case-study-1-960.webp',
                step2light1: '/images/case-study-2-960.webp',
                step2light2: '/images/case-study-3-800.webp',
                step3light: '/images/work-hvac-1200.webp',
                step4light: '/images/lighthouse-after.png',
                alt: 'Axiom delivery process showcase',
              }}
              step1img1Class="pointer-events-none w-[55%] rounded-2xl border border-[color:var(--hairline)] shadow-[0_30px_60px_-30px_rgba(0,0,0,0.6)] transition-all duration-500 max-md:scale-[150%] max-md:rounded-xl left-[8%] top-[58%] md:left-[3%] md:top-[38%] md:group-hover:translate-y-2"
              step1img2Class="pointer-events-none w-[55%] rounded-2xl border border-[color:var(--hairline)] shadow-[0_30px_60px_-30px_rgba(0,0,0,0.6)] overflow-hidden transition-all duration-500 max-md:scale-[150%] left-[55%] top-[42%] md:left-[48%] md:top-[28%] md:group-hover:-translate-y-4"
              step2img1Class="pointer-events-none w-[50%] rounded-2xl border border-[color:var(--hairline)] shadow-[0_30px_60px_-30px_rgba(0,0,0,0.6)] overflow-hidden transition-all duration-500 max-md:scale-[150%] left-[8%] top-[60%] md:left-[3%] md:top-[36%] md:group-hover:translate-y-2"
              step2img2Class="pointer-events-none w-[45%] rounded-2xl border border-[color:var(--hairline)] shadow-[0_30px_60px_-30px_rgba(0,0,0,0.6)] overflow-hidden transition-all duration-500 max-md:scale-[140%] left-[60%] top-[42%] md:left-[52%] md:top-[26%] md:group-hover:-translate-y-4"
              step3imgClass="pointer-events-none w-[90%] rounded-2xl border border-[color:var(--hairline)] shadow-[0_40px_80px_-30px_rgba(0,0,0,0.7)] overflow-hidden transition-all duration-500 left-[5%] top-[42%] md:left-[5%] md:top-[30%]"
              step4imgClass="pointer-events-none w-[90%] rounded-2xl border border-[color:var(--hairline)] shadow-[0_40px_80px_-30px_rgba(0,0,0,0.7)] overflow-hidden transition-all duration-500 left-[5%] top-[42%] md:left-[5%] md:top-[30%]"
              bgClass="bg-gradient-to-b from-[var(--surface-1)] to-[var(--surface-2)]"
            />
          </FadeIn>
        </div>
      </div>
    </section>

    <section class="page-section section-shell">
      <div class="axiom-container">
        <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.3fr)] lg:items-start lg:gap-16">
          <FadeIn motion="editorialMaskReveal" className="space-y-4 lg:sticky lg:top-32">
            <Eyebrow>DIRECT PARTNERSHIP</Eyebrow>
            <SectionDivider className="mt-6" />
            <MotionHeading as="h2" text="Direct partnership. *Direct execution.*" className="section-heading mt-4" />
            <p class="section-copy mt-4 md:text-[17px]">
              Axiom is run by two partners. You work directly with the strategists and engineers executing the scope. No account managers, no layers of overhead, and a direct line to updates.
            </p>
          </FadeIn>

          <div class="grid gap-5 md:grid-cols-2 lg:mt-0">
            {team.map((member, index) => (
              <FadeIn motion="depthCardReveal" delay={Math.min(index * 160, 640)} as="div" className="h-full">
                <Card className="group rounded-2xl border-[color:var(--hairline)] bg-[color:var(--surface-overlay)] p-8 transition-all duration-300 hover:border-[color:var(--hairline-strong)] hover:bg-[color:var(--surface-overlay-press)] h-full flex flex-col justify-between">
                  <div class="flex h-full flex-col">
                    <div class="flex items-start gap-4">
                      <div
                        aria-hidden="true"
                        class="relative flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-[color:var(--accent-border)] bg-[color:var(--surface-overlay)] shadow-[inset_0_1px_0_rgba(255,255,255,0.05),0_8px_24px_rgba(0,0,0,0.14)]"
                      >
                        <span aria-hidden="true" class="animate-ring-pulse absolute inset-0 rounded-full border border-[color:var(--accent-solid)]/40 opacity-0 transition-all duration-700 group-hover:scale-[1.2] group-hover:opacity-0 motion-safe:animate-none"></span>
                        {member.monogram === 'aidan' ? (
                          <svg
                            viewBox="0 0 48 48"
                            class="h-12 w-12 text-[var(--accent-solid)]"
                            fill="currentColor"
                            aria-hidden="true"
                          >
                            <path d="M24 8L9 38h7l3.1-6h9.8l3.1 6h7L24 8zm-3 17 3-6 3 6h-6z" />
                          </svg>
                        ) : (
                          <svg
                            viewBox="0 0 48 48"
                            class="h-12 w-12 text-[var(--accent-solid)]"
                            fill="currentColor"
                            aria-hidden="true"
                          >
                            <path d="M13 38V10h14.2c6.8 0 10.8 3.3 10.8 8.6 0 4.2-2.4 7-6.3 8.1l7.1 11.3h-7.8l-6-10H20v10h-7zm7-15h6.7c3.1 0 4.7-1.2 4.7-3.8s-1.6-3.9-4.7-3.9H20V23z" />
                          </svg>
                        )}
                      </div>

                      <div class="min-w-0">
                        <h3 class="text-xl font-semibold text-[var(--text-primary)]">{member.name}</h3>
                        <div class="mt-3 flex flex-wrap gap-1">
                          {member.roles.map((role) => (
                            <span class="rounded-full bg-[color:var(--surface-overlay-press)] px-2 py-0.5 text-[12px] uppercase tracking-widest text-[var(--text-secondary)]">
                              {role}
                            </span>
                          ))}
                        </div>
                      </div>
                    </div>

                    <p class="mt-6 text-[15px] leading-[1.7] text-[var(--text-secondary)]">
                      {member.description}
                    </p>
                  </div>
                </Card>
              </FadeIn>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="final-cta-panel">
      <div class="axiom-container py-16 md:py-20">
        <div class="mx-auto max-w-4xl text-center">
          <FadeIn as="div" motion="finalFrameFooter">
            <SectionDivider className="mx-auto mb-6" />
            <MotionHeading as="h2" text="Make the site *easier to believe*." className="section-heading mx-auto text-[clamp(32px,4vw,52px)] font-[600] text-[var(--text-primary)]" />
            <p class="section-copy mx-auto mt-5 md:text-[17px]">
              Monthly, ownership, or custom scope. Pricing is public, the launch path is defined, and every build is checked for speed and mobile quality before it ships.
            </p>
            <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row sm:items-center">
              <Button asChild size="lg" className="w-full sm:w-auto">
                <a href={CTA_PATHS.startProject}>Start a project</a>
              </Button>
              <Button asChild variant="ghost" size="lg" className="w-full px-0 sm:w-auto">
                <a href="/pricing">See pricing</a>
              </Button>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>
  </main>

  <style>
    .hero-shell {
      isolation: isolate;
    }

    .hero-shell::after {
      content: '';
      position: absolute;
      inset: auto 0 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--hairline-strong), transparent);
      opacity: 0.8;
    }

    .hero-aurora {
      animation: hero-aurora-drift 30s ease-in-out infinite;
      transform-origin: center;
      will-change: transform, opacity;
    }

    .hero-grid {
      background-image:
        linear-gradient(to right, rgba(255, 255, 255, 0.04) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(255, 255, 255, 0.032) 1px, transparent 1px);
      background-size: 92px 92px;
      opacity: 0.18;
      mask-image: radial-gradient(circle at 78% 24%, black, transparent 62%);
    }

    .hero-browser-shell {
      position: relative;
      width: clamp(22rem, 32vw, 30rem);
      opacity: 0.78;
      transform: translate3d(0.75rem, -0.5rem, 0) rotate(1.6deg);
      transform-origin: center;
      pointer-events: none;
      will-change: transform, opacity;
    }

    .hero-visual {
      animation: hero-visual-float 8s var(--ease-premium-soft) infinite;
    }

    .hero-browser-frame {
      fill: rgba(255, 255, 255, 0.026);
      stroke: rgba(255, 255, 255, 0.13);
      stroke-width: 1;
    }

    .hero-browser-chrome {
      fill: rgba(255, 255, 255, 0.035);
    }

    .hero-browser-dot {
      fill: rgba(255, 255, 255, 0.22);
    }

    .hero-browser-bar {
      fill: var(--accent-solid);
      opacity: 0;
      transform-box: fill-box;
      transform-origin: left center;
      animation:
        browser-bar-reveal 1.45s var(--ease-cinematic) var(--browser-delay, 0s) forwards,
        browser-bar-pulse 8s ease-in-out calc(1.2s + var(--browser-delay, 0s)) infinite;
      will-change: opacity, transform;
    }

    .hero-browser-chip {
      fill: rgba(255, 255, 255, 0.075);
      stroke: rgba(255, 255, 255, 0.08);
      stroke-width: 1;
    }

    .hero-browser-chip-soft {
      fill: rgb(var(--accent-v2-rgb, var(--accent-current-rgb)) / 0.14);
      stroke: rgb(var(--accent-v2-rgb, var(--accent-current-rgb)) / 0.22);
    }

    .hero-browser-arc {
      stroke: rgb(var(--accent-v2-rgb, var(--accent-current-rgb)) / 0.5);
      stroke-width: 1.5;
      stroke-linecap: round;
      stroke-dasharray: 220;
      stroke-dashoffset: 220;
      animation: hero-arc-draw 1.45s var(--ease-cinematic) 0.9s forwards;
    }

    .hero-browser-arc-muted {
      stroke: rgba(255,255,255,0.22);
      animation-delay: 1.08s;
    }

    .hero-status-panel {
      position: absolute;
      right: -0.85rem;
      bottom: 2.25rem;
      width: min(16rem, 62%);
      border: 1px solid var(--hairline-strong);
      border-radius: 16px;
      background: rgba(0, 0, 0, 0.72);
      box-shadow: var(--shadow-card-elevated);
      padding: 1rem 1.05rem;
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      animation: hero-panel-in 0.96s var(--ease-cinematic) 1.08s both;
    }

    .hero-status-panel span,
    .hero-status-panel strong {
      display: block;
    }

    .hero-status-panel span {
      font-family: var(--font-mono);
      font-size: 0.67rem;
      line-height: 1.2;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent-solid);
    }

    .hero-status-panel strong {
      margin-top: 0.35rem;
      color: var(--text-primary);
      font-size: 0.95rem;
      line-height: 1.35;
      font-weight: 600;
    }

    @keyframes browser-bar-reveal {
      0% {
        opacity: 0;
        transform: translateY(5px);
      }

      100% {
        opacity: 0.6;
        transform: translateY(0);
      }
    }

    @keyframes browser-bar-pulse {
      0%,
      18%,
      100% {
        opacity: 0.6;
        transform: translateY(0);
      }

      48% {
        opacity: 0.42;
        transform: translateY(0);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .hero-aurora {
        animation: none !important;
      }

      .hero-browser-shell {
        opacity: 0.45;
        transform: translate3d(0.75rem, -0.5rem, 0) rotate(1.6deg);
      }

      .hero-browser-bar {
        animation: none !important;
        opacity: 0.55;
        transform: none;
      }

      .hero-visual,
      .hero-browser-arc,
      .hero-status-panel {
        animation: none !important;
      }

      .hero-browser-arc {
        stroke-dashoffset: 0;
      }
    }

    @keyframes hero-aurora-drift {
      0%,
      100% {
        transform: translate3d(-1.5%, -0.5%, 0);
      }

      50% {
        transform: translate3d(1.5%, 0.75%, 0);
      }
    }

    @keyframes hero-visual-float {
      0%,
      100% {
        transform: translate3d(0.75rem, -0.5rem, 0) rotate(1.6deg);
      }

      50% {
        transform: translate3d(0.25rem, -1.15rem, 0) rotate(1deg);
      }
    }

    @keyframes hero-arc-draw {
      to {
        stroke-dashoffset: 0;
      }
    }

    @keyframes hero-panel-in {
      0% {
        opacity: 0;
        transform: translate3d(0, 12px, 0);
      }

      100% {
        opacity: 1;
        transform: translate3d(0, 0, 0);
      }
    }

    .group:hover [aria-hidden='true'].animate-ring-pulse {
      animation: ring-pulse 0.8s ease-out 1;
    }

    @keyframes ring-pulse {
      0% {
        transform: scale(1);
        opacity: 0.45;
      }

      100% {
        transform: scale(1.35);
        opacity: 0;
      }
    }
  </style>
</SiteLayout>

