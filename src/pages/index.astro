---
import ResponsivePicture from '../components/site/ResponsivePicture.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { CTA_PATHS } from '../lib/cta';
import { HOME_JSON_LD, WEBSITE_SCHEMA, SEO_ROUTES } from '../lib/seo';
import { getWorkProofImage } from '../lib/workProofImages';
import { FadeIn } from '../components/ui/FadeIn';
import { FeatureCarousel } from '../components/ui/FeatureCarousel';
import { Button } from '../components/ui/button';
import { Card } from '../components/ui/card';
import { Eyebrow } from '../components/ui/Eyebrow';
import DrawIcon from '../components/ui/DrawIcon.astro';
import { MotionHeading } from '../components/motion/MotionHeading';
import { ProofBar } from '../components/motion/ProofBar';
import { SectionDivider } from '../components/motion/SectionDivider';

const workCards = [
  {
    tag: 'CONCEPT',
    eyebrow: 'CONVERSION STRATEGY',
    title: 'Aurelia Dental Studio',
    outcome: 'Clear, warm, and easy to navigate. New patients find what they need and book without second-guessing.',
    image: getWorkProofImage('concept-dental-demo').source,
    alt: getWorkProofImage('concept-dental-demo').alt || 'Aurelia Dental Studio',
    position: getWorkProofImage('concept-dental-demo').position || 'center 30%',
  },
  {
    tag: 'CONCEPT',
    eyebrow: 'LOCAL BUSINESS',
    title: 'Nails Studio Demo',
    outcome: 'Booking is visible early, services are easy to compare, and the brand reads as calm and polished.',
    image: getWorkProofImage('concept-salon-demo').source,
    alt: getWorkProofImage('concept-salon-demo').alt || 'Nails Studio Demo',
    position: getWorkProofImage('concept-salon-demo').position || 'center 30%',
  },
  {
    tag: 'CONCEPT',
    eyebrow: 'REBUILD',
    title: 'Blackline Barber Co.',
    outcome: 'Fast, sharp, and direct. Clients get to the booking button in seconds — no hunting required.',
    image: getWorkProofImage('concept-barber-demo').source,
    alt: getWorkProofImage('concept-barber-demo').alt || 'Blackline Barber Co.',
    position: getWorkProofImage('concept-barber-demo').position || 'center 30%',
  },
] as const;

const principles = [
  {
    number: '01',
    title: 'Absolute commercial alignment',
    description: 'We ensure visitors immediately comprehend your exact offer, target market, and the primary path to engagement. Zero ambiguity.',
    icon: 'eye',
  },
  {
    number: '02',
    title: 'Evidence-based authority',
    description: 'We place case outcomes, industry credentials, and verified testimonials exactly where buyers make critical evaluation decisions. We never fabricate metrics.',
    icon: 'shield-check',
  },
  {
    number: '03',
    title: 'Uncompromised performance',
    description: 'Every platform loads in under one second. We audit semantic HTML, responsive grids, and Core Web Vitals on every release to ensure flawless rendering.',
    icon: 'bolt',
  },
  {
    number: '04',
    title: 'Active platform guardianship',
    description: 'We handle hosting security, performance audits, and content updates. You retain direct partner support post-launch without agency ticketing queues.',
    icon: 'key',
  },
] as const;

const services = [
  {
    label: 'Conversion Sites',
    description:
      'For service businesses that need a clearer offer, stronger trust signals, and fewer steps from visit to inquiry.',
    href: '/services#conversion-sites',
    icon: 'target',
    metric: '2–3 week build',
  },
  {
    label: 'Local Business Websites',
    description:
      'For companies whose reputation, service quality, and contact path need to be obvious on every device.',
    href: '/services#local-business-websites',
    icon: 'crown',
    metric: '3–4 week build',
  },
  {
    label: 'Rebuilds',
    description:
      'Replace a dated or confusing site while protecting useful content, redirects, domains, and buyer trust.',
    href: '/services#rebuilds',
    icon: 'refresh',
    metric: 'From $3,500',
  },
] as const;

const team = [
  {
    name: 'Aidan',
    monogram: 'aidan',
    roles: ['Client Strategy & Scope'],
    description: 'Architects the commercial message and content hierarchy. Ensures the site structure maps directly to how buyers evaluate your services.',
  },
  {
    name: 'Riley',
    monogram: 'riley',
    roles: ['Platform Architecture & Engineering'],
    description: 'Engineers the codebase and manages platform delivery. Focuses on rendering speeds, responsive integrity, and clean codebase handoffs.',
  },
] as const;
---

<SiteLayout
  title={SEO_ROUTES.home.title}
  description={SEO_ROUTES.home.description}
  canonicalPath="/"
  ogImageAlt="Axiom Web homepage – custom web development in Kitchener-Waterloo."
  schema={[HOME_JSON_LD, WEBSITE_SCHEMA]}
>
  <main id="main-content" tabindex="-1" class="-mt-28 md:-mt-32">

    <!-- ═══════════════════ HERO — ═══════════════════ -->
    <section class="axiom-hero relative min-h-[90vh] overflow-hidden pb-24 pt-40 md:pb-32 md:pt-48">
      <!-- Dramatic light architecture -->
      <div aria-hidden="true" class="pointer-events-none absolute inset-0">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_70%_0%,rgb(var(--accent-v2-rgb,var(--accent-current-rgb))/0.15),transparent_48%)]" />
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_20%_80%,rgba(255,255,255,0.04),transparent_40%)]" />
        <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(0,0,0,0) 60%, #000 100%);" />
      </div>

      <!-- Fine architectural grid -->
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 opacity-[0.04]"
        style="background-image:
          linear-gradient(to right, rgba(212,175,55,0.4) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(212,175,55,0.3) 1px, transparent 1px);
        background-size: 64px 64px;"
      />

      <div class="axiom-container relative">
        <div class="max-w-5xl">
          <!-- Eyebrow -->
          <FadeIn motion="eyebrow" delay={0}>
            <div class="mb-6 inline-flex items-center gap-3 rounded-full border border-[color:var(--accent-border)] bg-[rgb(var(--accent-v2-rgb,var(--accent-current-rgb))/0.06)] px-4 py-1.5">
              <span class="inline-block h-1.5 w-1.5 rounded-full bg-[var(--accent-solid)]" />
              <span class="font-mono text-[11px] font-medium uppercase tracking-[0.12em] text-[var(--accent-solid)]">Premium Web Development</span>
            </div>
          </FadeIn>

          <!-- Primary headline — editorial scale -->
          <FadeIn motion="sceneOpen" className="hero-copy-primary">
            <MotionHeading
              as="h1"
              text="Websites built for companies with *reputations to protect*."
              className="text-balance"
            />
          </FadeIn>

          <!-- Supporting copy -->
          <FadeIn delay={520} motion="editorialMaskReveal">
            <p class="mt-8 max-w-2xl text-[1.15rem] leading-[1.7] text-[var(--text-secondary)] md:text-[1.2rem]">
              We deploy high-performance web platforms for firms that cannot afford to look second-rate. Sub-second load speeds, conversion-guided layout design, and direct partner execution from review to launch.
            </p>
          </FadeIn>

          <!-- CTAs -->
          <FadeIn delay={780} motion="sceneOpen">
            <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
              <Button asChild size="lg" className="w-full sm:w-auto">
                <a href={CTA_PATHS.startProject}>Start a project</a>
              </Button>
              <Button asChild variant="ghost" size="lg" className="w-full px-0 sm:w-auto">
                <a href="/services">See services &rarr;</a>
              </Button>
            </div>
          </FadeIn>
        </div>

        <!-- Bottom-right architectural accent -->
        <FadeIn delay={1200} as="div" motion="editorial" className="absolute -bottom-6 right-0 hidden lg:block">
          <div class="flex items-center gap-3 font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--text-muted)]">
            <span class="inline-block h-px w-12 bg-[var(--accent-border)]" />
            <span>Sub-second load speeds</span>
            <span class="inline-block h-px w-12 bg-[var(--accent-border)]" />
            <span>Semantic HTML5</span>
          </div>
        </FadeIn>
      </div>
    </section>

    <div aria-hidden="true" class="section-glow section-glow-offset-top" />

    <!-- ═══════════════════ PROOF BAR ═══════════════════ -->
    <div class="relative"><ProofBar /></div>

    <div aria-hidden="true" class="section-glow section-glow-offset-top" />

    <!-- ═══════════════════ SELECTED WORK ═══════════════════ -->
    <section class="page-section section-shell">
      <div class="axiom-container">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
          <FadeIn motion="editorialMaskReveal" className="max-w-3xl">
            <Eyebrow>SELECTED WORK</Eyebrow>
            <SectionDivider className="mt-6" />
            <MotionHeading as="h2" text="Structural demonstrations of *our standard*." class="section-heading mt-4" />
            <p class="section-copy mt-4 md:text-[17px]">
              A curated portfolio of sector-specific platforms engineered to our exact performance and message standards. We build and label these interactive models to demonstrate structural quality without compromising client privacy.
            </p>
          </FadeIn>

          <FadeIn delay={180} motion="sceneOpen" className="flex flex-wrap items-center gap-3 lg:justify-end lg:pb-1">
            <a
              href="/work"
              class="inline-flex min-h-11 items-center justify-center rounded-full border border-[color:var(--accent-border)] bg-[rgba(214,173,66,0.08)] px-5 font-mono text-[12px] font-medium uppercase tracking-[0.12em] text-[var(--accent-solid)] transition-[border-color,background-color,color] duration-200 hover:border-[color:var(--accent-solid)] hover:bg-[rgba(214,173,66,0.12)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--accent-solid)]"
            >
              View all work
            </a>
          </FadeIn>
        </div>

        <!-- Work grid — larger, more editorial imagery -->
        <div id="selected-work-demos" class="mt-12 grid gap-6 grid-cols-1 md:grid-cols-12 md:auto-rows-[320px]">
          <!-- Card 1: Aurelia Dental Studio (hero image span) -->
          <FadeIn motion="depthCardReveal" delay={0} className="md:col-span-7 md:row-span-2 md:auto-rows-auto" as="div">
            <Card className="group overflow-hidden p-0 transition-all duration-300 hover:bg-[var(--surface-2)] hover:border-[color:var(--hairline-strong)] h-full flex flex-col md:flex-row">
              <figure class="relative overflow-hidden border-b md:border-b-0 md:border-r border-[color:var(--hairline)] bg-white/5 md:w-3/5 h-full min-h-[280px] md:min-h-[320px]">
                <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent z-10 pointer-events-none" />
                <ResponsivePicture
                  source={workCards[0].image}
                  alt={workCards[0].alt}
                  sizes="(min-width: 1024px) 50vw, 100vw"
                  class="media-zoom absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                  loading="lazy"
                  fetchpriority="low"
                  objectPosition={workCards[0].position}
                />
              </figure>
              <div class="flex flex-col justify-center p-7 sm:p-10 md:w-2/5">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="rounded-full border border-[color:var(--hairline)] bg-[color:var(--surface-overlay)] px-3 py-1 font-mono text-[11px] font-medium uppercase tracking-[0.14em] text-[var(--accent-solid)]">
                    {workCards[0].tag}
                  </span>
                  <Eyebrow>{workCards[0].eyebrow}</Eyebrow>
                </div>
                <h3 class="mt-5 text-[clamp(1.35rem,2.4vw,1.85rem)] font-semibold tracking-tight text-[var(--text-primary)]">
                  {workCards[0].title}
                </h3>
                <p class="section-copy mt-3 text-[14.5px] leading-relaxed">
                  {workCards[0].outcome}
                </p>
              </div>
            </Card>
          </FadeIn>

          <!-- Card 2: Nails Studio Demo -->
          <FadeIn motion="depthCardReveal" delay={150} className="md:col-span-5 md:row-span-1" as="div">
            <Card className="group overflow-hidden p-0 transition-all duration-300 hover:bg-[var(--surface-2)] hover:border-[color:var(--hairline-strong)] h-full flex flex-col">
              <figure class="relative overflow-hidden border-b border-[color:var(--hairline)] bg-white/5 aspect-[16/9] md:aspect-[4/3] w-full">
                <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent z-10 pointer-events-none" />
                <ResponsivePicture
                  source={workCards[1].image}
                  alt={workCards[1].alt}
                  sizes="(min-width: 1024px) 30vw, 100vw"
                  class="media-zoom absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                  loading="lazy"
                  fetchpriority="low"
                  objectPosition={workCards[1].position}
                />
              </figure>
              <div class="flex flex-col p-6 sm:p-7 flex-grow">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="rounded-full border border-[color:var(--hairline)] bg-[color:var(--surface-overlay)] px-3 py-1 font-mono text-[11px] font-medium uppercase tracking-[0.14em] text-[var(--accent-solid)]">
                    {workCards[1].tag}
                  </span>
                  <Eyebrow>{workCards[1].eyebrow}</Eyebrow>
                </div>
                <h3 class="mt-4 text-[1.3rem] font-semibold tracking-tight text-[var(--text-primary)]">
                  {workCards[1].title}
                </h3>
                <p class="section-copy mt-2 text-[14px] leading-relaxed">
                  {workCards[1].outcome}
                </p>
              </div>
            </Card>
          </FadeIn>

          <!-- Card 3: Blackline Barber Co. -->
          <FadeIn motion="depthCardReveal" delay={300} className="md:col-span-5 md:row-span-1" as="div">
            <Card className="group overflow-hidden p-0 transition-all duration-300 hover:bg-[var(--surface-2)] hover:border-[color:var(--hairline-strong)] h-full flex flex-col">
              <figure class="relative overflow-hidden border-b border-[color:var(--hairline)] bg-white/5 aspect-[16/9] md:aspect-[4/3] w-full">
                <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent z-10 pointer-events-none" />
                <ResponsivePicture
                  source={workCards[2].image}
                  alt={workCards[2].alt}
                  sizes="(min-width: 1024px) 30vw, 100vw"
                  class="media-zoom absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                  loading="lazy"
                  fetchpriority="low"
                  objectPosition={workCards[2].position}
                />
              </figure>
              <div class="flex flex-col p-6 sm:p-7 flex-grow">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="rounded-full border border-[color:var(--hairline)] bg-[color:var(--surface-overlay)] px-3 py-1 font-mono text-[11px] font-medium uppercase tracking-[0.14em] text-[var(--accent-solid)]">
                    {workCards[2].tag}
                  </span>
                  <Eyebrow>{workCards[2].eyebrow}</Eyebrow>
                </div>
                <h3 class="mt-4 text-[1.3rem] font-semibold tracking-tight text-[var(--text-primary)]">
                  {workCards[2].title}
                </h3>
                <p class="section-copy mt-2 text-[14px] leading-relaxed">
                  {workCards[2].outcome}
                </p>
              </div>
            </Card>
          </FadeIn>

          <!-- Card 4: Specifications Bento Block -->
          <FadeIn motion="depthCardReveal" delay={450} className="md:col-span-7 md:row-span-1" as="div">
            <Card className="group overflow-hidden p-8 sm:p-10 transition-all duration-300 hover:bg-[var(--surface-2)] hover:border-[color:var(--hairline-strong)] h-full flex flex-col justify-between">
              <div class="flex flex-col gap-3">
                <div class="flex items-center justify-between">
                  <span class="rounded-full border border-[color:var(--hairline)] bg-[color:var(--surface-overlay)] px-3 py-1 font-mono text-[11px] font-medium uppercase tracking-[0.14em] text-[var(--accent-solid)]">
                    SPECIFICATIONS
                  </span>
                  <span class="font-mono text-[11px] tracking-[0.16em] text-[var(--text-muted)]">SYSTEM V3.0</span>
                </div>
                <h3 class="mt-4 text-2xl font-semibold tracking-tight text-[var(--text-primary)]">
                  Performance-first build quality.
                </h3>
                <p class="section-copy mt-2 text-[14.5px] leading-relaxed max-w-xl">
                  We verify core metrics on every deployment. Our sites load in under a second, use semantic layouts for optimal search indexing, and offer clear code ownership without SaaS lock-in.
                </p>
              </div>
              <div class="mt-10 grid grid-cols-2 gap-6 border-t border-[color:var(--hairline)] pt-7">
                <div>
                  <span class="block font-mono text-[10px] uppercase tracking-[0.16em] text-[var(--text-muted)]">LOAD SPEED TARGET</span>
                  <span class="text-[clamp(2rem,3vw,2.5rem)] font-bold tracking-tight text-[var(--accent-solid)]">100/100</span>
                </div>
                <div>
                  <span class="block font-mono text-[10px] uppercase tracking-[0.16em] text-[var(--text-muted)]">CODE STRUCTURE</span>
                  <span class="text-[clamp(1.25rem,1.8vw,1.5rem)] font-bold tracking-tight text-[var(--text-primary)]">Semantic HTML5</span>
                </div>
              </div>
            </Card>
          </FadeIn>
        </div>
      </div>
    </section>

    <div aria-hidden="true" class="section-glow section-glow-offset-top" />

    <!-- ═══════════════════ SERVICES ═══════════════════ -->
    <section class="page-section section-shell">
      <div class="axiom-container">
        <FadeIn motion="editorialMaskReveal" className="max-w-3xl">
          <Eyebrow>SERVICES</Eyebrow>
          <SectionDivider className="mt-6" />
          <MotionHeading as="h2" text="Three ways to *strengthen* the site." class="section-heading mt-4" />
        </FadeIn>

        <!-- Service cards — visual, card-based -->
        <div class="mt-12 grid gap-6 md:grid-cols-3">
          {services.map((service, index) => (
            <FadeIn motion="depthCardReveal" delay={Math.min(index * 150, 450)} as="div" className="h-full">
              <a
                href={service.href}
                class="group relative flex h-full flex-col overflow-hidden rounded-[var(--radius-card)] border border-[color:var(--hairline)] bg-[var(--surface-1)] p-8 transition-all duration-300 hover:border-[color:var(--accent-border)] hover:bg-[var(--surface-2)] hover:shadow-[var(--shadow-card-hover)]"
              >
                <!-- Number accent -->
                <div class="mb-6 flex items-center justify-between">
                  <span class="font-mono text-[clamp(2.5rem,4vw,3.5rem)] font-bold leading-none text-[rgb(var(--accent-v2-rgb,var(--accent-current-rgb))/0.2)] transition-colors duration-300 group-hover:text-[rgb(var(--accent-v2-rgb,var(--accent-current-rgb))/0.35)]">
                    {String(index + 1).padStart(2, '0')}
                  </span>
                  <DrawIcon name={service.icon} className="text-[var(--text-muted)] transition-all duration-300 group-hover:rotate-6 group-hover:text-[var(--accent-solid)]" size={26} />
                </div>

                <h3 class="text-[1.35rem] font-semibold tracking-tight text-[var(--text-primary)]">
                  {service.label}
                </h3>
                <p class="section-copy mt-3 text-[14px] leading-relaxed flex-grow">
                  {service.description}
                </p>

                <!-- Bottom accent -->
                <div class="mt-6 flex items-center gap-3 border-t border-[color:var(--hairline)] pt-5">
                  <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-[var(--text-muted)] transition-colors duration-300 group-hover:text-[var(--accent-solid)]">
                    {service.metric}
                  </span>
                  <span class="ml-auto inline-flex h-7 w-7 items-center justify-center rounded-full border border-[color:var(--hairline)] text-[11px] text-[var(--text-muted)] transition-all duration-300 group-hover:translate-x-1 group-hover:border-[var(--accent-border)] group-hover:text-[var(--accent-solid)]">
                    &rarr;
                  </span>
                </div>
              </a>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <div aria-hidden="true" class="section-glow section-glow-offset-top" />

    <!-- ═══════════════════ WHY AXIOM ═══════════════════ -->
    <section class="page-section section-shell">
      <div class="axiom-container">
        <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.3fr)] lg:items-start lg:gap-16">
          <FadeIn motion="editorialMaskReveal" className="space-y-4 lg:sticky lg:top-32">
            <Eyebrow>WHY AXIOM</Eyebrow>
            <SectionDivider className="mt-6" />
            <MotionHeading as="h2" text="Where reputation dictates *execution*." class="section-heading mt-4" />
            <p class="section-copy mt-4 md:text-[17px]">
              Established businesses. Higher-ticket services. If the site needs to look credible before a new client picks up the phone, this is built for you.
            </p>
          </FadeIn>

          <div class="flex flex-col border-t border-[color:var(--hairline)]">
            {principles.map((principle, index) => (
              <FadeIn motion="timelineSequence" delay={Math.min(index * 120, 480)} as="div">
                <div class="grid gap-4 py-9 border-b border-[color:var(--hairline)] sm:grid-cols-[4rem_minmax(0,1fr)]">
                  <div class="font-mono text-[clamp(2rem,3vw,2.5rem)] font-light text-[rgb(var(--accent-v2-rgb,var(--accent-current-rgb))/0.5)] leading-none pt-0.5">
                    {principle.number}
                  </div>
                  <div class="flex flex-col gap-2">
                    <div class="flex items-center gap-4">
                      <DrawIcon name={principle.icon} className="text-[var(--accent-solid)] w-6 h-6 shrink-0" />
                      <h3 class="text-[clamp(1.15rem,1.4vw,1.35rem)] font-semibold tracking-tight text-[var(--text-primary)]">
                        {principle.title}
                      </h3>
                    </div>
                    <p class="section-copy text-[14.5px] leading-relaxed mt-1 ml-10">
                      {principle.description}
                    </p>
                  </div>
                </div>
              </FadeIn>
            ))}
          </div>
        </div>
      </div>
    </section>

    <div aria-hidden="true" class="section-glow section-glow-offset-top" />

    <!-- ═══════════════════ PROCESS ═══════════════════ -->
    <section class="page-section section-shell">
      <div class="axiom-container">
        <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.3fr)] lg:items-start lg:gap-16">
          <FadeIn motion="editorialMaskReveal" className="space-y-4 lg:sticky lg:top-32">
            <Eyebrow>PROCESS</Eyebrow>
            <SectionDivider className="mt-6" />
            <MotionHeading as="h2" text="A disciplined, *30-day* delivery." class="section-heading mt-4" />
            <p class="section-copy mt-4 md:text-[17px]">
              We run a strict, four-stage deployment process that removes the overhead, scope drift, and communication lag of traditional agency models.
            </p>
            <div class="pt-2">
              <Button asChild variant="ghost" className="px-0 text-[var(--accent-solid)]">
                <a href="/services#timeline" class="inline-flex items-center gap-2">
                  Explore our operating timeline &rarr;
                </a>
              </Button>
            </div>
          </FadeIn>

          <FadeIn motion="precisionPricingReveal" as="div">
            <FeatureCarousel
              client:visible
              steps={[
                { id: '01', name: 'Stage 01', title: 'Diagnostics', description: 'We audit your current brand assets, copywriting, and user drop-off points to define the strategic blueprint.' },
                { id: '02', name: 'Stage 02', title: 'Blueprinting', description: 'We design the page hierarchy, layout flow, and exact copywriting draft. The entire architecture is approved before writing code.' },
                { id: '03', name: 'Stage 03', title: 'Custom Engineering', description: 'We develop the platform using lightweight, custom code. No templates, no bloated plugins, and zero performance compromises.' },
                { id: '04', name: 'Stage 04', title: 'Release & Handoff', description: 'We execute comprehensive DNS, speed, and responsive audits before release, handing over a clean repository with managed hosting options.' },
              ]}
              image={{
                step1light1: '/images/process-diagnostics-analytics.png',
                step1light2: '/images/process-diagnostics-brand-audit.png',
                step2light1: '/images/process-blueprint-sitemap.png',
                step2light2: '/images/process-blueprint-copy.png',
                step3light: '/images/process-engineering-code.png',
                step4light: '/images/process-release-lighthouse.png',
                alt: 'Axiom delivery process showcase',
              }}
              step1img1Class="pointer-events-none w-[62%] rounded-2xl border border-[color:var(--hairline)] shadow-[0_30px_60px_-30px_rgba(0,0,0,0.6)] overflow-hidden transition-all duration-500 max-md:rounded-xl left-[2%] top-[44%] md:left-[2%] md:top-[36%] md:group-hover:translate-y-2"
              step1img2Class="pointer-events-none w-[55%] rounded-2xl border border-[color:var(--hairline)] shadow-[0_30px_60px_-30px_rgba(0,0,0,0.6)] overflow-hidden transition-all duration-500 left-[44%] top-[30%] md:left-[44%] md:top-[24%] md:group-hover:-translate-y-4"
              step2img1Class="pointer-events-none w-[60%] rounded-2xl border border-[color:var(--hairline)] shadow-[0_30px_60px_-30px_rgba(0,0,0,0.6)] overflow-hidden transition-all duration-500 left-[2%] top-[44%] md:left-[2%] md:top-[36%] md:group-hover:translate-y-2"
              step2img2Class="pointer-events-none w-[52%] rounded-2xl border border-[color:var(--hairline)] shadow-[0_30px_60px_-30px_rgba(0,0,0,0.6)] overflow-hidden transition-all duration-500 left-[46%] top-[30%] md:left-[46%] md:top-[24%] md:group-hover:-translate-y-4"
              step3imgClass="pointer-events-none w-[94%] rounded-2xl border border-[color:var(--hairline)] shadow-[0_40px_80px_-30px_rgba(0,0,0,0.7)] overflow-hidden transition-all duration-500 left-[3%] top-[36%] md:left-[3%] md:top-[30%]"
              step4imgClass="pointer-events-none w-[94%] rounded-2xl border border-[color:var(--hairline)] shadow-[0_40px_80px_-30px_rgba(0,0,0,0.7)] overflow-hidden transition-all duration-500 left-[3%] top-[36%] md:left-[3%] md:top-[30%]"
              bgClass="bg-gradient-to-b from-[var(--surface-1)] to-[var(--surface-2)]"
            />
          </FadeIn>
        </div>
      </div>
    </section>

    <div aria-hidden="true" class="section-glow section-glow-offset-top" />

    <!-- ═══════════════════ TEAM ═══════════════════ -->
    <section class="page-section section-shell">
      <div class="axiom-container">
        <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.3fr)] lg:items-start lg:gap-16">
          <FadeIn motion="editorialMaskReveal" className="space-y-4 lg:sticky lg:top-32">
            <Eyebrow>DIRECT PARTNERSHIP</Eyebrow>
            <SectionDivider className="mt-6" />
            <MotionHeading as="h2" text="Direct partnership. *Direct execution.*" class="section-heading mt-4" />
            <p class="section-copy mt-4 md:text-[17px]">
              Axiom is run by two partners. You work directly with the strategists and engineers executing the scope. No account managers, no layers of overhead, and a direct line to updates.
            </p>
          </FadeIn>

          <div class="grid gap-6 md:grid-cols-2 lg:mt-0">
            {team.map((member, index) => (
              <FadeIn motion="depthCardReveal" delay={Math.min(index * 160, 640)} as="div" className="h-full">
                <Card className="group rounded-2xl border-[color:var(--hairline)] bg-[var(--surface-overlay)] p-8 transition-all duration-300 hover:border-[color:var(--hairline-strong)] hover:bg-[var(--surface-overlay-press)] h-full flex flex-col justify-between">
                  <div class="flex h-full flex-col">
                    <div class="flex items-start gap-5">
                      <!-- Avatar with headshot-based placeholder -->
                      <div class="relative flex h-14 w-14 shrink-0 items-center justify-center rounded-full border border-[color:var(--accent-border)] bg-[color:var(--surface-overlay)] shadow-[inset_0_1px_0_rgba(255,255,255,0.05),0_8px_24px_rgba(0,0,0,0.14)] overflow-hidden">
                        {member.monogram === 'aidan' ? (
                          <img src="/photos/aidan-headshot.jpg" alt="Aidan" class="h-full w-full object-cover" loading="lazy" />
                        ) : (
                          <img src="/photos/riley-headshot.jpg" alt="Riley" class="h-full w-full object-cover" loading="lazy" />
                        )}
                        <div class="pointer-events-none absolute inset-0 rounded-full ring-1 ring-inset ring-white/10" />
                      </div>

                      <div class="min-w-0">
                        <h3 class="text-[1.25rem] font-semibold text-[var(--text-primary)]">{member.name}</h3>
                        <div class="mt-2 flex flex-wrap gap-1.5">
                          {member.roles.map((role) => (
                            <span class="rounded-full bg-[color:var(--surface-overlay-press)] px-2.5 py-0.5 text-[11px] uppercase tracking-widest text-[var(--text-secondary)]">
                              {role}
                            </span>
                          ))}
                        </div>
                      </div>
                    </div>

                    <p class="mt-6 text-[15px] leading-[1.7] text-[var(--text-secondary)]">
                      {member.description}
                    </p>
                  </div>
                </Card>
              </FadeIn>
            ))}
          </div>
        </div>
      </div>
    </section>

    <div aria-hidden="true" class="section-glow section-glow-offset-top" />

    <!-- ═══════════════════ CTA ═══════════════════ -->
    <section class="axiom-cta-panel relative overflow-hidden py-24 md:py-32">
      <!-- Dramatic background -->
      <div aria-hidden="true" class="pointer-events-none absolute inset-0">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_0%,rgb(var(--accent-v2-rgb,var(--accent-current-rgb))/0.12),transparent_50%)]" />
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_100%,rgba(255,255,255,0.02),transparent_40%)]" />
        <div class="absolute inset-0" style="background: linear-gradient(to top, #000, transparent 60%);" />
      </div>

      <!-- Grid pattern -->
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 opacity-[0.025]"
        style="background-image:
          linear-gradient(to right, rgba(212,175,55,0.5) 1px, transparent 1px),
          linear-gradient(to bottom, rgba(212,175,55,0.4) 1px, transparent 1px);
        background-size: 48px 48px;"
      />

      <div class="axiom-container relative">
        <div class="mx-auto max-w-4xl text-center">
          <FadeIn as="div" motion="finalFrameFooter">
            <SectionDivider className="mx-auto mb-6" />

            <!-- Bold headline -->
            <MotionHeading
              as="h2"
              text="Make the site *easier to believe*."
              class="mx-auto text-[clamp(2.5rem,5vw,4.5rem)] font-[600] text-[var(--text-primary)]"
              align="center"
            />

            <p class="mx-auto mt-6 max-w-2xl text-[1.05rem] leading-[1.7] text-[var(--text-secondary)] md:text-[1.1rem]">
              Monthly, ownership, or custom scope. Pricing is public, the launch path is defined, and every build is checked for speed and mobile quality before it ships.
            </p>

            <div class="mt-10 flex flex-col justify-center gap-4 sm:flex-row sm:items-center">
              <Button asChild size="lg" className="w-full sm:w-auto min-h-[3.25rem] px-8 text-[1rem]">
                <a href={CTA_PATHS.startProject}>Start a project</a>
              </Button>
              <Button asChild variant="ghost" size="lg" className="w-full px-0 sm:w-auto">
                <a href="/pricing">See pricing &rarr;</a>
              </Button>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>
  </main>

  <style>
    /* ═══ HERO - Dramatic full-viewport entrance ═══ */
    .axiom-hero {
      isolation: isolate;
      position: relative;
    }

    .axiom-hero::after {
      content: '';
      position: absolute;
      inset: auto 0 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent-border-strong), var(--accent-solid), var(--accent-border-strong), transparent);
      opacity: 0.6;
    }

    /* ═══ CTA panel - Stopping power ═══ */
    .axiom-cta-panel {
      position: relative;
      isolation: isolate;
    }

    .axiom-cta-panel::after {
      content: '';
      position: absolute;
      inset: auto 0 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--hairline-strong), transparent);
      opacity: 0.5;
    }

    /* Motion-safe overrides */
    @media (prefers-reduced-motion: reduce) {
      .axiom-hero,
      .axiom-cta-panel {
        animation: none !important;
      }
    }
  </style>
</SiteLayout>
