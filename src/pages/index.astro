---
import ResponsivePicture from '../components/site/ResponsivePicture.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { HOME_JSON_LD, SITE_TAGLINE } from '../lib/seo';
import { getWorkProofImage } from '../lib/workProofImages';
import { FadeIn } from '../components/ui/FadeIn';
import { HomepageStats } from '../components/site/HomepageStats';
import { Button } from '../components/ui/button';
import { Card } from '../components/ui/card';
import { Eyebrow } from '../components/ui/Eyebrow';

const industries = [
  { label: 'HVAC & CLIMATE', icon: 'hvac' },
  { label: 'LEGAL SERVICES', icon: 'legal' },
  { label: 'LANDSCAPING & OUTDOOR', icon: 'landscaping' },
  { label: 'ROOFING & EXTERIORS', icon: 'roofing' },
  { label: 'LOCAL TRADES', icon: 'trades' },
] as const;

const workCards = [
  {
    eyebrow: 'RESTAURANT & HOSPITALITY',
    title: 'Restaurant reservation site',
    outcome: 'Reservation flow visible on every screen - zero missed bookings on mobile.',
    metricLabel: 'LOAD TARGET',
    metricValue: '<1s',
    image: getWorkProofImage('demonstration-restaurant-reservation-site').source,
    alt: getWorkProofImage('demonstration-restaurant-reservation-site').alt || 'Restaurant reservation site',
    position: getWorkProofImage('demonstration-restaurant-reservation-site').position || 'center 24%',
  },
  {
    eyebrow: 'LANDSCAPING & OUTDOOR SERVICES',
    title: 'Landscaping authority site',
    outcome: 'Portfolio proof leads the page - quote requests stay one tap away.',
    metricLabel: 'MOBILE TARGET',
    metricValue: '98+',
    image: getWorkProofImage('concept-landscaping-authority-site').source,
    alt: getWorkProofImage('concept-landscaping-authority-site').alt || 'Landscaping authority site',
    position: getWorkProofImage('concept-landscaping-authority-site').position || 'center 52%',
  },
  {
    eyebrow: 'ROOFING & EXTERIORS',
    title: 'Roofing conversion site',
    outcome: 'Emergency inspection paths stay separate from planned estimates.',
    metricLabel: 'CALL PATH',
    metricValue: '1 TAP',
    image: getWorkProofImage('concept-roofing-conversion-site').source,
    alt: getWorkProofImage('concept-roofing-conversion-site').alt || 'Roofing conversion site',
    position: getWorkProofImage('concept-roofing-conversion-site').position || 'center 36%',
  },
] as const;

const principles = [
  {
    number: '01',
    title: 'Clarity over everything.',
    description: "If the offer isn't readable in three seconds, the site is already losing.",
  },
  {
    number: '02',
    title: 'Proof before polish.',
    description: 'Real work, real reviews, real results - placed where they convert.',
  },
  {
    number: '03',
    title: 'Performance is non-negotiable.',
    description: 'Sub-second loads or we fix it free. That is the floor.',
  },
  {
    number: '04',
    title: 'Full ownership, always.',
    description: 'You get the code. No subscriptions, no hostage hosting.',
  },
] as const;

const processStages = [
  {
    day: 'Day 1',
    title: 'Review',
    description: 'We audit the current site, the offer, and the gaps that are costing trust.',
  },
  {
    day: 'Day 3',
    title: 'Scope',
    description: 'We lock the structure, the message, and the pages that actually matter.',
  },
  {
    day: 'Day 7',
    title: 'Build',
    description: 'The design system, layout, and content come together in production.',
  },
  {
    day: 'Day 14',
    title: 'Launch',
    description: 'We ship the site, verify the handoff, and make ownership complete.',
  },
] as const;

const services = [
  {
    label: 'Conversion Site',
    description:
      'Designed to turn visitors into booked jobs. Clear offer, friction-free contact paths, and trust signals placed where they convert.',
    href: '/work',
  },
  {
    label: 'Authority Site',
    description:
      'Establishes credibility in competitive markets. Portfolio, reviews, and credentials structured to hold the room.',
    href: '/work',
  },
  {
    label: 'Rebuild & Migrate',
    description:
      'Your current site stripped and rebuilt correctly - same domain, zero downtime, measurably faster on day one.',
    href: '/process',
  },
] as const;

---

<SiteLayout
  title="Websites that do the selling for you"
  description={SITE_TAGLINE}
  canonicalPath="/"
  schema={HOME_JSON_LD}
>
  <main id="main-content" tabindex="-1" class="-mt-28 md:-mt-32">
    <section class="relative overflow-hidden pb-20 pt-32 md:pb-28 md:pt-36">
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0"
        style="
          background:
            radial-gradient(circle at 82% 12%, var(--accent-surface) 0%, var(--accent-surface-strong) 14%, transparent 36%),
            linear-gradient(180deg, var(--surface-panel-strong) 0%, transparent 18%);
        "
      />
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 opacity-[0.03]"
        style="
          background-image:
            radial-gradient(circle at 20% 20%, var(--hero-noise-dot) 0.6px, transparent 0.6px),
            radial-gradient(circle at 80% 70%, var(--hero-noise-dot-alt) 0.6px, transparent 0.6px);
          background-size: 4px 4px, 5px 5px;
          background-position: 0 0, 1px 1px;
          mix-blend-mode: overlay;
        "
      />
      <div class="axiom-container relative">
        <FadeIn client:load className="max-w-4xl">
          <Eyebrow className="text-[11px] text-[var(--text-secondary)]">WEB DESIGN AGENCY</Eyebrow>
          <h1 class="mt-6 max-w-4xl text-left">
            Websites that do the selling for you.
          </h1>
          <p class="section-copy mt-6">
            Axiom builds fast, clear, conversion-engineered websites for businesses that are done settling for mediocre
            sites. Every build is owned outright - no subscriptions, no lock-ins.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
            <Button asChild size="lg" className="w-full sm:w-auto">
              <a href="/start">Start a project</a>
            </Button>
            <Button asChild variant="ghost" size="lg" className="w-full px-0 sm:w-auto">
              <a href="/work">See the work</a>
            </Button>
          </div>

          <div class="mt-8 flex flex-wrap items-center gap-3 text-[12px] font-medium uppercase tracking-[0.14em] text-[var(--text-secondary)]">
            <span>14-DAY BUILD</span>
            <span aria-hidden="true" class="h-4 w-px bg-[color:var(--hairline)]" />
            <span>FULL CODE OWNERSHIP</span>
            <span aria-hidden="true" class="h-4 w-px bg-[color:var(--hairline)]" />
            <span>BUILT TO CONVERT</span>
          </div>
        </FadeIn>
      </div>
    </section>

    <section class="border-y border-[color:var(--hairline)] bg-[color:var(--surface-panel)] py-6 md:py-8">
      <div class="axiom-container space-y-5">
        <p class="text-center font-mono text-[11px] uppercase tracking-[0.14em] text-[var(--text-secondary)]">
          INDUSTRIES WE BUILD FOR
        </p>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-5">
          {industries.map((industry) => (
            <div class="flex flex-col items-center gap-3 text-center">
              {industry.icon === 'hvac' ? (
                <svg
                  viewBox="0 0 24 24"
                  class="h-6 w-6 text-[color:var(--accent-solid)] opacity-40"
                  fill="none"
                  aria-hidden="true"
                >
                  <path d="M12 3v18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                  <path d="M8.5 6.5h7M8.5 17.5h7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                  <path d="M12 7.5a3.5 3.5 0 0 1 0 7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                  <path d="M4.5 12h3M16.5 12h3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                </svg>
              ) : industry.icon === 'legal' ? (
                <svg
                  viewBox="0 0 24 24"
                  class="h-6 w-6 text-[color:var(--accent-solid)] opacity-40"
                  fill="none"
                  aria-hidden="true"
                >
                  <path d="M12 4.5V20" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                  <path d="M6.5 8.5h11" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                  <path d="m8 8.5 2.2 4.1H5.8L8 8.5Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
                  <path d="m16 8.5 2.2 4.1h-4.4L16 8.5Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
                  <path d="M7 19.5h10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                </svg>
              ) : industry.icon === 'landscaping' ? (
                <svg
                  viewBox="0 0 24 24"
                  class="h-6 w-6 text-[color:var(--accent-solid)] opacity-40"
                  fill="none"
                  aria-hidden="true"
                >
                  <path d="M12 20V9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                  <path d="M12 9c-2.2 0-4-1.8-4-4 2.2 0 4 1.8 4 4Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
                  <path d="M12 11c2.5 0 4.5-2 4.5-4.5C14 6.5 12 8.5 12 11Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
                  <path d="M7 20h10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                </svg>
              ) : industry.icon === 'roofing' ? (
                <svg
                  viewBox="0 0 24 24"
                  class="h-6 w-6 text-[color:var(--accent-solid)] opacity-40"
                  fill="none"
                  aria-hidden="true"
                >
                  <path d="M4.5 12 12 5.5 19.5 12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                  <path d="M6.5 11.5V19h11v-7.5" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
                  <path d="M10 19v-4h4v4" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
                </svg>
              ) : (
                <svg
                  viewBox="0 0 24 24"
                  class="h-6 w-6 text-[color:var(--accent-solid)] opacity-40"
                  fill="none"
                  aria-hidden="true"
                >
                  <path d="M6 12h4l1.2-2.5 2.1 5L14.5 12H18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                  <path d="M5.5 7.5h13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                  <path d="M5.5 16.5h13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                </svg>
              )}
              <span class="max-w-[14ch] text-[11px] font-medium uppercase tracking-[0.14em] text-[var(--text-muted)]">
                {industry.label}
              </span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <FadeIn client:load className="max-w-3xl">
          <Eyebrow>SELECTED WORK</Eyebrow>
          <h2 class="section-heading mt-4">
            Built for businesses that measure results.
          </h2>
        </FadeIn>

        <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {workCards.map((card, index) => (
            <FadeIn client:load delay={Math.min(index * 100, 400)}>
              <Card
                className="group overflow-hidden p-0 transition-[transform,background-color,border-color,box-shadow] duration-200 ease-[cubic-bezier(0.4,0,0.2,1)] hover:-translate-y-1 hover:bg-[var(--surface-2)] hover:border-[color:var(--hairline-strong)]"
              >
                <figure class="relative overflow-hidden border-b border-[color:var(--hairline)] bg-white/5">
                  <ResponsivePicture
                    source={card.image}
                    alt={card.alt}
                    sizes="(min-width: 1280px) 32vw, (min-width: 768px) 45vw, 100vw"
                    class="aspect-[4/3] h-full w-full object-cover transition-transform duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] group-hover:scale-[1.03]"
                    loading="lazy"
                    fetchpriority="low"
                    objectPosition={card.position}
                  />
                  <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_top,var(--overlay-black-soft),transparent)]" />
                </figure>

                <div class="flex h-full flex-col p-6 sm:p-7">
                  <Eyebrow>{card.eyebrow}</Eyebrow>
                  <h3 class="mt-4 text-[22px] font-semibold tracking-[-0.01em] text-[var(--text-primary)]">
                    {card.title}
                  </h3>
                  <p class="section-copy mt-3">
                    {card.outcome}
                  </p>

                  <div class="mt-auto flex items-center justify-between gap-4 border-t border-[color:var(--hairline)] pt-5">
                    <span class="axiom-metric text-[var(--text-muted)]">{card.metricLabel}</span>
                    <span class="text-[15px] font-semibold tracking-[0.08em] text-[var(--text-primary)]">
                      {card.metricValue}
                    </span>
                  </div>
                </div>
              </Card>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <FadeIn client:load className="max-w-3xl">
          <Eyebrow>WHAT WE BUILD</Eyebrow>
          <h2 class="section-heading mt-4">
            Three formats. One outcome.
          </h2>
        </FadeIn>

        <div class="mt-10 grid gap-5 md:grid-cols-3">
          {services.map((service, index) => (
            <FadeIn client:load delay={Math.min(index * 100, 400)} as="div">
              <a
                href={service.href}
                class="group flex h-full flex-col gap-4 rounded-[var(--radius-card)] border border-[color:var(--hairline)] bg-[color:var(--surface-1)] p-6 transition-[border-color,background-color] duration-200 hover:border-[color:var(--hairline-strong)] hover:bg-[var(--surface-2)] sm:p-7"
              >
                <p class="text-[19px] font-semibold tracking-[-0.01em] text-[var(--text-primary)]">
                  {service.label}
                </p>
                <p class="section-copy">
                  {service.description}
                </p>
                <span class="mt-auto font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--accent-solid)] transition-opacity duration-200 group-hover:opacity-80">
                  See examples &rarr;
                </span>
              </a>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <FadeIn client:load className="max-w-3xl">
          <Eyebrow>WHY AXIOM</Eyebrow>
          <h2 class="section-heading mt-4">
            The difference is what we refuse to ship.
          </h2>
        </FadeIn>

        <div class="mt-10 grid gap-5 md:grid-cols-2">
          {principles.map((principle, index) => (
            <FadeIn client:load delay={Math.min(index * 100, 400)} as="div">
              <Card className="h-full p-0">
                <div class="flex h-full flex-col p-6 sm:p-7">
                  <Eyebrow className="text-[var(--text-muted)]">{principle.number}</Eyebrow>
                  <h3 class="mt-4 text-[22px] font-semibold tracking-[-0.01em] text-[var(--text-primary)]">
                    {principle.title}
                  </h3>
                  <p class="section-copy mt-3">
                    {principle.description}
                  </p>
                </div>
              </Card>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <FadeIn client:load className="max-w-3xl">
          <Eyebrow>HOW WE BUILD</Eyebrow>
          <h2 class="section-heading mt-4">
            Four stages. Fourteen days. No drift.
          </h2>
        </FadeIn>

        <div class="mt-10 flex flex-col gap-4 lg:flex-row lg:flex-nowrap">
          {processStages.map((stage, index) => (
            <FadeIn client:load delay={Math.min(index * 100, 400)} as="div">
              <Card className="flex-1 min-w-[220px] p-0">
                <div class="flex h-full flex-col gap-4 p-6 sm:p-7">
                  <span class="font-mono text-[12px] uppercase tracking-[0.08em] text-[var(--accent-solid)]">
                    {stage.day}
                  </span>
                  <div>
                    <p class="text-[18px] font-semibold tracking-[-0.01em] text-[var(--text-primary)]">
                      {stage.title}
                    </p>
                    <p class="section-copy mt-2">
                      {stage.description}
                    </p>
                  </div>
                </div>
              </Card>
            </FadeIn>
          ))}
        </div>

        <div class="mt-6">
          <Button asChild variant="ghost" className="px-0">
            <a href="/process">See the full process &rarr;</a>
          </Button>
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <FadeIn client:load as="div">
          <Card className="mx-auto max-w-5xl p-0 text-center">
            <div class="px-6 py-8 sm:px-8 sm:py-10 md:px-10 md:py-12">
              <Eyebrow className="justify-center">THE GUARANTEE</Eyebrow>
              <h2 class="section-heading mx-auto mt-4">
                If your site loads in over one second, we fix it free.
              </h2>
              <p class="section-copy mx-auto mt-4">
                No asterisks. That is the floor we build to.
              </p>
            </div>
          </Card>
        </FadeIn>
      </div>
    </section>

    <HomepageStats client:load />

    <section class="border-t border-[color:var(--hairline)] bg-[var(--surface-2)]">
      <div class="axiom-container py-12 md:py-16">
        <div class="grid gap-8 lg:grid-cols-[minmax(0,1.2fr)_minmax(18rem,0.75fr)] lg:items-end">
          <FadeIn client:load as="div" className="max-w-3xl">
            <h2 class="section-heading text-[clamp(32px,4vw,52px)] font-[600] text-[var(--text-primary)]">
              If the site isn't earning trust, it's costing you work.
            </h2>
            <p class="section-copy mt-4">
                Send us your current site. We&apos;ll tell you exactly what&apos;s losing you leads &mdash; in one business day.
            </p>
          </FadeIn>

          <FadeIn client:load delay={100} as="div">
            <div class="flex flex-col gap-4 lg:items-end">
              <Button asChild size="lg" className="w-full sm:w-auto">
                <a href="/start">Start a project</a>
              </Button>
              <p class="axiom-metric text-[var(--text-muted)]">
                Review &rarr; Scope &rarr; Build &rarr; Launch
              </p>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
