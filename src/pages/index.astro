---
import ResponsivePicture from '../components/site/ResponsivePicture.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { CTA_PATHS } from '../lib/cta';
import { HOME_JSON_LD, WEBSITE_SCHEMA, SEO_ROUTES, breadcrumbSchema } from '../lib/seo';
import { getWorkProofImage } from '../lib/workProofImages';
import { FadeIn } from '../components/ui/FadeIn';
import { Button } from '../components/ui/button';
import { Card } from '../components/ui/card';
import { Eyebrow } from '../components/ui/Eyebrow';
import DrawIcon from '../components/ui/DrawIcon.astro';
import { MotionHeading } from '../components/motion/MotionHeading';
import { MotionQuote } from '../components/motion/MotionQuote';
import { ProofBar } from '../components/motion/ProofBar';
import { SectionDivider } from '../components/motion/SectionDivider';
import { Timeline } from '../components/motion/Timeline';

const browserBars = [
  { width: '92%', delay: 0 },
  { width: '78%', delay: 0.4 },
  { width: '64%', delay: 0.8 },
] as const;

const workCards = [
  {
    eyebrow: 'SALON & BEAUTY',
    title: 'Nails Studio Demo',
    outcome: 'Clean booking flow paired with modern trust cues and a polished luxury feel.',
    metricLabel: 'LOAD TARGET',
    metricValue: '<1s',
    image: getWorkProofImage('concept-salon-demo').source,
    alt: getWorkProofImage('concept-salon-demo').alt || 'Nails Studio Demo',
    position: getWorkProofImage('concept-salon-demo').position || 'center 40%',
  },
  {
    eyebrow: 'PERSONAL SERVICES & GROOMING',
    title: 'Blackline Barber Co.',
    outcome: 'Sharp branding, fast booking, and a cleaner first impression.',
    metricLabel: 'BOOKING PATH',
    metricValue: '1 TAP',
    image: getWorkProofImage('concept-barber-demo').source,
    alt: getWorkProofImage('concept-barber-demo').alt || 'Blackline Barber Co.',
    position: getWorkProofImage('concept-barber-demo').position || 'center 40%',
  },
  {
    eyebrow: 'HEALTHCARE & MEDICAL',
    title: 'Aurelia Dental Studio',
    outcome: 'Calm, trust-focused presentation paired with a polished booking experience.',
    metricLabel: 'MOBILE TARGET',
    metricValue: '98+',
    image: getWorkProofImage('concept-dental-demo').source,
    alt: getWorkProofImage('concept-dental-demo').alt || 'Aurelia Dental Studio',
    position: getWorkProofImage('concept-dental-demo').position || 'center 40%',
  },
] as const;

const principles = [
  {
    number: '01',
    title: 'No unclear offer.',
    description: "If a visitor can't tell what you do in three seconds, we haven't finished.",
    icon: 'eye',
  },
  {
    number: '02',
    title: 'No buried proof.',
    description: 'Real work, real reviews, and real results belong where buyers actually look.',
    icon: 'shield-check',
  },
  {
    number: '03',
    title: 'No slow first load.',
    description: 'Sub-second loads are the floor. If it drags, we fix it.',
    icon: 'bolt',
  },
  {
    number: '04',
    title: 'No dead-end handoff.',
    description: "Monthly clients keep support. Ownership clients get a clean exit. Either way, the site doesn't rot.",
    icon: 'key',
  },
] as const;

const processStages = [
  {
    day: 'Week 1',
    title: 'Review',
    description: 'We audit the current site, the offer, and the gaps that are costing trust.',
    icon: 'search',
  },
  {
    day: 'Week 1',
    title: 'Scope',
    description: 'We lock the structure, the message, and the pages that actually matter.',
    icon: 'document',
  },
  {
    day: 'Weeks 2-3',
    title: 'Build',
    description: 'The design system, layout, and content come together in production.',
    icon: 'code',
  },
  {
    day: 'Weeks 3-4',
    title: 'Launch',
    description: 'We ship the site, verify the handoff, and make ownership complete.',
    icon: 'arrow-up',
  },
] as const;

const timelineSteps = processStages.map((stage) => ({
  kicker: stage.day,
  title: stage.title,
  description: stage.description,
}));

const services = [
  {
    label: 'Monthly growth site',
    description:
      'Low upfront cost. Ongoing edits and support. Best when you want the site to keep getting better after launch.',
    href: '/work',
    icon: 'target',
  },
  {
    label: 'Ownership build',
    description:
      'One payment. Full code handoff at launch. Best when you want to own the site outright from day one.',
    href: '/work',
    icon: 'crown',
  },
  {
    label: 'Rebuild & Migrate',
    description:
      'Replace a slow or outdated site without downtime. We migrate, relaunch, and make sure nothing breaks.',
    href: '/process',
    icon: 'refresh',
  },
] as const;

---

<SiteLayout
  title={SEO_ROUTES.home.title}
  description={SEO_ROUTES.home.description}
  canonicalPath="/"
  ogImageAlt="Axiom Infrastructure homepage – custom web development in Kitchener-Waterloo."
  schema={[HOME_JSON_LD, WEBSITE_SCHEMA]}
>
  <main id="main-content" tabindex="-1" class="-mt-28 md:-mt-32">
    <section class="hero-shell relative overflow-hidden pb-20 pt-32 md:pb-28 md:pt-40">
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 hero-aurora"
        style="
          background:
            radial-gradient(circle at 82% 12%, var(--accent-surface) 0%, var(--accent-surface-strong) 14%, transparent 36%),
            linear-gradient(180deg, var(--surface-panel-strong) 0%, transparent 18%);
        "
      />
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 hero-noise opacity-[0.04]"
        style="
          background-image:
            radial-gradient(circle at 20% 20%, var(--hero-noise-dot) 0.6px, transparent 0.6px),
            radial-gradient(circle at 80% 70%, var(--hero-noise-dot-alt) 0.6px, transparent 0.6px);
          background-size: 4px 4px, 5px 5px;
          background-position: 0 0, 1px 1px;
          mix-blend-mode: overlay;
        "
      />
      <div aria-hidden="true" class="hero-grid pointer-events-none absolute inset-0" />
      <div class="axiom-container relative">
        <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(22rem,30rem)] lg:items-center">
          <div class="max-w-3xl">
            <FadeIn delay={0} motion="eyebrow">
              <Eyebrow>DIGITAL INFRASTRUCTURE</Eyebrow>
            </FadeIn>
            <FadeIn delay={180} motion="sceneOpen">
              <MotionHeading as="h1" text="Websites that turn visitors into booked calls." className="mt-6 max-w-4xl text-left" />
            </FadeIn>
            <FadeIn delay={520} motion="editorialMaskReveal">
              <p class="section-copy mt-6 max-w-2xl md:text-[1.1rem]">
              Fast websites. Clear offers. More booked jobs.
              We build in 2-4 weeks, start at $0 down, and keep supporting the site after launch. It keeps earning long
              after it goes live.
              </p>
            </FadeIn>

            <FadeIn delay={780} motion="sceneOpen">
              <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
                <Button asChild size="lg" className="w-full sm:w-auto">
                  <a href={CTA_PATHS.startProject}>Start a project</a>
                </Button>
                <Button asChild variant="ghost" size="lg" className="w-full px-0 sm:w-auto">
                  <a href="/work">See real builds</a>
                </Button>
              </div>

              <p class="mt-3 text-[13px] uppercase tracking-[0.08em] text-[var(--text-muted)]">
                MONTHLY FROM $150. ONE-TIME OWNERSHIP FROM $3,500. NO ASTERISKS.
              </p>
            </FadeIn>
          </div>

          <FadeIn delay={980} as="div" motion="depthCardReveal" className="hidden justify-self-end lg:block" aria-hidden="true">
            <div class="hero-browser-shell hero-visual">
              <svg viewBox="0 0 520 340" class="block h-auto w-full" fill="none" role="presentation">
                <rect x="0.75" y="0.75" width="518.5" height="338.5" rx="24" class="hero-browser-frame" />
                <rect x="0.75" y="0.75" width="518.5" height="52" rx="24" class="hero-browser-chrome" />
                <circle cx="36" cy="26" r="5.5" class="hero-browser-dot" />
                <circle cx="54" cy="26" r="5.5" class="hero-browser-dot" />
                <circle cx="72" cy="26" r="5.5" class="hero-browser-dot" />

                {browserBars.map((bar, index) => (
                  <rect
                    key={index}
                    x="42"
                    y={86 + index * 46}
                    width={bar.width}
                    height="16"
                    rx="8"
                    class="hero-browser-bar"
                    style={`--browser-delay: ${bar.delay}s;`}
                  />
                ))}
                <rect x="42" y="250" width="182" height="34" rx="17" class="hero-browser-chip" />
                <rect x="248" y="250" width="108" height="34" rx="17" class="hero-browser-chip hero-browser-chip-soft" />
                <path d="M405 116C431 142 444 170 444 200C444 230 428 255 396 276" class="hero-browser-arc" />
                <path d="M386 104C407 132 416 161 413 191C410 222 392 246 358 263" class="hero-browser-arc hero-browser-arc-muted" />
              </svg>
              <div class="hero-status-panel">
                <span>CORE WEB VITALS</span>
                <strong>Verified before launch</strong>
              </div>
            </div>
          </FadeIn>

          <div class="flex justify-center lg:col-span-2">
            <MotionQuote
              className="text-center"
              phrases={['2-4 weeks.', 'Under one second.', 'Ongoing support included.']}
            />
          </div>
        </div>
      </div>
    </section>

    <ProofBar />

    <section class="page-section section-shell">
      <div class="axiom-container">
        <FadeIn motion="editorialMaskReveal" className="max-w-3xl">
          <Eyebrow>SELECTED WORK</Eyebrow>
          <SectionDivider className="mt-6" />
          <MotionHeading as="h2" text="Real builds. Real outcomes." className="section-heading mt-4" />
        </FadeIn>

        <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {workCards.map((card, index) => (
            <FadeIn motion="depthCardReveal" delay={Math.min(index * 150, 600)}>
              <Card
                className="group overflow-hidden p-0 transition-[transform,background-color,border-color,box-shadow] duration-200 ease-[var(--ease-premium)] hover:bg-[var(--surface-2)] hover:border-[color:var(--hairline-strong)]"
              >
                <figure class="relative overflow-hidden border-b border-[color:var(--hairline)] bg-white/5">
                  <ResponsivePicture
                    source={card.image}
                    alt={card.alt}
                    sizes="(min-width: 1280px) 32vw, (min-width: 768px) 45vw, 100vw"
                    class="media-zoom aspect-[4/3] h-full w-full object-cover"
                    loading="lazy"
                    fetchpriority="low"
                    objectPosition={card.position}
                  />
                  <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_top,var(--overlay-black-soft),transparent)]" />
                </figure>

                <div class="flex h-full flex-col p-6 sm:p-7">
                  <Eyebrow>{card.eyebrow}</Eyebrow>
                  <h3 class="mt-4 text-[22px] font-semibold tracking-[-0.01em] text-[var(--text-primary)]">
                    {card.title}
                  </h3>
                  <p class="section-copy mt-3">
                    {card.outcome}
                  </p>

                  <div class="mt-auto flex items-center justify-between gap-4 border-t border-[color:var(--hairline)] pt-5">
                    <span class="axiom-metric text-[var(--text-muted)]">{card.metricLabel}</span>
                    <span class="text-[15px] font-semibold tracking-[0.08em] text-[var(--text-primary)]">
                      {card.metricValue}
                    </span>
                  </div>
                </div>
              </Card>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section section-shell">
      <div class="axiom-container">
        <FadeIn motion="editorialMaskReveal" className="max-w-3xl">
          <Eyebrow>WHAT WE BUILD</Eyebrow>
          <SectionDivider className="mt-6" />
          <MotionHeading as="h2" text="Three formats. One outcome." className="section-heading mt-4" />
        </FadeIn>

        <div class="mt-10 grid gap-5 md:grid-cols-3">
          {services.map((service, index) => (
            <FadeIn motion="depthCardReveal" delay={Math.min(index * 120, 480)} as="div">
              <a
                href={service.href}
                class="premium-card group flex h-full flex-col gap-4 rounded-[var(--radius-card)] border border-[color:var(--hairline)] bg-[rgba(255,255,255,0.02)] p-6 transition-[border-color,background-color,box-shadow,transform] duration-200 hover:border-[color:var(--accent-border)] hover:bg-[rgba(255,255,255,0.03)] hover:shadow-[0_20px_48px_rgba(0,0,0,0.28),0_0_0_1px_rgb(var(--accent-v2-rgb,var(--accent-current-rgb))_/_0.14)] sm:p-7"
              >
                <DrawIcon name={service.icon} className="transition-transform duration-300 group-hover:rotate-90 group-hover:text-[var(--accent-solid)]" />
                  <p class="text-[clamp(1.25rem,1.5vw,1.5rem)] font-medium tracking-[-0.02em] text-[var(--text-primary)]">
                    {service.label}
                  </p>
                <p class="section-copy">
                  {service.description}
                </p>
                <span class="mt-auto font-mono text-[12px] uppercase tracking-[0.12em] text-[var(--accent-solid)] transition-opacity duration-200 group-hover:opacity-80">
                  See real builds
                </span>
              </a>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section section-shell">
      <div class="axiom-container">
        <FadeIn motion="editorialMaskReveal" className="max-w-3xl">
          <Eyebrow>WHY AXIOM</Eyebrow>
          <SectionDivider className="mt-6" />
          <MotionHeading as="h2" text="What we won't ship." className="section-heading mt-4" />
        </FadeIn>

        <div class="mt-10 grid gap-5 md:grid-cols-2">
          {principles.map((principle, index) => (
            <FadeIn motion="timelineSequence" delay={Math.min(index * 140, 560)} as="div">
              <Card className="h-full p-0">
                <div class="flex h-full flex-col p-6 sm:p-7">
                  <div class="mb-5 flex items-center justify-between gap-4">
                    <DrawIcon name={principle.icon} />
                    <p class="font-mono text-[0.75rem] font-medium uppercase tracking-[0.08em] text-[var(--accent-solid)]">{principle.number}</p>
                  </div>
                  <h3 class="mt-4 text-[clamp(1.25rem,1.5vw,1.5rem)] font-medium tracking-[-0.02em] text-[var(--text-primary)]">
                    {principle.title}
                  </h3>
                  <p class="section-copy mt-3">
                    {principle.description}
                  </p>
                </div>
              </Card>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section section-shell">
      <div class="axiom-container">
        <FadeIn motion="editorialMaskReveal" className="max-w-3xl">
          <Eyebrow>HOW WE BUILD</Eyebrow>
          <SectionDivider className="mt-6" />
          <MotionHeading as="h2" text="Four stages. 2-4 weeks. No drift." className="section-heading mt-4" />
        </FadeIn>

        <div class="mt-10">
          <Timeline steps={timelineSteps} />
        </div>

        <div class="mt-6">
          <Button asChild variant="ghost" className="px-0">
            <a href="/process">See the full process</a>
          </Button>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-20">
      <div class="axiom-container">
        <FadeIn as="div" motion="finalFrameFooter">
          <Card className="mx-auto max-w-5xl overflow-hidden p-0 text-center">
            <div class="relative px-6 py-8 sm:px-8 sm:py-10 md:px-10 md:py-12">
              <div aria-hidden="true" class="absolute inset-0 bg-[radial-gradient(circle_at_50%_30%,rgb(var(--accent-v2-rgb,var(--accent-current-rgb))_/_0.12),transparent_45%)] blur-[100px]" />
              <div class="relative">
                <Eyebrow className="justify-center">THE GUARANTEE</Eyebrow>
                <SectionDivider className="mx-auto mt-6" />
                <MotionHeading as="h2" text="If your site loads in over one second, we fix it free." className="section-heading mx-auto mt-4" />
          <p class="section-copy mx-auto mt-4">
                No asterisks. Monthly-first support stays with you after launch.
              </p>
              </div>
            </div>
          </Card>
        </FadeIn>
      </div>
    </section>

    <section class="final-cta-panel">
      <div class="axiom-container py-12 md:py-16">
        <div class="grid gap-8 lg:grid-cols-[minmax(0,1.2fr)_minmax(18rem,0.75fr)] lg:items-end">
          <FadeIn as="div" motion="finalFrameFooter" className="max-w-3xl">
            <SectionDivider className="mb-6" />
            <MotionHeading as="h2" text="A slow site is a silent bill. We fix that." className="section-heading text-[clamp(32px,4vw,52px)] font-[600] text-[var(--text-primary)]" />
            <p class="section-copy mt-4">
              Start monthly at $0 down, or buy it outright from $3,500.
              Either way, you get a site that actually books work.
            </p>
          </FadeIn>

          <FadeIn delay={240} motion="finalFrameFooter" as="div">
            <div class="flex flex-col gap-4 lg:items-end">
              <Button asChild size="lg" className="w-full sm:w-auto">
                <a href={CTA_PATHS.startProject}>Start a project</a>
              </Button>
              <p class="axiom-metric text-[var(--text-muted)]">
                Lower upfront cost &rarr; Ongoing support &rarr; Ownership optional
              </p>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>
  </main>

  <style>
    .hero-shell {
      isolation: isolate;
    }

    .hero-shell::after {
      content: '';
      position: absolute;
      inset: auto 0 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--hairline-strong), transparent);
      opacity: 0.8;
    }

    .hero-aurora {
      animation: hero-aurora-drift 30s ease-in-out infinite;
      transform-origin: center;
      will-change: transform, opacity;
    }

    .hero-grid {
      background-image:
        linear-gradient(to right, rgba(255, 255, 255, 0.04) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(255, 255, 255, 0.032) 1px, transparent 1px);
      background-size: 92px 92px;
      opacity: 0.18;
      mask-image: radial-gradient(circle at 78% 24%, black, transparent 62%);
    }

    .hero-browser-shell {
      position: relative;
      width: clamp(22rem, 32vw, 30rem);
      opacity: 0.78;
      transform: translate3d(0.75rem, -0.5rem, 0) rotate(1.6deg);
      transform-origin: center;
      pointer-events: none;
      will-change: transform, opacity;
    }

    .hero-visual {
      animation: hero-visual-float 8s var(--ease-premium-soft) infinite;
    }

    .hero-browser-frame {
      fill: rgba(255, 255, 255, 0.026);
      stroke: rgba(255, 255, 255, 0.13);
      stroke-width: 1;
    }

    .hero-browser-chrome {
      fill: rgba(255, 255, 255, 0.035);
    }

    .hero-browser-dot {
      fill: rgba(255, 255, 255, 0.22);
    }

    .hero-browser-bar {
      fill: var(--accent-solid);
      opacity: 0;
      transform-box: fill-box;
      transform-origin: left center;
      animation:
        browser-bar-reveal 1.45s var(--ease-cinematic) var(--browser-delay, 0s) forwards,
        browser-bar-pulse 8s ease-in-out calc(1.2s + var(--browser-delay, 0s)) infinite;
      will-change: opacity, transform;
    }

    .hero-browser-chip {
      fill: rgba(255, 255, 255, 0.075);
      stroke: rgba(255, 255, 255, 0.08);
      stroke-width: 1;
    }

    .hero-browser-chip-soft {
      fill: rgb(var(--accent-v2-rgb, var(--accent-current-rgb)) / 0.14);
      stroke: rgb(var(--accent-v2-rgb, var(--accent-current-rgb)) / 0.22);
    }

    .hero-browser-arc {
      stroke: rgb(var(--accent-v2-rgb, var(--accent-current-rgb)) / 0.5);
      stroke-width: 1.5;
      stroke-linecap: round;
      stroke-dasharray: 220;
      stroke-dashoffset: 220;
      animation: hero-arc-draw 1.45s var(--ease-cinematic) 0.9s forwards;
    }

    .hero-browser-arc-muted {
      stroke: rgba(255,255,255,0.22);
      animation-delay: 1.08s;
    }

    .hero-status-panel {
      position: absolute;
      right: -0.85rem;
      bottom: 2.25rem;
      width: min(16rem, 62%);
      border: 1px solid var(--hairline-strong);
      border-radius: 16px;
      background: rgba(0, 0, 0, 0.72);
      box-shadow: var(--shadow-card-elevated);
      padding: 1rem 1.05rem;
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      animation: hero-panel-in 0.96s var(--ease-cinematic) 1.08s both;
    }

    .hero-status-panel span,
    .hero-status-panel strong {
      display: block;
    }

    .hero-status-panel span {
      font-family: var(--font-mono);
      font-size: 0.67rem;
      line-height: 1.2;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent-solid);
    }

    .hero-status-panel strong {
      margin-top: 0.35rem;
      color: var(--text-primary);
      font-size: 0.95rem;
      line-height: 1.35;
      font-weight: 600;
    }

    @keyframes browser-bar-reveal {
      0% {
        opacity: 0;
        transform: translateY(5px);
      }

      100% {
        opacity: 0.6;
        transform: translateY(0);
      }
    }

    @keyframes browser-bar-pulse {
      0%,
      18%,
      100% {
        opacity: 0.6;
        transform: translateY(0);
      }

      48% {
        opacity: 0.42;
        transform: translateY(0);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .hero-aurora {
        animation: none !important;
      }

      .hero-browser-shell {
        opacity: 0.45;
        transform: translate3d(0.75rem, -0.5rem, 0) rotate(1.6deg);
      }

      .hero-browser-bar {
        animation: none !important;
        opacity: 0.55;
        transform: none;
      }

      .hero-visual,
      .hero-browser-arc,
      .hero-status-panel {
        animation: none !important;
      }

      .hero-browser-arc {
        stroke-dashoffset: 0;
      }
    }

    @keyframes hero-aurora-drift {
      0%,
      100% {
        transform: translate3d(-1.5%, -0.5%, 0);
      }

      50% {
        transform: translate3d(1.5%, 0.75%, 0);
      }
    }

    @keyframes hero-visual-float {
      0%,
      100% {
        transform: translate3d(0.75rem, -0.5rem, 0) rotate(1.6deg);
      }

      50% {
        transform: translate3d(0.25rem, -1.15rem, 0) rotate(1deg);
      }
    }

    @keyframes hero-arc-draw {
      to {
        stroke-dashoffset: 0;
      }
    }

    @keyframes hero-panel-in {
      0% {
        opacity: 0;
        transform: translate3d(0, 12px, 0);
      }

      100% {
        opacity: 1;
        transform: translate3d(0, 0, 0);
      }
    }
  </style>
</SiteLayout>

