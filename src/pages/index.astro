---
import ResponsivePicture from '../components/site/ResponsivePicture.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { CTA_PATHS, createStartProjectHref } from '../lib/cta';
import { HOME_JSON_LD, WEBSITE_SCHEMA, SEO_ROUTES, breadcrumbSchema } from '../lib/seo';
import { getWorkProofImage } from '../lib/workProofImages';
import { FadeIn } from '../components/ui/FadeIn';
import { Button } from '../components/ui/button';
import { Card } from '../components/ui/card';
import { Eyebrow } from '../components/ui/Eyebrow';
import DrawIcon from '../components/ui/DrawIcon.astro';
import { MotionHeading } from '../components/motion/MotionHeading';
import { ProofBar } from '../components/motion/ProofBar';
import { SectionDivider } from '../components/motion/SectionDivider';
import { Timeline } from '../components/motion/Timeline';

const browserBars = [
  { width: '92%', delay: 0 },
  { width: '78%', delay: 0.4 },
  { width: '64%', delay: 0.8 },
] as const;

const workCards = [
  {
    tag: 'STUDY',
    eyebrow: 'CONVERSION STRATEGY',
    title: 'Aurelia Dental Studio',
    outcome: 'Clear, warm, and easy to navigate. New patients find what they need and book without second-guessing.',
    image: getWorkProofImage('concept-dental-demo').source,
    alt: getWorkProofImage('concept-dental-demo').alt || 'Aurelia Dental Studio',
    position: getWorkProofImage('concept-dental-demo').position || 'center 40%',
  },
  {
    tag: 'STUDY',
    eyebrow: 'LOCAL BUSINESS',
    title: 'Nails Studio Demo',
    outcome: 'Booking is visible early, services are easy to compare, and the brand reads as calm and polished.',
    image: getWorkProofImage('concept-salon-demo').source,
    alt: getWorkProofImage('concept-salon-demo').alt || 'Nails Studio Demo',
    position: getWorkProofImage('concept-salon-demo').position || 'center 40%',
  },
  {
    tag: 'STUDY',
    eyebrow: 'REBUILD',
    title: 'Blackline Barber Co.',
    outcome: 'Fast, sharp, and direct. Clients get to the booking button in seconds - no hunting required.',
    image: getWorkProofImage('concept-barber-demo').source,
    alt: getWorkProofImage('concept-barber-demo').alt || 'Blackline Barber Co.',
    position: getWorkProofImage('concept-barber-demo').position || 'center 40%',
  },
] as const;

const principles = [
  {
    number: '01',
    title: 'Your offer reads in five seconds.',
    description: 'Visitors learn what you do, who you serve, and how to book before they scroll. No hunting through nav menus.',
    icon: 'eye',
  },
  {
    number: '02',
    title: 'Your booking button is the loudest thing on the page.',
    description: 'Phone, online booking, or contact form — never more than one tap away on mobile, never buried below the fold.',
    icon: 'bolt',
  },
  {
    number: '03',
    title: 'Reviews and credentials sit where buyers decide.',
    description: 'Proof goes next to the price, the service, and the booking button — not hidden in a footer carousel.',
    icon: 'shield-check',
  },
  {
    number: '04',
    title: 'Mobile-first, verified before launch.',
    description: 'Core Web Vitals, tap targets, and form quality are tested on real devices — not just a desktop preview.',
    icon: 'key',
  },
] as const;

const processStages = [
  {
    day: 'Week 1',
    title: 'Review',
    description: 'Current site, offer, audience, conversion path, and technical constraints are assessed first.',
    icon: 'search',
  },
  {
    day: 'Week 2',
    title: 'Scope',
    description: 'The page set, message hierarchy, visual direction, and launch requirements are locked before production.',
    icon: 'document',
  },
  {
    day: 'Weeks 2-3',
    title: 'Build',
    description: 'Design, development, content structure, responsiveness, and performance are assembled together.',
    icon: 'code',
  },
  {
    day: 'Weeks 3-4',
    title: 'Launch',
    description: 'QA, Core Web Vitals checks, analytics, handoff, and support path are completed before release.',
    icon: 'arrow-up',
  },
] as const;

const timelineSteps = processStages.map((stage) => ({
  kicker: stage.day,
  title: stage.title,
  description: stage.description,
}));

const faqs = [
  {
    q: 'Who owns the site?',
    a: 'You do. Code, content, domain, and analytics transfer on day one. No platform lock-in, no proprietary builder you can\'t leave.',
  },
  {
    q: 'What stack do you use?',
    a: 'Astro, React, Tailwind — static-fast, framework-portable, hostable anywhere. No SaaS page-builder dependency.',
  },
  {
    q: 'What if I want to leave later?',
    a: 'Take the code, content, and domain with you. Monthly clients can cancel with 30 days\' notice. No exit fees, no held-hostage assets.',
  },
  {
    q: 'How long until launch?',
    a: 'Two to four weeks from kickoff. Dates are locked in scope, not aspirational. Delays on our side mean a discount, in writing.',
  },
  {
    q: 'Do you handle ongoing changes?',
    a: 'Monthly clients get scheduled updates included. Ownership clients book changes by the hour or in retainer blocks — your call.',
  },
  {
    q: 'Why no client list yet?',
    a: 'We\'re new. The studies above show the standard we build to. In exchange for that gap: fixed scope, transparent pricing, and a free teardown of your current site before you decide anything.',
  },
] as const;

const services = [
  {
    label: 'Booking-led Conversion Sites',
    description:
      'For appointment-based businesses where the booking button is the product. Clear offer up top, proof beside the price, one tap to book on mobile.',
    href: '/services/conversion-sites',
    icon: 'target',
  },
  {
    label: 'Local Business Websites',
    description:
      'For practices, studios, and shops whose reputation and service area need to be obvious in the first scroll — with Google Business, reviews, and contact path wired in.',
    href: '/services/local-business-websites',
    icon: 'crown',
  },
  {
    label: 'Rebuilds',
    description:
      'Replace a dated or template-heavy site without losing rankings, content, or domain trust. Same URL, faster load, cleaner path to inquiry.',
    href: '/services/rebuilds',
    icon: 'refresh',
  },
] as const;

---

<SiteLayout
  title={SEO_ROUTES.home.title}
  description={SEO_ROUTES.home.description}
  canonicalPath="/"
  ogImageAlt="Axiom Web homepage – custom web development in Kitchener-Waterloo."
  schema={[HOME_JSON_LD, WEBSITE_SCHEMA]}
>
  <main id="main-content" tabindex="-1" class="-mt-28 md:-mt-32">
    <section class="hero-shell relative overflow-hidden pb-20 pt-32 md:pb-28 md:pt-40">
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 hero-aurora"
        style="
          background:
            radial-gradient(circle at 82% 12%, var(--accent-surface) 0%, var(--accent-surface-strong) 14%, transparent 36%),
            linear-gradient(180deg, var(--surface-panel-strong) 0%, transparent 18%);
        "
      />
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 hero-noise opacity-[0.04]"
        style="
          background-image:
            radial-gradient(circle at 20% 20%, var(--hero-noise-dot) 0.6px, transparent 0.6px),
            radial-gradient(circle at 80% 70%, var(--hero-noise-dot-alt) 0.6px, transparent 0.6px);
          background-size: 4px 4px, 5px 5px;
          background-position: 0 0, 1px 1px;
          mix-blend-mode: overlay;
        "
      />
      <div aria-hidden="true" class="hero-grid pointer-events-none absolute inset-0" />
      <div aria-hidden="true" class="hero-cursor-glow" />
      <div class="axiom-container relative">
        <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(22rem,30rem)] lg:items-center">
          <div class="max-w-3xl">
            <FadeIn motion="sceneOpen" className="hero-copy-primary">
              <MotionHeading as="h1" text="A website your *next booking* actually comes from." className="max-w-4xl text-left" />
            </FadeIn>
            <FadeIn delay={520} motion="editorialMaskReveal">
              <p class="section-copy mt-6 max-w-2xl md:text-[1.1rem]">
                Axiom builds high-trust websites for local appointment-based businesses — dental, beauty, fitness, clinics, studios. Clearer offer, visible booking, mobile-correct, fast. Based in Kitchener-Waterloo, serving Canada.
              </p>
            </FadeIn>

            <FadeIn delay={780} motion="sceneOpen">
              <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
                <Button asChild size="lg" className="w-full sm:w-auto">
                  <a href={createStartProjectHref('teardown')}>Get a free site teardown</a>
                </Button>
                <Button asChild variant="ghost" size="lg" className="w-full px-0 sm:w-auto">
                  <a href="/work">See the work</a>
                </Button>
              </div>
            </FadeIn>

            <FadeIn delay={920} motion="editorialMaskReveal">
              <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 font-mono text-[11px] uppercase tracking-[0.14em] text-[var(--text-muted)]">
                <span>From $200/mo, $0 down</span>
                <span aria-hidden="true">&bull;</span>
                <span>Reply within one business day</span>
                <span aria-hidden="true">&bull;</span>
                <span>No sales call required</span>
              </div>
              <p class="mt-3 text-[13px] leading-[1.6] text-[var(--text-muted)]">
                Or own it outright from $3,500. <a href="/pricing" class="text-[var(--accent-solid)] underline-offset-4 hover:underline">See full pricing</a>.
              </p>
            </FadeIn>
          </div>

          <FadeIn delay={980} as="div" motion="depthCardReveal" className="hidden justify-self-end lg:block" aria-hidden="true">
            <div class="hero-browser-shell hero-visual">
              <svg viewBox="0 0 520 340" class="block h-auto w-full" fill="none" role="presentation">
                <rect x="0.75" y="0.75" width="518.5" height="338.5" rx="24" class="hero-browser-frame" />
                <rect x="0.75" y="0.75" width="518.5" height="52" rx="24" class="hero-browser-chrome" />
                <circle cx="36" cy="26" r="5.5" class="hero-browser-dot" />
                <circle cx="54" cy="26" r="5.5" class="hero-browser-dot" />
                <circle cx="72" cy="26" r="5.5" class="hero-browser-dot" />

                {browserBars.map((bar, index) => (
                  <rect
                    key={index}
                    x="42"
                    y={86 + index * 46}
                    width={bar.width}
                    height="16"
                    rx="8"
                    class="hero-browser-bar"
                    style={`--browser-delay: ${bar.delay}s;`}
                  />
                ))}
                <rect x="42" y="250" width="182" height="34" rx="17" class="hero-browser-chip" />
                <rect x="248" y="250" width="108" height="34" rx="17" class="hero-browser-chip hero-browser-chip-soft" />
                <path d="M405 116C431 142 444 170 444 200C444 230 428 255 396 276" class="hero-browser-arc" />
                <path d="M386 104C407 132 416 161 413 191C410 222 392 246 358 263" class="hero-browser-arc hero-browser-arc-muted" />
              </svg>
              <div class="hero-status-panel">
                <span>CORE WEB VITALS</span>
                <strong>Verified before launch</strong>
              </div>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>

    <ProofBar />

    <section class="page-section section-shell">
      <div class="axiom-container">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
          <FadeIn motion="editorialMaskReveal" className="max-w-3xl">
            <Eyebrow>SELECTED WORK</Eyebrow>
            <SectionDivider className="mt-6" />
            <MotionHeading as="h2" text="Studies built to *our standard*." className="section-heading mt-4" />
            <p class="section-copy mt-4 md:text-[17px]">
              Each study shows how we'd approach a real business in its industry — booking visible, proof close to the decision, mobile-correct. Client projects are in progress; these set the bar.
            </p>
          </FadeIn>

          <FadeIn delay={180} motion="sceneOpen" className="flex flex-wrap items-center gap-3 lg:justify-end lg:pb-1">
            <a
              href="/work"
              class="inline-flex min-h-11 items-center justify-center rounded-full border border-[color:var(--accent-border)] bg-[rgba(214,173,66,0.08)] px-5 font-mono text-[12px] font-medium uppercase tracking-[0.12em] text-[var(--accent-solid)] transition-[border-color,background-color,color] duration-200 hover:border-[color:var(--accent-solid)] hover:bg-[rgba(214,173,66,0.12)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--accent-solid)]"
            >
              View all work
            </a>
          </FadeIn>
        </div>

        <div
          id="selected-work-demos"
          class="mt-10 grid gap-6 grid-cols-1 md:grid-cols-3"
        >
          <!-- Card 1: Aurelia Dental Studio (Landscape, col-span-2) -->
          <FadeIn motion="depthCardReveal" delay={0} className="md:col-span-2" as="div">
            <Card
              className="premium-card group overflow-hidden p-0 transition-[transform,background-color,border-color,box-shadow] duration-200 ease-[var(--ease-premium)] hover:bg-[var(--surface-2)] hover:border-[color:var(--hairline-strong)] h-full flex flex-col md:flex-row"
            >
              <figure class="relative overflow-hidden border-b md:border-b-0 md:border-r border-[color:var(--hairline)] bg-white/5 md:w-3/5 h-full min-h-[240px]">
                <ResponsivePicture
                  source={workCards[0].image}
                  alt={workCards[0].alt}
                  sizes="(min-width: 1024px) 50vw, 100vw"
                  class="media-zoom absolute inset-0 h-full w-full object-cover"
                  loading="lazy"
                  fetchpriority="low"
                  objectPosition={workCards[0].position}
                />
                <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_top,var(--overlay-black-soft),transparent)]" />
              </figure>

              <div class="flex flex-col justify-center p-6 sm:p-8 md:w-2/5">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="rounded-full border border-[color:var(--hairline)] bg-[color:var(--surface-overlay)] px-3 py-1 font-mono text-[11px] font-medium uppercase tracking-[0.14em] text-[var(--accent-solid)]">
                    {workCards[0].tag}
                  </span>
                  <Eyebrow>{workCards[0].eyebrow}</Eyebrow>
                </div>
                <h3 class="mt-4 text-[clamp(1.25rem,2.2vw,1.75rem)] font-semibold tracking-tight text-[var(--text-primary)]">
                  {workCards[0].title}
                </h3>
                <p class="section-copy mt-3 text-[14px] leading-relaxed">
                  {workCards[0].outcome}
                </p>
              </div>
            </Card>
          </FadeIn>

          <!-- Card 2: Nails Studio Demo (Portrait, col-span-1) -->
          <FadeIn motion="depthCardReveal" delay={150} className="md:col-span-1" as="div">
            <Card
              className="premium-card group overflow-hidden p-0 transition-[transform,background-color,border-color,box-shadow] duration-200 ease-[var(--ease-premium)] hover:bg-[var(--surface-2)] hover:border-[color:var(--hairline-strong)] h-full flex flex-col"
            >
              <figure class="relative overflow-hidden border-b border-[color:var(--hairline)] bg-white/5 aspect-[4/3] w-full">
                <ResponsivePicture
                  source={workCards[1].image}
                  alt={workCards[1].alt}
                  sizes="(min-width: 1024px) 25vw, 100vw"
                  class="media-zoom absolute inset-0 h-full w-full object-cover"
                  loading="lazy"
                  fetchpriority="low"
                  objectPosition={workCards[1].position}
                />
                <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_top,var(--overlay-black-soft),transparent)]" />
              </figure>

              <div class="flex flex-col p-6 sm:p-7 flex-grow">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="rounded-full border border-[color:var(--hairline)] bg-[color:var(--surface-overlay)] px-3 py-1 font-mono text-[11px] font-medium uppercase tracking-[0.14em] text-[var(--accent-solid)]">
                    {workCards[1].tag}
                  </span>
                  <Eyebrow>{workCards[1].eyebrow}</Eyebrow>
                </div>
                <h3 class="mt-4 text-xl font-semibold tracking-tight text-[var(--text-primary)]">
                  {workCards[1].title}
                </h3>
                <p class="section-copy mt-3 text-[14px] leading-relaxed">
                  {workCards[1].outcome}
                </p>
              </div>
            </Card>
          </FadeIn>

          <!-- Card 3: Blackline Barber Co. (Portrait, col-span-1) -->
          <FadeIn motion="depthCardReveal" delay={300} className="md:col-span-1" as="div">
            <Card
              className="premium-card group overflow-hidden p-0 transition-[transform,background-color,border-color,box-shadow] duration-200 ease-[var(--ease-premium)] hover:bg-[var(--surface-2)] hover:border-[color:var(--hairline-strong)] h-full flex flex-col"
            >
              <figure class="relative overflow-hidden border-b border-[color:var(--hairline)] bg-white/5 aspect-[4/3] w-full">
                <ResponsivePicture
                  source={workCards[2].image}
                  alt={workCards[2].alt}
                  sizes="(min-width: 1024px) 25vw, 100vw"
                  class="media-zoom absolute inset-0 h-full w-full object-cover"
                  loading="lazy"
                  fetchpriority="low"
                  objectPosition={workCards[2].position}
                />
                <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_top,var(--overlay-black-soft),transparent)]" />
              </figure>

              <div class="flex flex-col p-6 sm:p-7 flex-grow">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="rounded-full border border-[color:var(--hairline)] bg-[color:var(--surface-overlay)] px-3 py-1 font-mono text-[11px] font-medium uppercase tracking-[0.14em] text-[var(--accent-solid)]">
                    {workCards[2].tag}
                  </span>
                  <Eyebrow>{workCards[2].eyebrow}</Eyebrow>
                </div>
                <h3 class="mt-4 text-xl font-semibold tracking-tight text-[var(--text-primary)]">
                  {workCards[2].title}
                </h3>
                <p class="section-copy mt-3 text-[14px] leading-relaxed">
                  {workCards[2].outcome}
                </p>
              </div>
            </Card>
          </FadeIn>

          <!-- Card 4: Founder block (Landscape, col-span-2) -->
          <FadeIn motion="depthCardReveal" delay={450} className="md:col-span-2" as="div">
            <Card
              className="premium-card group overflow-hidden p-6 sm:p-8 transition-[transform,background-color,border-color,box-shadow] duration-200 ease-[var(--ease-premium)] hover:bg-[var(--surface-2)] hover:border-[color:var(--hairline-strong)] h-full flex flex-col justify-between"
            >
              <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between">
                  <span class="rounded-full border border-[color:var(--hairline)] bg-[color:var(--surface-overlay)] px-3 py-1 font-mono text-[11px] font-medium uppercase tracking-[0.14em] text-[var(--accent-solid)]">
                    WHO BUILDS THIS
                  </span>
                  <span class="font-mono text-[11px] tracking-[0.16em] text-[var(--text-muted)]">KITCHENER-WATERLOO</span>
                </div>
                <h3 class="mt-4 text-2xl font-semibold tracking-tight text-[var(--text-primary)]">
                  Two people. Not a vendor.
                </h3>
                <p class="section-copy mt-2 text-[14px] leading-relaxed max-w-xl">
                  Axiom is Aidan and Riley. No account managers, no offshore handoffs. You talk to the people doing the work, every step. One business day to reply, one point of contact through launch.
                </p>
              </div>

              <div class="mt-8 grid grid-cols-2 gap-4 border-t border-[color:var(--hairline)] pt-6">
                <div>
                  <span class="block font-mono text-[10px] uppercase tracking-[0.16em] text-[var(--text-muted)]">AIDAN</span>
                  <span class="text-[15px] font-medium tracking-tight text-[var(--text-primary)]">Strategy, scope, client support</span>
                </div>
                <div>
                  <span class="block font-mono text-[10px] uppercase tracking-[0.16em] text-[var(--text-muted)]">RILEY</span>
                  <span class="text-[15px] font-medium tracking-tight text-[var(--text-primary)]">Design, build, QA</span>
                </div>
              </div>
            </Card>
          </FadeIn>
        </div>
      </div>
    </section>

    <section class="page-section section-shell">
      <div class="axiom-container">
        <FadeIn motion="editorialMaskReveal" className="max-w-3xl">
          <Eyebrow>SERVICES</Eyebrow>
          <SectionDivider className="mt-6" />
            <MotionHeading as="h2" text="Three ways to *strengthen* the site." className="section-heading mt-4" />
        </FadeIn>

        <div class="mt-12 flex flex-col border-t border-[color:var(--hairline)]">
          {services.map((service, index) => (
            <FadeIn motion="timelineSequence" delay={Math.min(index * 120, 480)} as="div">
              <div class="border-b border-[color:var(--hairline)]">
                <a
                  href={service.href}
                  class="group flex flex-col md:flex-row md:items-center justify-between py-8 px-6 transition-all duration-300 hover:bg-white/[0.01]"
                >
                  <div class="flex items-start md:items-center gap-6">
                    <span class="font-mono text-[14px] font-semibold text-[var(--accent-solid)] pt-1 md:pt-0">
                      0{index + 1}
                    </span>
                    <div class="flex items-center gap-4">
                      <DrawIcon name={service.icon} className="transition-transform duration-300 group-hover:rotate-90 group-hover:text-[var(--accent-solid)] text-[var(--text-muted)]" />
                      <div class="flex flex-col gap-1">
                        <h3 class="text-xl md:text-2xl font-medium tracking-tight text-[var(--text-primary)]">
                          {service.label}
                        </h3>
                        <p class="section-copy max-w-2xl text-[14px] md:text-[15px] mt-0.5">
                          {service.description}
                        </p>
                      </div>
                    </div>
                  </div>
                  <div class="mt-6 md:mt-0 flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.16em] text-[var(--text-muted)] group-hover:text-[var(--accent-solid)] transition-colors duration-300">
                    Explore Service
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 transform group-hover:translate-x-1.5 transition-transform duration-300"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                  </div>
                </a>
              </div>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section section-shell">
      <div class="axiom-container">
        <FadeIn motion="editorialMaskReveal" className="max-w-3xl">
          <Eyebrow>WHY AXIOM</Eyebrow>
          <SectionDivider className="mt-6" />
          <MotionHeading as="h2" text="Built for businesses that *live or die by bookings*." className="section-heading mt-4" />
          <p class="section-copy mt-4 md:text-[17px]">
            Dental clinics. Salons and studios. Med-spas and fitness. Trades booked by appointment. If your next client decides whether to call from their phone, the site has to do four things right.
          </p>
        </FadeIn>

        <div class="mt-10 grid gap-5 md:grid-cols-2">
          {principles.map((principle, index) => (
            <FadeIn motion="timelineSequence" delay={Math.min(index * 140, 560)} as="div">
              <Card className="h-full p-0">
                <div class="flex h-full flex-col p-6 sm:p-7">
                  <div class="mb-5 flex items-center justify-between gap-4">
                    <DrawIcon name={principle.icon} />
                    <p class="font-mono text-[0.75rem] font-medium uppercase tracking-[0.08em] text-[var(--accent-solid)]">{principle.number}</p>
                  </div>
                  <h3 class="mt-4 text-[clamp(1.25rem,1.5vw,1.5rem)] font-medium tracking-[-0.02em] text-[var(--text-primary)]">
                    {principle.title}
                  </h3>
                  <p class="section-copy mt-3">
                    {principle.description}
                  </p>
                </div>
              </Card>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section section-shell">
      <div class="axiom-container">
        <FadeIn motion="editorialMaskReveal" className="max-w-3xl">
          <Eyebrow>PROCESS</Eyebrow>
          <SectionDivider className="mt-6" />
          <MotionHeading as="h2" text="A clear *operating system*, start to finish." className="section-heading mt-4" />
        </FadeIn>

        <div class="mt-10">
          <Timeline client:visible steps={timelineSteps} />
        </div>

        <div class="mt-6">
          <Button asChild variant="ghost" className="px-0">
            <a href="/process">See the full process</a>
          </Button>
        </div>
      </div>
    </section>

    <section class="page-section section-shell">
      <div class="axiom-container">
        <FadeIn motion="editorialMaskReveal" className="max-w-3xl">
          <Eyebrow>FAQ</Eyebrow>
          <SectionDivider className="mt-6" />
          <MotionHeading as="h2" text="Common questions, *answered first*." className="section-heading mt-4" />
          <p class="section-copy mt-4 md:text-[17px]">
            The questions every buyer asks before they hit send. Answered here so you don't have to schedule a call to find out.
          </p>
        </FadeIn>

        <div class="mt-10 grid gap-px overflow-hidden rounded-[22px] border border-[color:var(--hairline)] bg-[color:var(--hairline)] md:grid-cols-2">
          {faqs.map((faq, index) => (
            <FadeIn motion="timelineSequence" delay={Math.min(index * 90, 540)} as="div">
              <details class="group h-full bg-[var(--surface-1)] p-6 sm:p-7 transition-colors duration-200 hover:bg-[var(--surface-2)]">
                <summary class="flex cursor-pointer items-start justify-between gap-4 text-left">
                  <span class="text-[clamp(1.05rem,1.4vw,1.2rem)] font-medium tracking-tight text-[var(--text-primary)]">
                    {faq.q}
                  </span>
                  <span class="mt-1 flex h-7 w-7 flex-none items-center justify-center rounded-full border border-[color:var(--hairline)] font-mono text-[14px] text-[var(--accent-solid)] transition-transform duration-200 group-open:rotate-45" aria-hidden="true">+</span>
                </summary>
                <p class="section-copy mt-4 text-[14px] leading-relaxed">
                  {faq.a}
                </p>
              </details>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="final-cta-panel">
      <div class="axiom-container py-16 md:py-20">
        <div class="mx-auto max-w-4xl text-center">
          <FadeIn as="div" motion="finalFrameFooter">
            <SectionDivider className="mx-auto mb-6" />
            <MotionHeading as="h2" text="See what your site is *costing you* — free." className="section-heading mx-auto text-[clamp(32px,4vw,52px)] font-[600] text-[var(--text-primary)]" />
            <p class="section-copy mx-auto mt-5 md:text-[17px]">
              Send us your URL. We reply within one business day with a short teardown: what's working, what's leaking bookings, and what we'd change first. No sales call, no obligation.
            </p>
            <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row sm:items-center">
              <Button asChild size="lg" className="w-full sm:w-auto">
                <a href={createStartProjectHref('teardown')}>Get a free site teardown</a>
              </Button>
              <Button asChild variant="ghost" size="lg" className="w-full px-0 sm:w-auto">
                <a href="/pricing">See pricing</a>
              </Button>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>
  </main>

  <style>
    details > summary {
      list-style: none;
    }
    details > summary::-webkit-details-marker {
      display: none;
    }
    details:not([open]) > *:not(summary) {
