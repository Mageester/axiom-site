---
import ResponsivePicture from '../components/site/ResponsivePicture.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { CTA_PATHS } from '../lib/cta';
import { HOME_JSON_LD, WEBSITE_SCHEMA, SEO_ROUTES, breadcrumbSchema } from '../lib/seo';
import { getWorkProofImage } from '../lib/workProofImages';
import { FadeIn } from '../components/ui/FadeIn';
import { Button } from '../components/ui/button';
import { Card } from '../components/ui/card';
import { Eyebrow } from '../components/ui/Eyebrow';
import DrawIcon from '../components/ui/DrawIcon.astro';
import { MotionHeading } from '../components/motion/MotionHeading';
import { ProofBar } from '../components/motion/ProofBar';
import { SectionDivider } from '../components/motion/SectionDivider';
import { Timeline } from '../components/motion/Timeline';

const browserBars = [
  { width: '92%', delay: 0 },
  { width: '78%', delay: 0.4 },
  { width: '64%', delay: 0.8 },
] as const;

const workCards = [
  {
    tag: 'CONCEPT',
    eyebrow: 'SALON & BEAUTY',
    title: 'Nails Studio Demo',
    outcome: 'Refined service positioning, direct booking flow, and a visual system built for higher-consideration appointments.',
    metricLabel: 'STUDY',
    metricValue: 'SERVICE',
    image: getWorkProofImage('concept-salon-demo').source,
    alt: getWorkProofImage('concept-salon-demo').alt || 'Nails Studio Demo',
    position: getWorkProofImage('concept-salon-demo').position || 'center 40%',
  },
  {
    tag: 'CONCEPT',
    eyebrow: 'PERSONAL SERVICES & GROOMING',
    title: 'Blackline Barber Co.',
    outcome: 'A sharper brand environment with fewer decisions between arrival and booking.',
    metricLabel: 'STUDY',
    metricValue: 'GROOMING',
    image: getWorkProofImage('concept-barber-demo').source,
    alt: getWorkProofImage('concept-barber-demo').alt || 'Blackline Barber Co.',
    position: getWorkProofImage('concept-barber-demo').position || 'center 40%',
  },
  {
    tag: 'CONCEPT',
    eyebrow: 'HEALTHCARE & MEDICAL',
    title: 'Aurelia Dental Studio',
    outcome: 'Calm interface, trust-forward structure, and patient conversion paths that feel considered from the first screen.',
    metricLabel: 'STUDY',
    metricValue: 'HEALTHCARE',
    image: getWorkProofImage('concept-dental-demo').source,
    alt: getWorkProofImage('concept-dental-demo').alt || 'Aurelia Dental Studio',
    position: getWorkProofImage('concept-dental-demo').position || 'center 40%',
  },
] as const;

const principles = [
  {
    number: '01',
    title: 'Clear commercial position',
    description: 'The offer, audience, and next action are sharpened before the interface gets dressed.',
    icon: 'eye',
  },
  {
    number: '02',
    title: 'Proof in the buyer path',
    description: 'Credibility sits where decisions happen, not hidden at the bottom of the page.',
    icon: 'shield-check',
  },
  {
    number: '03',
    title: 'Performance as baseline',
    description: 'Core Web Vitals, load speed, accessibility, and mobile behavior are treated as launch requirements.',
    icon: 'bolt',
  },
  {
    number: '04',
    title: 'Support without dependency',
    description: 'Monthly support is available. Ownership remains clean. The site is never built to trap the client.',
    icon: 'key',
  },
] as const;

const processStages = [
  {
    day: 'Week 1',
    title: 'Review',
    description: 'Current site, offer, audience, conversion path, and technical constraints are assessed first.',
    icon: 'search',
  },
  {
    day: 'Week 2',
    title: 'Scope',
    description: 'The page set, message hierarchy, visual direction, and launch requirements are locked before production.',
    icon: 'document',
  },
  {
    day: 'Weeks 2-3',
    title: 'Build',
    description: 'Design, development, content structure, responsiveness, and performance are assembled together.',
    icon: 'code',
  },
  {
    day: 'Weeks 3-4',
    title: 'Launch',
    description: 'QA, Core Web Vitals checks, analytics, handoff, and support path are completed before release.',
    icon: 'arrow-up',
  },
] as const;

const timelineSteps = processStages.map((stage) => ({
  kicker: stage.day,
  title: stage.title,
  description: stage.description,
}));

const services = [
  {
    label: 'Growth Retainer',
    description:
      'Launch with lower upfront friction, then keep design, content, performance, and support moving after release.',
    href: '/work',
    icon: 'target',
  },
  {
    label: 'Ownership Build',
    description:
      'A scoped custom site with full code handoff, launch support, and clean ownership from day one.',
    href: '/work',
    icon: 'crown',
  },
  {
    label: 'Rebuild & Migrate',
    description:
      'Replace a dated or underperforming site without losing momentum, structure, or search visibility.',
    href: '/process',
    icon: 'refresh',
  },
] as const;

---

<SiteLayout
  title={SEO_ROUTES.home.title}
  description={SEO_ROUTES.home.description}
  canonicalPath="/"
  ogImageAlt="Axiom Web homepage – custom web development in Kitchener-Waterloo."
  schema={[HOME_JSON_LD, WEBSITE_SCHEMA]}
>
  <main id="main-content" tabindex="-1" class="-mt-28 md:-mt-32">
    <section class="hero-shell relative overflow-hidden pb-20 pt-32 md:pb-28 md:pt-40">
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 hero-aurora"
        style="
          background:
            radial-gradient(circle at 82% 12%, var(--accent-surface) 0%, var(--accent-surface-strong) 14%, transparent 36%),
            linear-gradient(180deg, var(--surface-panel-strong) 0%, transparent 18%);
        "
      />
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 hero-noise opacity-[0.04]"
        style="
          background-image:
            radial-gradient(circle at 20% 20%, var(--hero-noise-dot) 0.6px, transparent 0.6px),
            radial-gradient(circle at 80% 70%, var(--hero-noise-dot-alt) 0.6px, transparent 0.6px);
          background-size: 4px 4px, 5px 5px;
          background-position: 0 0, 1px 1px;
          mix-blend-mode: overlay;
        "
      />
      <div aria-hidden="true" class="hero-grid pointer-events-none absolute inset-0" />
      <div class="axiom-container relative">
        <div class="grid gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(22rem,30rem)] lg:items-center">
          <div class="max-w-3xl">
            <FadeIn delay={180} motion="sceneOpen">
              <MotionHeading as="h1" text="We build the site your business actually deserves." className="max-w-4xl text-left" />
            </FadeIn>
            <FadeIn delay={520} motion="editorialMaskReveal">
              <p class="section-copy mt-6 max-w-2xl md:text-[1.1rem]">
              Custom web design and development for teams that need sharper positioning, faster performance, and a more serious path from first impression to booked conversation.
              </p>
            </FadeIn>

            <FadeIn delay={780} motion="sceneOpen">
              <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
                <Button asChild size="lg" className="w-full sm:w-auto">
                  <a href={CTA_PATHS.startProject}>Start a project</a>
                </Button>
                <Button asChild variant="ghost" size="lg" className="w-full px-0 sm:w-auto">
                  <a href="/work">View concept work</a>
                </Button>
              </div>
            </FadeIn>
          </div>

          <FadeIn delay={980} as="div" motion="depthCardReveal" className="hidden justify-self-end lg:block" aria-hidden="true">
            <div class="hero-browser-shell hero-visual">
              <svg viewBox="0 0 520 340" class="block h-auto w-full" fill="none" role="presentation">
                <rect x="0.75" y="0.75" width="518.5" height="338.5" rx="24" class="hero-browser-frame" />
                <rect x="0.75" y="0.75" width="518.5" height="52" rx="24" class="hero-browser-chrome" />
                <circle cx="36" cy="26" r="5.5" class="hero-browser-dot" />
                <circle cx="54" cy="26" r="5.5" class="hero-browser-dot" />
                <circle cx="72" cy="26" r="5.5" class="hero-browser-dot" />

                {browserBars.map((bar, index) => (
                  <rect
                    key={index}
                    x="42"
                    y={86 + index * 46}
                    width={bar.width}
                    height="16"
                    rx="8"
                    class="hero-browser-bar"
                    style={`--browser-delay: ${bar.delay}s;`}
                  />
                ))}
                <rect x="42" y="250" width="182" height="34" rx="17" class="hero-browser-chip" />
                <rect x="248" y="250" width="108" height="34" rx="17" class="hero-browser-chip hero-browser-chip-soft" />
                <path d="M405 116C431 142 444 170 444 200C444 230 428 255 396 276" class="hero-browser-arc" />
                <path d="M386 104C407 132 416 161 413 191C410 222 392 246 358 263" class="hero-browser-arc hero-browser-arc-muted" />
              </svg>
              <div class="hero-status-panel">
                <span>CORE WEB VITALS</span>
                <strong>Verified before launch</strong>
              </div>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>

    <ProofBar />

    <section class="page-section section-shell">
      <div class="axiom-container">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
          <FadeIn motion="editorialMaskReveal" className="max-w-3xl">
            <Eyebrow>SELECTED WORK</Eyebrow>
            <SectionDivider className="mt-6" />
            <MotionHeading as="h2" text="Concept studies." className="section-heading mt-4" />
            <p class="section-copy mt-4 md:text-[17px]">
              Internal explorations of how Axiom approaches different categories. Client work in production.
            </p>
          </FadeIn>

          <FadeIn delay={180} motion="sceneOpen" className="lg:pb-1">
            <button
              type="button"
              class="inline-flex min-h-11 items-center justify-center rounded-full border border-[color:var(--hairline)] bg-[rgba(255,255,255,0.03)] px-5 font-mono text-[12px] font-medium uppercase tracking-[0.12em] text-[var(--accent-solid)] transition-[border-color,background-color,color] duration-200 hover:border-[color:var(--accent-border)] hover:bg-[rgba(255,255,255,0.05)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--accent-solid)]"
              data-work-demo-toggle
              aria-controls="selected-work-demos"
              aria-expanded="true"
            >
              <span data-work-demo-label>Collapse demos</span>
            </button>
          </FadeIn>
        </div>

        <div
          id="selected-work-demos"
          class="mt-10 grid gap-6 overflow-hidden md:grid-cols-2 xl:grid-cols-3"
          data-work-demo-list
          data-state="expanded"
        >
          {workCards.map((card, index) => (
            <FadeIn motion="depthCardReveal" delay={Math.min(index * 150, 600)}>
              <Card
                className="group overflow-hidden p-0 transition-[transform,background-color,border-color,box-shadow] duration-200 ease-[var(--ease-premium)] hover:bg-[var(--surface-2)] hover:border-[color:var(--hairline-strong)]"
              >
                <figure class="relative overflow-hidden border-b border-[color:var(--hairline)] bg-white/5">
                  <ResponsivePicture
                    source={card.image}
                    alt={card.alt}
                    sizes="(min-width: 1280px) 32vw, (min-width: 768px) 45vw, 100vw"
                    class="media-zoom aspect-[4/3] h-full w-full object-cover"
                    loading="lazy"
                    fetchpriority="low"
                    objectPosition={card.position}
                  />
                  <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(to_top,var(--overlay-black-soft),transparent)]" />
                </figure>

                <div class="flex h-full flex-col p-6 sm:p-7">
                  <div class="flex flex-wrap items-center gap-3">
                    <span class="rounded-full border border-[color:var(--hairline)] bg-[color:var(--surface-overlay)] px-3 py-1 font-mono text-[11px] font-medium uppercase tracking-[0.14em] text-[var(--accent-solid)]">
                      {card.tag}
                    </span>
                    <Eyebrow>{card.eyebrow}</Eyebrow>
                  </div>
                  <h3 class="mt-4 text-[22px] font-semibold tracking-[-0.01em] text-[var(--text-primary)]">
                    {card.title}
                  </h3>
                  <p class="section-copy mt-3">
                    {card.outcome}
                  </p>
                </div>
              </Card>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section section-shell">
      <div class="axiom-container">
        <FadeIn motion="editorialMaskReveal" className="max-w-3xl">
          <Eyebrow>ENGAGEMENTS</Eyebrow>
          <SectionDivider className="mt-6" />
          <MotionHeading as="h2" text="Three ways to commission the work." className="section-heading mt-4" />
        </FadeIn>

        <div class="mt-10 grid gap-5 md:grid-cols-3">
          {services.map((service, index) => (
            <FadeIn motion="depthCardReveal" delay={Math.min(index * 120, 480)} as="div">
              <a
                href={service.href}
                class="premium-card group flex h-full flex-col gap-4 rounded-[var(--radius-card)] border border-[color:var(--hairline)] bg-[rgba(255,255,255,0.02)] p-6 transition-[border-color,background-color,box-shadow,transform] duration-200 hover:border-[color:var(--accent-border)] hover:bg-[rgba(255,255,255,0.03)] hover:shadow-[0_20px_48px_rgba(0,0,0,0.28),0_0_0_1px_rgb(var(--accent-v2-rgb,var(--accent-current-rgb))_/_0.14)] sm:p-7"
              >
                <DrawIcon name={service.icon} className="transition-transform duration-300 group-hover:rotate-90 group-hover:text-[var(--accent-solid)]" />
                  <p class="text-[clamp(1.25rem,1.5vw,1.5rem)] font-medium tracking-[-0.02em] text-[var(--text-primary)]">
                    {service.label}
                  </p>
                <p class="section-copy">
                  {service.description}
                </p>
                <span class="mt-auto font-mono text-[12px] uppercase tracking-[0.12em] text-[var(--accent-solid)] transition-opacity duration-200 group-hover:opacity-80">
                  View concept work
                </span>
              </a>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section section-shell">
      <div class="axiom-container">
        <FadeIn motion="editorialMaskReveal" className="max-w-3xl">
          <Eyebrow>FIT</Eyebrow>
          <SectionDivider className="mt-6" />
          <MotionHeading as="h2" text="Built for companies with something to protect." className="section-heading mt-4" />
          <p class="section-copy mt-4 md:text-[17px]">
            Established offers. Growing teams. Higher-value sales conversations. Brands where the site has to signal judgment before it asks for action.
          </p>
        </FadeIn>
      </div>
    </section>

    <script is:inline>
      (() => {
        const button = document.querySelector('[data-work-demo-toggle]');
        const label = document.querySelector('[data-work-demo-label]');
        const demoList = document.querySelector('[data-work-demo-list]');

        if (!(button instanceof HTMLButtonElement) || !(label instanceof HTMLElement) || !(demoList instanceof HTMLElement)) {
          return;
        }

        const setExpanded = (expanded) => {
          button.setAttribute('aria-expanded', String(expanded));
          label.textContent = expanded ? 'Collapse demos' : 'Expand demos';
          demoList.dataset.state = expanded ? 'expanded' : 'collapsed';
          demoList.style.maxHeight = expanded ? `${demoList.scrollHeight}px` : '0px';
        };

        setExpanded(true);

        window.addEventListener('resize', () => {
          if (button.getAttribute('aria-expanded') === 'true') {
            demoList.style.maxHeight = `${demoList.scrollHeight}px`;
          }
        });

        button.addEventListener('click', () => {
          setExpanded(button.getAttribute('aria-expanded') !== 'true');
        });
      })();
    </script>

    <style>
      [data-work-demo-list] {
        transition:
          max-height 560ms var(--ease-premium),
          opacity 320ms var(--ease-premium),
          transform 420ms var(--ease-premium);
        will-change: max-height, opacity, transform;
      }

      [data-work-demo-list][data-state='collapsed'] {
        opacity: 0;
        pointer-events: none;
        transform: translateY(-0.5rem);
      }

      [data-work-demo-list][data-state='expanded'] {
        opacity: 1;
        transform: translateY(0);
      }

      @media (prefers-reduced-motion: reduce) {
        [data-work-demo-list] {
          transition: none;
        }
      }
    </style>

    <section class="page-section section-shell">
      <div class="axiom-container">
        <FadeIn motion="editorialMaskReveal" className="max-w-3xl">
          <Eyebrow>WHY AXIOM</Eyebrow>
          <SectionDivider className="mt-6" />
          <MotionHeading as="h2" text="The standard is visible before the call." className="section-heading mt-4" />
        </FadeIn>

        <div class="mt-10 grid gap-5 md:grid-cols-2">
          {principles.map((principle, index) => (
            <FadeIn motion="timelineSequence" delay={Math.min(index * 140, 560)} as="div">
              <Card className="h-full p-0">
                <div class="flex h-full flex-col p-6 sm:p-7">
                  <div class="mb-5 flex items-center justify-between gap-4">
                    <DrawIcon name={principle.icon} />
                    <p class="font-mono text-[0.75rem] font-medium uppercase tracking-[0.08em] text-[var(--accent-solid)]">{principle.number}</p>
                  </div>
                  <h3 class="mt-4 text-[clamp(1.25rem,1.5vw,1.5rem)] font-medium tracking-[-0.02em] text-[var(--text-primary)]">
                    {principle.title}
                  </h3>
                  <p class="section-copy mt-3">
                    {principle.description}
                  </p>
                </div>
              </Card>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section section-shell">
      <div class="axiom-container">
        <FadeIn motion="editorialMaskReveal" className="max-w-3xl">
          <Eyebrow>PROCESS</Eyebrow>
          <SectionDivider className="mt-6" />
          <MotionHeading as="h2" text="A tight build cycle with senior attention." className="section-heading mt-4" />
        </FadeIn>

        <div class="mt-10">
          <Timeline steps={timelineSteps} />
        </div>

        <div class="mt-6">
          <Button asChild variant="ghost" className="px-0">
            <a href="/process">See the full process</a>
          </Button>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-20">
      <div class="axiom-container">
        <FadeIn as="div" motion="finalFrameFooter">
          <Card className="mx-auto max-w-5xl overflow-hidden p-0 text-center">
            <div class="relative px-6 py-8 sm:px-8 sm:py-10 md:px-10 md:py-12">
              <div aria-hidden="true" class="absolute inset-0 bg-[radial-gradient(circle_at_50%_30%,rgb(var(--accent-v2-rgb,var(--accent-current-rgb))_/_0.12),transparent_45%)] blur-[100px]" />
              <div class="relative">
                <Eyebrow className="justify-center">PERFORMANCE STANDARD</Eyebrow>
                <SectionDivider className="mx-auto mt-6" />
                <MotionHeading as="h2" text="Speed is part of the brief." className="section-heading mx-auto mt-4" />
          <p class="section-copy mx-auto mt-4">
                Performance is not treated as polish. Standard builds are checked against Core Web Vitals before launch, with page weight, mobile responsiveness, and interaction quality reviewed as part of delivery.
              </p>
              </div>
            </div>
          </Card>
        </FadeIn>
      </div>
    </section>

    <section class="final-cta-panel">
      <div class="axiom-container py-12 md:py-16">
        <div class="grid gap-8 lg:grid-cols-[minmax(0,1.2fr)_minmax(18rem,0.75fr)] lg:items-end">
          <FadeIn as="div" motion="finalFrameFooter" className="max-w-3xl">
            <SectionDivider className="mb-6" />
            <MotionHeading as="h2" text="Investment follows the shape of the engagement." className="section-heading text-[clamp(32px,4vw,52px)] font-[600] text-[var(--text-primary)]" />
            <p class="section-copy mt-4">
              Monthly engagements begin at $200/mo. Ownership builds begin at $3,500. E-commerce, migrations, and larger systems are scoped individually. The first call determines fit, scope, and the cleanest path forward.
            </p>
          </FadeIn>

          <FadeIn delay={240} motion="finalFrameFooter" as="div">
            <div class="flex flex-col gap-4 lg:items-end">
              <Button asChild size="lg" className="w-full sm:w-auto">
                <a href={CTA_PATHS.startProject}>Start a project</a>
              </Button>
            </div>
          </FadeIn>
        </div>
      </div>
    </section>

    <section class="page-section-tight section-shell">
      <div class="axiom-container">
        <FadeIn as="div" motion="finalFrameFooter">
          <Card className="mx-auto max-w-5xl overflow-hidden p-0 text-center">
            <div class="px-6 py-8 sm:px-8 sm:py-10 md:px-10 md:py-12">
              <SectionDivider className="mx-auto mb-6" />
              <MotionHeading as="h2" text="Make the site easier to believe." className="section-heading mx-auto" />
              <p class="section-copy mx-auto mt-4 max-w-3xl">
                A sharper first impression. A cleaner path to inquiry. A technical foundation that can carry the business past its current stage.
              </p>
              <div class="mt-7">
                <Button asChild size="lg">
                  <a href={CTA_PATHS.startProject}>Start a project</a>
                </Button>
              </div>
            </div>
          </Card>
        </FadeIn>
      </div>
    </section>
  </main>

  <style>
    .hero-shell {
      isolation: isolate;
    }

    .hero-shell::after {
      content: '';
      position: absolute;
      inset: auto 0 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--hairline-strong), transparent);
      opacity: 0.8;
    }

    .hero-aurora {
      animation: hero-aurora-drift 30s ease-in-out infinite;
      transform-origin: center;
      will-change: transform, opacity;
    }

    .hero-grid {
      background-image:
        linear-gradient(to right, rgba(255, 255, 255, 0.04) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(255, 255, 255, 0.032) 1px, transparent 1px);
      background-size: 92px 92px;
      opacity: 0.18;
      mask-image: radial-gradient(circle at 78% 24%, black, transparent 62%);
    }

    .hero-browser-shell {
      position: relative;
      width: clamp(22rem, 32vw, 30rem);
      opacity: 0.78;
      transform: translate3d(0.75rem, -0.5rem, 0) rotate(1.6deg);
      transform-origin: center;
      pointer-events: none;
      will-change: transform, opacity;
    }

    .hero-visual {
      animation: hero-visual-float 8s var(--ease-premium-soft) infinite;
    }

    .hero-browser-frame {
      fill: rgba(255, 255, 255, 0.026);
      stroke: rgba(255, 255, 255, 0.13);
      stroke-width: 1;
    }

    .hero-browser-chrome {
      fill: rgba(255, 255, 255, 0.035);
    }

    .hero-browser-dot {
      fill: rgba(255, 255, 255, 0.22);
    }

    .hero-browser-bar {
      fill: var(--accent-solid);
      opacity: 0;
      transform-box: fill-box;
      transform-origin: left center;
      animation:
        browser-bar-reveal 1.45s var(--ease-cinematic) var(--browser-delay, 0s) forwards,
        browser-bar-pulse 8s ease-in-out calc(1.2s + var(--browser-delay, 0s)) infinite;
      will-change: opacity, transform;
    }

    .hero-browser-chip {
      fill: rgba(255, 255, 255, 0.075);
      stroke: rgba(255, 255, 255, 0.08);
      stroke-width: 1;
    }

    .hero-browser-chip-soft {
      fill: rgb(var(--accent-v2-rgb, var(--accent-current-rgb)) / 0.14);
      stroke: rgb(var(--accent-v2-rgb, var(--accent-current-rgb)) / 0.22);
    }

    .hero-browser-arc {
      stroke: rgb(var(--accent-v2-rgb, var(--accent-current-rgb)) / 0.5);
      stroke-width: 1.5;
