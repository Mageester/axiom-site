---
import SiteLayout from '../layouts/SiteLayout.astro';
import { CTA } from '../lib/cta';
import { SEO_ROUTES } from '../lib/seo';
---

<SiteLayout title={SEO_ROUTES.notFound.title} description={SEO_ROUTES.notFound.description} canonicalPath="/404" noIndex={true}>
  <main id="main-content" tabindex="-1" class="axiom-container flex min-h-[70vh] items-center py-24">
    <section class="w-full">
      <article class="mx-auto max-w-3xl overflow-hidden rounded-[var(--radius-card)] border border-white/10 bg-[linear-gradient(180deg,rgba(17,22,31,0.96)_0%,rgba(10,13,19,0.99)_100%)] p-8 text-center shadow-[0_18px_52px_rgba(0,0,0,0.2)] md:p-10">
        <p class="section-eyebrow">Not found</p>
        <h1 class="mt-3 text-[clamp(2.3rem,5vw,4rem)] font-bold tracking-tight text-[#F2F4F7]">
          The page you requested is not available.
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-sm leading-relaxed text-slate-300 md:text-base">
          Use the main links to continue, or go back to the home page.
        </p>
        <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
          <a href="/" class="btn-primary btn-lg w-full sm:w-auto">
            Home
          </a>
          <a href={CTA.work.to} class="btn-secondary btn-lg w-full sm:w-auto">
            See the work
          </a>
        </div>
      </article>
    </section>
  </main>
</SiteLayout>
