---
import AdminShell from '../components/admin/AdminShell';
import AdminLayout from '../layouts/AdminLayout.astro';
---

<AdminLayout title="Axiom Admin" description="Private admin area for Axiom Web." noIndex={true}>
  <div class="space-y-6">
    <div class="rounded-3xl border border-[color:var(--hairline)] bg-[color:var(--surface-overlay)] p-6 shadow-[var(--shadow-card-elevated)] md:p-8">
      <p class="font-axiomMono text-[11px] uppercase tracking-[0.2em] text-[var(--text-muted)]">Secure area</p>
      <div class="mt-4 h-10 w-64 max-w-full animate-pulse rounded bg-[color:var(--surface-overlay-press)]"></div>
      <p class="mt-4 text-sm text-[var(--text-secondary)]">Loading admin tools.</p>
    </div>

    <AdminShell client:only="react" />
  </div>
</AdminLayout>
