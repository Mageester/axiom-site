---
import SiteLayout from '../layouts/SiteLayout.astro';
import { CTA } from '../lib/cta';
import { SEO_ROUTES } from '../lib/seo';

const aboutPrinciples = [
  {
    number: '01',
    title: 'Clarity over everything',
    description:
      'Your offer has to be readable the moment someone lands. Not buried, not vague. If they have to work for it, they are already gone.',
  },
  {
    number: '02',
    title: "Proof closes deals. Polish doesn't.",
    description: 'Real results, real reviews, and real work shown early. That is what converts a visitor into a call.',
  },
  {
    number: '03',
    title: 'Slow sites lose jobs.',
    description:
      'Most people find you on their phone. If your site takes more than two seconds, they have already moved on. Every build we ship loads fast - tested, not assumed.',
  },
] as const;
---

<SiteLayout title={SEO_ROUTES.about.title} description={SEO_ROUTES.about.description} canonicalPath="/about">
  <main id="main-content" tabindex="-1" class="axiom-container w-full pb-16 md:pb-20">
    <section class="pt-10 md:pt-16">
      <article class="overflow-hidden rounded-[var(--radius-card)] border border-white/10 bg-white/[0.02] p-6 shadow-[0_18px_52px_rgba(0,0,0,0.18)] md:p-8 lg:p-10">
        <div class="max-w-4xl">
          <p class="section-eyebrow">About</p>
          <h1 class="mt-3 text-[clamp(2.35rem,5.8vw,4.35rem)] font-extrabold leading-[0.96] tracking-tight text-[#F2F4F7]">
            We build sites that earn attention before anyone explains them.
          </h1>
          <p class="mt-5 max-w-2xl text-base leading-relaxed text-slate-200/90 md:text-lg">
            You do not need more pages, better fonts, or a redesign for the sake of it. You need a site where someone
            lands, immediately gets what you do, and knows exactly how to reach you. That is the only problem we solve -
            and we solve it completely.
          </p>
          <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a href="/start-a-project" class="btn-primary btn-lg w-full whitespace-nowrap sm:w-auto">
              Start a project
            </a>
          </div>
        </div>
      </article>
    </section>

    <section class="pt-10 md:pt-16">
      <article class="overflow-hidden rounded-[var(--radius-card)] border border-white/10 bg-white/[0.02]">
        <div class="grid lg:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)] lg:items-stretch">
          <div class="p-6 md:p-8 lg:p-10">
            <p class="section-eyebrow">What the work does</p>
            <h2 class="mt-2 max-w-2xl text-3xl font-bold tracking-tight text-[#F2F4F7] md:text-5xl">
              The work is done when the site does not need explaining.
            </h2>
            <p class="mt-4 max-w-2xl text-[15px] leading-relaxed text-slate-300 md:text-sm md:text-base">
              Most sites do not need more pages or more effects. They need the offer to read clearly, proof to appear
              early, and the next step to stay obvious.
            </p>

            <div class="mt-8">
              <a href={CTA.work.to} class="inline-flex items-center text-[15px] font-semibold tracking-[0.14em] text-white/70 transition-colors hover:text-white md:text-sm">
                See the work →
              </a>
            </div>
          </div>

          <div class="border-t border-white/10 p-4 md:p-6 lg:border-l lg:border-t-0 lg:p-6">
            <div class="overflow-hidden rounded-[var(--radius-card)] border border-white/10 bg-[linear-gradient(180deg,rgba(16,21,31,0.96)_0%,rgba(10,13,19,0.98)_100%)] p-2">
              <div class="divide-y divide-white/10">
                <div class="grid gap-2 px-5 py-5 md:grid-cols-[4rem_minmax(0,1fr)] md:gap-5 md:px-6 md:py-6">
                  <div class="font-axiomMono text-[15px] md:text-xs uppercase tracking-[0.18em] text-[#A7B3BC] md:pt-1">01</div>
                  <div>
                    <p class="text-[15px] md:text-sm font-semibold text-[#F2F4F7]">
                      What you do, who you serve, and why you are the right call - readable before they scroll.
                    </p>
                    <p class="mt-2 text-[15px] md:text-sm leading-6 text-slate-300">
                      Not five clicks in. Not buried. Front and center, the moment someone lands.
                    </p>
                  </div>
                </div>
                <div class="grid gap-2 px-5 py-5 md:grid-cols-[4rem_minmax(0,1fr)] md:gap-5 md:px-6 md:py-6">
                  <div class="font-axiomMono text-[15px] md:text-xs uppercase tracking-[0.18em] text-[#A7B3BC] md:pt-1">02</div>
                  <div>
                    <p class="text-[15px] md:text-sm font-semibold text-[#F2F4F7]">Your reviews, past work, and results are front and center.</p>
                    <p class="mt-2 text-[15px] md:text-sm leading-6 text-slate-300">Doubt does not get a chance.</p>
                  </div>
                </div>
                <div class="grid gap-2 px-5 py-5 md:grid-cols-[4rem_minmax(0,1fr)] md:gap-5 md:px-6 md:py-6">
                  <div class="font-axiomMono text-[15px] md:text-xs uppercase tracking-[0.18em] text-[#A7B3BC] md:pt-1">03</div>
                  <div>
                    <p class="text-[15px] md:text-sm font-semibold text-[#F2F4F7]">One path forward.</p>
                    <p class="mt-2 text-[15px] md:text-sm leading-6 text-slate-300">Call, book, or request a quote - no hunting, no dead ends.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </article>
    </section>

    <section class="pt-10 md:pt-16">
      <article class="overflow-hidden rounded-[var(--radius-card)] border border-white/10 bg-white/[0.02] p-6 shadow-[0_18px_52px_rgba(0,0,0,0.18)] md:p-8 lg:p-10">
        <div class="max-w-4xl">
          <p class="section-eyebrow">The team</p>
          <h2 class="mt-2 max-w-3xl text-3xl font-bold tracking-tight text-[#F2F4F7] md:text-5xl">
            Built by two people who are serious about this.
          </h2>
        </div>

        <div class="mt-8 rounded-[var(--radius-card)] border border-white/5 bg-white/[0.01] p-3 md:mt-10 lg:p-4">
          <div class="flex flex-col gap-4 md:flex-row md:flex-wrap">
            <article class="flex min-w-[16rem] flex-1 items-start gap-4 rounded-[var(--radius-card)] border border-white/10 bg-[linear-gradient(180deg,rgba(15,19,28,0.96)_0%,rgba(9,11,16,0.99)_100%)] p-5 shadow-[0_8px_24px_rgba(0,0,0,0.12)] md:min-w-[18rem] md:p-6">
              <img
                src="/photos/aidan-headshot.jpg"
                alt="Aidan headshot"
                class="h-16 w-16 shrink-0 rounded-full border border-white/10 object-cover shadow-[0_0_0_1px_rgba(255,255,255,0.08)]"
                loading="lazy"
                decoding="async"
              />
              <div class="min-w-0">
                <h3 class="text-[18px] font-semibold tracking-tight text-[#F2F4F7]">Aidan</h3>
                <p class="text-sm leading-relaxed text-slate-300 md:text-[15px]">Co-founder - strategy, systems, client work</p>
                <p class="mt-3 text-sm leading-relaxed text-slate-400 md:text-[15px]">
                  Aidan keeps the project anchored to the business goal, the offer, and the next step a customer should
                  take. He handles the strategy, scope, and client communication so the work stays clear from first call
                  to launch.
                </p>
              </div>
            </article>

            <article class="flex min-w-[16rem] flex-1 items-start gap-4 rounded-[var(--radius-card)] border border-white/10 bg-[linear-gradient(180deg,rgba(15,19,28,0.96)_0%,rgba(9,11,16,0.99)_100%)] p-5 shadow-[0_8px_24px_rgba(0,0,0,0.12)] md:min-w-[18rem] md:p-6">
              <img
                src="/photos/riley-headshot.jpg"
                alt="Riley headshot"
                class="h-16 w-16 shrink-0 rounded-full border border-white/10 object-cover shadow-[0_0_0_1px_rgba(255,255,255,0.08)]"
                loading="lazy"
                decoding="async"
              />
              <div class="min-w-0">
                <h3 class="text-[18px] font-semibold tracking-tight text-[#F2F4F7]">Riley</h3>
                <p class="text-sm leading-relaxed text-slate-300 md:text-[15px]">Co-founder - design, build, technical delivery</p>
                <p class="mt-3 text-sm leading-relaxed text-slate-400 md:text-[15px]">
                  Riley translates the strategy into the actual site, from visual direction through implementation. He
                  handles design, build quality, and technical delivery so the final result stays fast, stable, and
                  clean.
                </p>
              </div>
            </article>
          </div>
        </div>

        <p class="mt-6 max-w-3xl text-[15px] leading-relaxed text-slate-300 md:text-sm md:text-base">
          We are based in Kitchener-Waterloo. We do not use templates, we do not outsource, and we do not take on
          projects we cannot do well. Every site is built by us.
        </p>
      </article>
    </section>

    <section class="pt-10 md:pt-16">
      <article class="overflow-hidden rounded-[var(--radius-card)] border border-white/10 bg-white/[0.02] p-6 shadow-[0_18px_52px_rgba(0,0,0,0.18)] md:p-8 lg:p-10">
        <div class="max-w-4xl">
          <p class="section-eyebrow">Our approach</p>
          <h2 class="mt-2 max-w-3xl text-3xl font-bold tracking-tight text-[#F2F4F7] md:text-5xl">
            Three principles that shape every build.
          </h2>
          <p class="mt-4 max-w-3xl text-[15px] leading-relaxed text-slate-300 md:text-sm md:text-base">
            The site has to read clearly, prove the point early, and make the next step obvious.
          </p>
        </div>

        <div class="mt-8 grid gap-4 md:grid-cols-3">
          {aboutPrinciples.map((principle) => (
            <article class="machined-card h-full rounded-[var(--radius-card)] border border-white/10 bg-[var(--axiom-elevated)] p-6 md:p-7">
              <p class="font-axiomMono text-xs uppercase tracking-wide text-[#d4a48e]">{principle.number}</p>
              <h3 class="mt-3 text-[1.05rem] font-semibold tracking-tight text-[#F2F4F7]">{principle.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-slate-300 md:text-[15px]">{principle.description}</p>
            </article>
          ))}
        </div>
      </article>
    </section>
  </main>
</SiteLayout>
