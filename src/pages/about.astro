---
import SiteLayout from '../layouts/SiteLayout.astro';
import { CTA_PATHS } from '../lib/cta';
import { SEO_ROUTES, ABOUT_JSON_LD } from '../lib/seo';
import { FadeIn } from '../components/ui/FadeIn';
import { Button } from '../components/ui/button';
import { Card } from '../components/ui/card';
import { Eyebrow } from '../components/ui/Eyebrow';
import { MotionHeading } from '../components/motion/MotionHeading';
import { SectionDivider } from '../components/motion/SectionDivider';
import DrawIcon from '../components/ui/DrawIcon.astro';

const whyAxiom = [
  {
    number: '01',
    title: 'The offer is obvious in three seconds.',
    description: "Visitors shouldn't have to hunt for what you do or why to pick you.",
  },
  {
    number: '02',
    title: 'Reviews, past work, and results front and center.',
    description: 'Proof shows up early - before doubt has time to build.',
  },
  {
    number: '03',
    title: 'One clear next step. And support after launch.',
    description: 'Monthly clients stay supported. Nothing gets handed off and forgotten.',
  },
] as const;

const team = [
  {
    name: 'Aidan',
    monogram: 'aidan',
    roles: ['STRATEGY', 'SCOPE', 'CLIENT SUPPORT'],
    description:
      'Strategy, scope, and client support. Keeps the work tied to the business goal from first call through launch and beyond.',
  },
  {
    name: 'Riley',
    monogram: 'riley',
    roles: ['DESIGN', 'BUILD', 'QA'],
    description:
      'Design, build, and QA. Turns the strategy into a site that loads fast, works clean, and holds up under traffic.',
  },
] as const;

const principles = [
  {
    number: '01',
    title: 'Clarity first.',
    icon: 'eye',
    description:
      "If the offer isn't readable in three seconds, the site is already losing. Polish comes after.",
  },
  {
    number: '02',
    title: 'Proof moves buyers.',
    icon: 'shield-check',
    description:
      'Real reviews, real past jobs, real results - all above the fold, not hidden in a footer.',
  },
  {
    number: '03',
    title: 'Speed books work.',
    icon: 'bolt',
    description:
      "Most visitors are on a phone. If it drags, they're gone. We test load times before launch - every time.",
  },
] as const;
---

<SiteLayout title={SEO_ROUTES.about.title} description={SEO_ROUTES.about.description} canonicalPath="/about" schema={ABOUT_JSON_LD}>
  <main id="main-content" tabindex="-1" class="-mt-28 md:-mt-32 pb-24 md:pb-32">
    <section class="axiom-container pt-24 md:pt-32">
      <div class="max-w-3xl">
        <FadeIn client:load>
          <Eyebrow>ABOUT</Eyebrow>
          <SectionDivider className="mt-6" />
        </FadeIn>
        <FadeIn client:load delay={100}>
          <MotionHeading as="h1" text="We build sites that do the selling for you." className="mt-4 max-w-4xl" />
        </FadeIn>
        <FadeIn client:load delay={200}>
          <p class="section-copy mt-5 md:text-[17px]">
            Axiom builds for established businesses across every sector - trades, medical, legal, food, retail,
            professional services. One thing in common: they want a site that books work, not one that just looks
            nice.
          </p>
        </FadeIn>
        <FadeIn client:load delay={300} className="mt-7">
          <Button asChild size="lg">
            <a href={CTA_PATHS.startProject}>Start a project</a>
          </Button>
        </FadeIn>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container grid gap-6 xl:grid-cols-[minmax(0,0.96fr)_minmax(0,1.04fr)] xl:items-start xl:gap-8">
        <FadeIn client:load as="div" className="space-y-5">
          <Eyebrow>WHY AXIOM</Eyebrow>
          <SectionDivider className="mt-6" />
          <MotionHeading as="h2" text="Launch isn't the finish line." className="section-heading mt-4" />
          <p class="section-copy md:text-[17px]">
            Most sites don't need more pages or more animations. They need a clear offer, proof up front, and
            support that keeps the site earning long after launch.
          </p>
          <Button asChild variant="ghost" className="px-0">
            <a href="/work">See real builds</a>
          </Button>
        </FadeIn>

        <Card className="p-0">
          <div class="p-6 sm:p-7">
            {whyAxiom.map((item, index) => (
              <FadeIn client:load as="div" delay={Math.min(index * 100, 400)} className={`grid gap-4 py-5 first:pt-0 last:pb-0 sm:grid-cols-[4rem_minmax(0,1fr)] ${index > 0 ? 'border-t border-[color:var(--hairline)]' : ''}`}>
                <div class="relative sm:pt-1">
                  <span
                    aria-hidden="true"
                    class="absolute left-0 top-0 h-full w-px origin-top bg-[color:var(--accent-solid)]/40"
                  ></span>
                  <div class="axiom-metric text-[var(--accent-solid)]">{item.number}</div>
                </div>
                <div>
                  <p class="text-[15px] font-semibold tracking-[-0.01em] text-[var(--text-primary)]">{item.title}</p>
                  <p class="section-copy mt-2">{item.description}</p>
                </div>
              </FadeIn>
            ))}
          </div>
        </Card>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <div class="max-w-3xl">
          <FadeIn client:load>
            <Eyebrow>THE TEAM</Eyebrow>
          </FadeIn>
          <FadeIn client:load delay={100}>
            <SectionDivider className="mt-6" />
            <MotionHeading as="h2" text="Two operators. Clear roles. Short chain of command." className="section-heading mt-4" />
          </FadeIn>
          <FadeIn client:load delay={200}>
            <p class="section-copy mt-3 md:text-[17px]">
              Based in Kitchener-Waterloo. Working with clients across Canada and beyond. The relationship doesn't end
              at launch.
            </p>
          </FadeIn>
        </div>

        <div class="mt-10 grid gap-5 lg:grid-cols-2">
          {team.map((member, index) => (
            <FadeIn client:load delay={Math.min(index * 100, 400)}>
              <Card className="group rounded-2xl border-[color:var(--hairline)] bg-[color:var(--surface-overlay)] p-8 transition-all duration-300 hover:border-[color:var(--hairline-strong)] hover:bg-[color:var(--surface-overlay-press)]">
                <div class="flex h-full flex-col">
                  <div class="flex items-start gap-4">
                    <div
                      aria-hidden="true"
                      class="relative flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-[color:var(--accent-border)] bg-[color:var(--surface-overlay)] shadow-[inset_0_1px_0_rgba(255,255,255,0.05),0_8px_24px_rgba(0,0,0,0.14)]"
                    >
                      <span aria-hidden="true" class="animate-ring-pulse absolute inset-0 rounded-full border border-[color:var(--accent-solid)]/40 opacity-0 transition-all duration-700 group-hover:scale-[1.2] group-hover:opacity-0 motion-safe:animate-none"></span>
                      {member.monogram === 'aidan' ? (
                        <svg
                          viewBox="0 0 48 48"
                          class="h-12 w-12 text-[var(--accent-solid)]"
                          fill="currentColor"
                          aria-hidden="true"
                        >
                          <path d="M24 8L9 38h7l3.1-6h9.8l3.1 6h7L24 8zm-3 17 3-6 3 6h-6z" />
                        </svg>
                      ) : (
                        <svg
                          viewBox="0 0 48 48"
                          class="h-12 w-12 text-[var(--accent-solid)]"
                          fill="currentColor"
                          aria-hidden="true"
                        >
                          <path d="M13 38V10h14.2c6.8 0 10.8 3.3 10.8 8.6 0 4.2-2.4 7-6.3 8.1l7.1 11.3h-7.8l-6-10H20v10h-7zm7-15h6.7c3.1 0 4.7-1.2 4.7-3.8s-1.6-3.9-4.7-3.9H20V23z" />
                        </svg>
                      )}
                    </div>

                    <div class="min-w-0">
                      <h3 class="text-xl font-semibold text-[var(--text-primary)]">{member.name}</h3>
                      <div class="mt-3 flex flex-wrap gap-1">
                        {member.roles.map((role) => (
                          <span class="rounded-full bg-[color:var(--surface-overlay-press)] px-2 py-0.5 text-[12px] uppercase tracking-widest text-[var(--text-secondary)]">
                            {role}
                          </span>
                        ))}
                      </div>
                    </div>
                  </div>

                  <p class="mt-6 text-[15px] leading-[1.7] text-[var(--text-secondary)]">
                    {member.description}
                  </p>
                </div>
              </Card>
            </FadeIn>
          ))}
        </div>

      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <div class="max-w-3xl">
          <FadeIn client:load>
            <Eyebrow>OUR APPROACH</Eyebrow>
          </FadeIn>
          <FadeIn client:load delay={100}>
            <h2 class="section-heading mt-4">Three rules. Every build.</h2>
          </FadeIn>
        </div>

        <div class="mt-10 grid gap-5 md:grid-cols-3">
          {principles.map((principle, index) => (
            <FadeIn client:load delay={Math.min(index * 100, 400)}>
              <Card className="h-full p-0">
                <div class="flex h-full flex-col p-6 sm:p-7">
                  <DrawIcon name={principle.icon} className="mb-4" />
                  <Eyebrow>{principle.number}</Eyebrow>
                  <h3 class="mt-4 text-[22px] font-semibold tracking-[-0.01em] text-[var(--text-primary)]">
                    {principle.title}
                  </h3>
                  <p class="section-copy mt-4">{principle.description}</p>
                </div>
              </Card>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <FadeIn client:load>
          <Card className="mx-auto max-w-6xl border-[color:var(--hairline)] bg-[var(--surface-2)] p-0">
            <div class="flex flex-col gap-6 px-6 py-8 sm:px-8 sm:py-10 md:px-10 md:py-12 lg:flex-row lg:items-end lg:justify-between">
              <div class="max-w-3xl">
                <SectionDivider className="mb-6" />
                <MotionHeading as="h2" text="Seen enough?" className="section-heading" />
                <p class="section-copy mt-4 md:text-[17px]">
                  Tell us what the business needs. Monthly or one-time, we'll point you to the right path - one
                  business day, no pitch.
                </p>
              </div>

              <Button asChild size="lg" className="w-full lg:w-auto">
                <a href={CTA_PATHS.startProject}>Start a project</a>
              </Button>
            </div>
          </Card>
        </FadeIn>
      </div>
    </section>
  </main>
</SiteLayout>

<style>
  .group:hover [aria-hidden='true'].animate-ring-pulse {
    animation: ring-pulse 0.8s ease-out 1;
  }

  @keyframes ring-pulse {
    0% {
      transform: scale(1);
      opacity: 0.45;
    }

    100% {
      transform: scale(1.35);
      opacity: 0;
    }
  }
</style>

