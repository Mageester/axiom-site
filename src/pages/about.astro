---
import SiteLayout from '../layouts/SiteLayout.astro';
import { CTA_PATHS } from '../lib/cta';
import { SEO_ROUTES, ABOUT_JSON_LD, breadcrumbSchema, SITE_URL } from '../lib/seo';
import { FadeIn } from '../components/ui/FadeIn';
import { Button } from '../components/ui/button';
import { Card } from '../components/ui/card';
import { Eyebrow } from '../components/ui/Eyebrow';
import { MotionHeading } from '../components/motion/MotionHeading';
import { SectionDivider } from '../components/motion/SectionDivider';
import DrawIcon from '../components/ui/DrawIcon.astro';

const whyAxiom = [
  {
    number: '01',
    title: 'Booking is the product.',
    description: "If the booking button is buried, the site is leaking revenue. We treat it as the most important pixel.",
  },
  {
    number: '02',
    title: 'Proof sits next to the decision.',
    description: 'Reviews, credentials, and photos go where buyers actually look — beside the price, the service, the call button.',
  },
  {
    number: '03',
    title: 'One support path. Two people who answer.',
    description: 'No agency phone tree. Reply within one business day from the same two people who built the site.',
  },
] as const;

const team = [
  {
    name: 'Aidan',
    monogram: 'aidan',
    roles: ['STRATEGY', 'SCOPE', 'CLIENT SUPPORT'],
    description:
      'Your first point of contact. Keeps the project tied to what the business actually needs, from first call through launch.',
  },
  {
    name: 'Riley',
    monogram: 'riley',
    roles: ['DESIGN', 'BUILD', 'QA'],
    description:
      'Builds the site. Handles design, development, and testing so the final product loads fast, works on every device, and holds up under real traffic.',
  },
] as const;

const principles = [
  {
    number: '01',
    title: 'Five-second offer.',
    icon: 'eye',
    description:
      "What you do, who you serve, how to book — readable before the first scroll. No hunting through menus.",
  },
  {
    number: '02',
    title: 'Proof beside the decision.',
    icon: 'shield-check',
    description:
      'Reviews, credentials, and real photos placed next to the booking button — not buried in a carousel.',
  },
  {
    number: '03',
    title: 'Mobile is the site.',
    icon: 'bolt',
    description:
      "Most appointment bookings start on a phone. Tap targets, load speed, and form quality are tested on real devices before launch.",
  },
] as const;
---

<SiteLayout
  title={SEO_ROUTES.about.title}
  description={SEO_ROUTES.about.description}
  canonicalPath="/about"
  schema={[ABOUT_JSON_LD, breadcrumbSchema([{ name: 'Home', url: SITE_URL }, { name: 'About', url: `${SITE_URL}/about` }])]}
>
  <main id="main-content" tabindex="-1" class="-mt-28 pb-0 md:-mt-32">
    <section class="axiom-container pt-20 md:pt-28">
      <div class="max-w-3xl">
        <FadeIn motion="eyebrow">
          <Eyebrow>ABOUT</Eyebrow>
          <SectionDivider className="mt-6" />
        </FadeIn>
        <FadeIn motion="sceneOpen" delay={180}>
          <MotionHeading as="h1" text="Two people. Built for businesses that *live or die by bookings*." className="mt-4 max-w-4xl" />
        </FadeIn>
        <FadeIn motion="editorialMaskReveal" delay={500}>
          <p class="section-copy mt-5 md:text-[17px]">
            Axiom builds high-trust websites for local appointment-based businesses — dental, beauty, fitness,
            clinics, studios, trades. Based in Kitchener-Waterloo, serving Canada. No account managers, no offshore
            handoffs. You talk to the people doing the work.
          </p>
        </FadeIn>
        <FadeIn motion="sceneOpen" delay={720} className="mt-7">
          <Button asChild variant="ghost" size="lg" className="px-0">
            <a href="/process">See how we work</a>
          </Button>
        </FadeIn>
      </div>
    </section>

    <div aria-hidden="true" class="section-glow section-glow-offset-top" />

    <section class="page-section section-shell">
      <div class="axiom-container grid gap-6 xl:grid-cols-[minmax(0,0.96fr)_minmax(0,1.04fr)] xl:items-start xl:gap-8">
        <FadeIn as="div" motion="editorialMaskReveal" className="space-y-5">
          <Eyebrow>WHY AXIOM</Eyebrow>
          <SectionDivider className="mt-6" />
          <MotionHeading as="h2" text="Launch isn't the finish line." className="section-heading mt-4" />
          <p class="section-copy md:text-[17px]">
            If the booking button isn't winning, more pages and more animations won't fix it. We focus on what makes
            a buyer pick up the phone or hit "book now" — and keep the site supported after launch so it stays sharp.
          </p>
          <Button asChild variant="ghost" className="px-0">
            <a href="/work">See concept builds</a>
          </Button>
        </FadeIn>

        <Card className="p-0">
          <div class="p-6 sm:p-7">
            {whyAxiom.map((item, index) => (
              <FadeIn as="div" motion="timelineSequence" delay={Math.min(index * 160, 640)} className={`grid gap-4 py-5 first:pt-0 last:pb-0 sm:grid-cols-[4rem_minmax(0,1fr)] ${index > 0 ? 'border-t border-[color:var(--hairline)]' : ''}`}>
                <div class="relative sm:pt-1">
                  <span
                    aria-hidden="true"
                    class="about-principle-line absolute left-0 top-0 h-full w-px origin-top bg-[color:var(--accent-solid)]/40"
                  ></span>
                  <div class="axiom-metric text-[var(--accent-solid)]">{item.number}</div>
                </div>
                <div>
                  <p class="text-[15px] font-semibold tracking-normal text-[var(--text-primary)]">{item.title}</p>
                  <p class="section-copy mt-2">{item.description}</p>
                </div>
              </FadeIn>
            ))}
          </div>
        </Card>
      </div>
    </section>

    <div aria-hidden="true" class="section-glow section-glow-offset-top" />

    <section class="page-section section-shell">
      <div class="axiom-container">
        <div class="max-w-3xl">
          <FadeIn motion="editorialMaskReveal">
            <Eyebrow>THE TEAM</Eyebrow>
          </FadeIn>
          <FadeIn motion="editorialMaskReveal" delay={120}>
            <SectionDivider className="mt-6" />
            <MotionHeading as="h2" text="Two people. Clear roles. You always know who to call." className="section-heading mt-4" />
          </FadeIn>
          <FadeIn motion="editorialMaskReveal" delay={260}>
            <p class="section-copy mt-3 md:text-[17px]">
              Based in Kitchener-Waterloo. Working with clients across Canada and beyond. The relationship doesn't end
              at launch.
            </p>
          </FadeIn>
        </div>

        <div class="mt-10 grid gap-5 lg:grid-cols-2">
          {team.map((member, index) => (
            <FadeIn motion="depthCardReveal" delay={Math.min(index * 160, 640)}>
              <Card className="group rounded-2xl border-[color:var(--hairline)] bg-[color:var(--surface-overlay)] p-8 transition-all duration-300 hover:border-[color:var(--hairline-strong)] hover:bg-[color:var(--surface-overlay-press)]">
                <div class="flex h-full flex-col">
                  <div class="flex items-start gap-4">
                    <div
                      aria-hidden="true"
                      class="relative flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-[color:var(--accent-border)] bg-[color:var(--surface-overlay)] shadow-[inset_0_1px_0_rgba(255,255,255,0.05),0_8px_24px_rgba(0,0,0,0.14)]"
                    >
                      <span aria-hidden="true" class="animate-ring-pulse absolute inset-0 rounded-full border border-[color:var(--accent-solid)]/40 opacity-0 transition-all duration-700 group-hover:scale-[1.2] group-hover:opacity-0 motion-safe:animate-none"></span>
                      {member.monogram === 'aidan' ? (
                        <svg
                          viewBox="0 0 48 48"
                          class="h-12 w-12 text-[var(--accent-solid)]"
                          fill="currentColor"
                          aria-hidden="true"
                        >
                          <path d="M24 8L9 38h7l3.1-6h9.8l3.1 6h7L24 8zm-3 17 3-6 3 6h-6z" />
                        </svg>
                      ) : (
                        <svg
                          viewBox="0 0 48 48"
                          class="h-12 w-12 text-[var(--accent-solid)]"
                          fill="currentColor"
                          aria-hidden="true"
                        >
                          <path d="M13 38V10h14.2c6.8 0 10.8 3.3 10.8 8.6 0 4.2-2.4 7-6.3 8.1l7.1 11.3h-7.8l-6-10H20v10h-7zm7-15h6.7c3.1 0 4.7-1.2 4.7-3.8s-1.6-3.9-4.7-3.9H20V23z" />
                        </svg>
                      )}
                    </div>

                    <div class="min-w-0">
                      <h3 class="text-xl font-semibold text-[var(--text-primary)]">{member.name}</h3>
                      <div class="mt-3 flex flex-wrap gap-1">
                        {member.roles.map((role) => (
                          <span class="rounded-full bg-[color:var(--surface-overlay-press)] px-2 py-0.5 text-[12px] uppercase tracking-widest text-[var(--text-secondary)]">
                            {role}
                          </span>
                        ))}
                      </div>
                    </div>
                  </div>

                  <p class="mt-6 text-[15px] leading-[1.7] text-[var(--text-secondary)]">
                    {member.description}
                  </p>
                </div>
              </Card>
            </FadeIn>
          ))}
        </div>

      </div>
    </section>

    <div aria-hidden="true" class="section-glow section-glow-offset-top" />

    <section class="page-section section-shell">
      <div class="axiom-container">
        <div class="max-w-3xl">
          <FadeIn motion="editorialMaskReveal">
            <Eyebrow>OUR APPROACH</Eyebrow>
            <SectionDivider className="mt-6" />
          </FadeIn>
          <FadeIn motion="editorialMaskReveal" delay={120}>
            <h2 class="section-heading mt-4">Three rules. Every build.</h2>
          </FadeIn>
        </div>

        <div class="mt-10 grid gap-5 md:grid-cols-3">
          {principles.map((principle, index) => (
            <FadeIn motion="depthCardReveal" delay={Math.min(index * 140, 560)}>
              <Card className="h-full p-0">
                <div class="flex h-full flex-col p-6 sm:p-7">
                  <DrawIcon name={principle.icon} className="mb-4" />
                  <Eyebrow>{principle.number}</Eyebrow>
                  <h3 class="mt-4 text-[22px] font-semibold tracking-normal text-[var(--text-primary)]">
                    {principle.title}
                  </h3>
                  <p class="section-copy mt-4">{principle.description}</p>
                </div>
              </Card>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <div aria-hidden="true" class="section-glow section-glow-offset-top" />

    <section class="page-section-tight section-shell">
      <div class="axiom-container">
        <FadeIn motion="finalFrameFooter">
          <Card className="mx-auto max-w-6xl border-[color:var(--hairline)] bg-[var(--surface-2)] p-0">
            <div class="flex flex-col gap-6 px-6 py-8 sm:px-8 sm:py-10 md:px-10 md:py-12 lg:flex-row lg:items-end lg:justify-between">
              <div class="max-w-3xl">
                <SectionDivider className="mb-6" />
                <MotionHeading as="h2" text="Let's build something your buyers trust." className="section-heading" />
                <p class="section-copy mt-4 md:text-[17px]">
                  Tell us what the business needs. Monthly or one-time, we'll scope the right path — one
                  business day, no pitch deck.
                </p>
              </div>

              <Button asChild size="lg" className="w-full lg:w-auto">
                <a href={CTA_PATHS.startProject}>Start a project</a>
              </Button>
            </div>
          </Card>
        </FadeIn>
      </div>
    </section>
  </main>
</SiteLayout>

<style>
  .group:hover [aria-hidden='true'].animate-ring-pulse {
    animation: ring-pulse 0.8s ease-out 1;
  }

  @keyframes ring-pulse {
    0% {
      transform: scale(1);
      opacity: 0.45;
    }

    100% {
      transform: scale(1.35);
      opacity: 0;
    }
  }
</style>

