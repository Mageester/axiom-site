---
import SiteLayout from '../layouts/SiteLayout.astro';
import { CTA_PATHS } from '../lib/cta';
import { SEO_ROUTES, ABOUT_JSON_LD } from '../lib/seo';
import { FadeIn } from '../components/ui/FadeIn';
import { Button } from '../components/ui/button';
import { Card } from '../components/ui/card';
import { Eyebrow } from '../components/ui/Eyebrow';

const whatTheWorkDoes = [
  {
    number: '01',
    title: 'What you do, who you serve, and why you are the right call.',
    description: 'Readable before they scroll. Not buried.',
  },
  {
    number: '02',
    title: 'Reviews, past work, and results front and center.',
    description: 'Doubt does not get a chance.',
  },
  {
    number: '03',
    title: 'One path forward.',
    description: 'Call, book, or request a quote. No hunting, no dead ends.',
  },
] as const;

const team = [
  {
    name: 'Aidan',
    role: 'Strategy / Systems / Client Work',
    description:
      'Keeps the work tied to the business goal, the scope, and the next step. Handles strategy and communication from first call to launch.',
  },
  {
    name: 'Riley',
    role: 'Design / Build / Delivery',
    description:
      'Turns the strategy into the site itself. Handles design, build quality, and delivery so the result stays fast, stable, and clean.',
  },
] as const;

const principles = [
  {
    number: '01',
    title: 'Clarity over everything',
    description:
      'If the offer is not readable in a few seconds, the site is already losing. Clarity comes before polish.',
  },
  {
    number: '02',
    title: 'Proof closes deals',
    description:
      'Real work, real reviews, and real results should show up early. That is what moves a visitor toward a call.',
  },
  {
    number: '03',
    title: 'Slow sites lose jobs',
    description:
      'Most people are on a phone. If the site drags, they leave. We build for speed and verify it before launch.',
  },
] as const;
---

<SiteLayout title={SEO_ROUTES.about.title} description={SEO_ROUTES.about.description} canonicalPath="/about" schema={ABOUT_JSON_LD}>
  <main id="main-content" tabindex="-1" class="-mt-28 md:-mt-32 pb-24 md:pb-32">
    <section class="axiom-container pt-12 md:pt-20">
      <div class="max-w-3xl">
        <FadeIn client:load>
          <Eyebrow>ABOUT</Eyebrow>
        </FadeIn>
        <FadeIn client:load delay={100}>
          <h1 class="mt-4 max-w-4xl">
            We build sites that earn attention before anyone explains them.
          </h1>
        </FadeIn>
        <FadeIn client:load delay={200}>
          <p class="mt-5 max-w-3xl text-[15px] leading-[1.65] text-[var(--text-secondary)] md:text-[17px]">
            You do not need more pages, better fonts, or a redesign for its own sake. You need a site that lands the
            offer instantly and routes the right people to the right action. That is the only problem we solve.
          </p>
        </FadeIn>
        <FadeIn client:load delay={300} className="mt-7">
          <Button asChild size="lg">
            <a href={CTA_PATHS.startProject}>Start a project</a>
          </Button>
        </FadeIn>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container grid gap-6 xl:grid-cols-[minmax(0,0.96fr)_minmax(0,1.04fr)] xl:items-start xl:gap-8">
        <FadeIn client:load as="div" className="space-y-5">
          <Eyebrow>WHAT THE WORK DOES</Eyebrow>
          <h2 class="max-w-2xl">The work is done when the site does not need explaining.</h2>
          <p class="max-w-2xl text-[15px] leading-[1.65] text-[var(--text-secondary)] md:text-[17px]">
            Most sites do not need more pages or more effects. They need the offer to read clearly, proof to appear
            early, and the next step to stay obvious.
          </p>
          <Button asChild variant="ghost" className="px-0">
            <a href="/work">See the work</a>
          </Button>
        </FadeIn>

        <Card className="p-0">
          <div class="p-6 sm:p-7">
            {whatTheWorkDoes.map((item, index) => (
              <FadeIn client:load as="div" delay={Math.min(index * 100, 400)} className={`grid gap-4 py-5 first:pt-0 last:pb-0 sm:grid-cols-[4rem_minmax(0,1fr)] ${index > 0 ? 'border-t border-[color:var(--hairline)]' : ''}`}>
                <div class="axiom-metric text-[var(--text-muted)] sm:pt-1">{item.number}</div>
                <div>
                  <p class="text-[15px] font-semibold tracking-[-0.01em] text-[var(--text-primary)]">{item.title}</p>
                  <p class="mt-2 text-[15px] leading-[1.65] text-[var(--text-secondary)]">{item.description}</p>
                </div>
              </FadeIn>
            ))}
          </div>
        </Card>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <div class="max-w-3xl">
          <FadeIn client:load>
            <Eyebrow>THE TEAM</Eyebrow>
          </FadeIn>
          <FadeIn client:load delay={100}>
            <h2 class="mt-4 max-w-3xl">Built by two operators who take this seriously.</h2>
          </FadeIn>
        </div>

        <div class="mt-10 grid gap-5 lg:grid-cols-2">
          {team.map((member, index) => (
            <FadeIn client:load delay={Math.min(index * 100, 400)}>
              <Card className="p-0">
              <div class="flex h-full items-start gap-4 p-6 sm:p-7">
                <div
                  aria-hidden="true"
                  class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full border border-[color:var(--hairline)] bg-[color:var(--surface-overlay)]"
                >
                  <span class="flex h-7 w-7 items-center justify-center rounded-[8px] bg-[var(--accent-solid)] shadow-[0_0_0_4px_var(--accent-surface-alt)]">
                    <span class="h-3.5 w-3.5 rounded-[3px] bg-[var(--bg-base)]" />
                  </span>
                </div>

                <div class="min-w-0">
                  <h3 class="text-[22px] font-semibold tracking-[-0.01em] text-[var(--text-primary)]">{member.name}</h3>
                  <p class="mt-2 font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--text-secondary)]">
                    {member.role}
                  </p>
                  <p class="mt-4 max-w-[34ch] text-[15px] leading-[1.65] text-[var(--text-secondary)]">
                    {member.description}
                  </p>
                </div>
              </div>
              </Card>
            </FadeIn>
          ))}
        </div>

        <FadeIn client:load delay={200}>
          <p class="mt-6 max-w-4xl text-[15px] leading-[1.65] text-[var(--text-secondary)] md:text-[17px]">
            Based in Kitchener-Waterloo. Serving businesses globally. No templates, no outsourcing, no projects we cannot do well.
          </p>
        </FadeIn>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <div class="max-w-3xl">
          <FadeIn client:load>
            <Eyebrow>OUR APPROACH</Eyebrow>
          </FadeIn>
          <FadeIn client:load delay={100}>
            <h2 class="mt-4 max-w-3xl">Three principles that shape every build.</h2>
          </FadeIn>
        </div>

        <div class="mt-10 grid gap-5 md:grid-cols-3">
          {principles.map((principle, index) => (
            <FadeIn client:load delay={Math.min(index * 100, 400)}>
              <Card className="h-full p-0">
              <div class="flex h-full flex-col p-6 sm:p-7">
                <Eyebrow>{principle.number}</Eyebrow>
                <h3 class="mt-4 text-[22px] font-semibold tracking-[-0.01em] text-[var(--text-primary)]">
                  {principle.title}
                </h3>
                <p class="mt-4 text-[15px] leading-[1.65] text-[var(--text-secondary)]">{principle.description}</p>
              </div>
              </Card>
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <FadeIn client:load>
          <Card className="mx-auto max-w-6xl border-[color:var(--hairline)] bg-[var(--surface-2)] p-0">
          <div class="flex flex-col gap-6 px-6 py-8 sm:px-8 sm:py-10 md:px-10 md:py-12 lg:flex-row lg:items-end lg:justify-between">
            <div class="max-w-3xl">
              <h2 class="max-w-3xl">
                Not sure where to begin?
              </h2>
              <p class="mt-4 max-w-2xl text-[15px] leading-[1.65] text-[var(--text-secondary)] md:text-[17px]">
                Start a project and we&apos;ll tell you what should change first. One business day, no pressure.
              </p>
            </div>

            <Button asChild size="lg" className="w-full lg:w-auto">
              <a href={CTA_PATHS.startProject}>Start a project</a>
            </Button>
          </div>
          </Card>
        </FadeIn>
      </div>
    </section>
  </main>
</SiteLayout>
