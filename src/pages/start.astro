---
import IntakeForm from '../components/site/IntakeForm.astro';
import { FadeIn } from '../components/ui/FadeIn';
import SiteLayout from '../layouts/SiteLayout.astro';
import { Button } from '../components/ui/button';
import { Card } from '../components/ui/card';
import { Eyebrow } from '../components/ui/Eyebrow';
import { MotionHeading } from '../components/motion/MotionHeading';
import { SectionDivider } from '../components/motion/SectionDivider';
import { CTA_PATHS } from '../lib/cta';
import { SEO_ROUTES } from '../lib/seo';
---

<SiteLayout title={SEO_ROUTES.start.title} description={SEO_ROUTES.start.description} canonicalPath={SEO_ROUTES.start.canonicalPath}>
  <main id="main-content" tabindex="-1" class="-mt-28 pb-24 md:-mt-32 md:pb-32">
    <section class="axiom-container pt-24 md:pt-32">
      <FadeIn client:load className="max-w-3xl">
        <Eyebrow>START A PROJECT</Eyebrow>
        <SectionDivider client:load className="mt-6" />
        <MotionHeading client:load as="h1" text="Tell us about the site. We'll handle the rest." className="mt-4 max-w-4xl" />
        <p class="section-copy mt-5 md:text-[17px]">
          Five short steps, about two minutes. You'll get a reply within one business day - from a real person, not
          a chatbot.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3 text-[11px] font-medium uppercase tracking-[0.14em] text-[var(--text-secondary)]">
          <span>ABOUT 2 MINUTES</span>
          <span aria-hidden="true" class="text-[var(--text-muted)]">&rarr;</span>
          <span>MONTHLY OR OWNERSHIP</span>
          <span aria-hidden="true" class="text-[var(--text-muted)]">&rarr;</span>
          <span>REPLY WITHIN ONE BUSINESS DAY</span>
        </div>

        <div class="mt-7">
          <Button asChild size="lg">
            <a href="#project-intake">Submit project brief</a>
          </Button>
        </div>
      </FadeIn>
    </section>

    <section class="page-section">
      <div class="axiom-container grid gap-6 xl:grid-cols-[minmax(0,1.18fr)_minmax(18rem,0.72fr)] xl:items-start">
        <FadeIn client:load as="div" id="project-intake" className="scroll-mt-32">
          <IntakeForm
            kind="project"
            endpoint="/api/intake"
            title="Tell us what needs to change."
            eyebrow="PROJECT INTAKE"
            description="Tell us what the business does, what&apos;s broken on the current site, and which path feels closest."
            helper="Three short lines is enough. Monthly, ownership, or not sure yet all work."
            submitLabel={`Submit project brief \u2192`}
            successTitle="Received."
            successText="We&apos;ll review and reply within one business day."
            noteLinkHref={CTA_PATHS.contact}
            noteLinkLabel="contact page"
            noteText="Need a quick question instead? Use the"
          />
        </FadeIn>

        <FadeIn client:load as="div">
          <Card className="self-start p-0 xl:sticky xl:top-28">
            <div class="p-6 sm:p-7">
              <Eyebrow>WHAT TO EXPECT</Eyebrow>
              <p class="section-copy mt-4">
                Use this form when you want to scope a real project.
              </p>
              <div class="mt-6 space-y-4 border-t border-[color:var(--hairline)] pt-5">
                <div>
                  <p class="text-[12px] font-medium uppercase tracking-[0.16em] text-[var(--text-secondary)]">Who this is for</p>
                  <p class="mt-2 text-[15px] leading-[1.7] text-[var(--text-secondary)]">Businesses ready to talk monthly or ownership website work.</p>
                </div>
                <div>
                  <p class="text-[12px] font-medium uppercase tracking-[0.16em] text-[var(--text-secondary)]">Monthly vs ownership</p>
                  <p class="mt-2 text-[15px] leading-[1.7] text-[var(--text-secondary)]">Monthly keeps the upfront cost lower. Ownership gives you full code handoff from launch.</p>
                </div>
                <div>
                  <p class="text-[12px] font-medium uppercase tracking-[0.16em] text-[var(--text-secondary)]">Timeline</p>
                  <p class="mt-2 text-[15px] leading-[1.7] text-[var(--text-secondary)]">We review the brief within one business day and outline the next step.</p>
                </div>
                <div>
                  <p class="text-[12px] font-medium uppercase tracking-[0.16em] text-[var(--text-secondary)]">After submit</p>
                  <p class="mt-2 text-[15px] leading-[1.7] text-[var(--text-secondary)]">We look at the scope, decide which path fits, and reply clearly.</p>
                </div>
              </div>
              <div class="mt-6">
                <a
                  href={CTA_PATHS.contact}
                  class="inline-flex min-h-11 items-center text-[15px] font-medium text-[var(--text-primary)] underline decoration-[color:var(--border-strong)] underline-offset-4 transition-[color,text-decoration-color] duration-200 hover:text-[var(--accent-solid)] hover:decoration-current focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--accent-ring)]"
                >
                  Need a quick question? Use Contact &rarr;
                </a>
              </div>
            </div>
          </Card>
        </FadeIn>
      </div>
    </section>
  </main>
</SiteLayout>
