---
import ProjectIntakeWizard from '../components/site/ProjectIntakeWizard';
import { FadeIn } from '../components/ui/FadeIn';
import SiteLayout from '../layouts/SiteLayout.astro';
import { SEO_ROUTES } from '../lib/seo';
import { Eyebrow } from '../components/ui/Eyebrow';
import { MotionHeading } from '../components/motion/MotionHeading';
import { SectionDivider } from '../components/motion/SectionDivider';

const sourcePath = Astro.url.pathname + Astro.url.search;
---

<SiteLayout
  title={SEO_ROUTES.startProject.title}
  description={SEO_ROUTES.startProject.description}
  canonicalPath="/start-a-project"
>
  <main id="main-content" tabindex="-1" class="-mt-28 pb-24 md:-mt-32 md:pb-32">
    <section class="axiom-container pt-16 md:pt-24">
      <div class="mx-auto max-w-5xl">
        <div class="mx-auto max-w-3xl text-center">
          <FadeIn client:load motion="eyebrow">
            <Eyebrow>START A PROJECT</Eyebrow>
            <SectionDivider client:load className="mt-6" />
          </FadeIn>
          <FadeIn client:load motion="cinematic" delay={160}>
            <MotionHeading client:load as="h1" text="Tell us about the site. We'll handle the rest." className="mt-4" />
          </FadeIn>
          <FadeIn client:load motion="editorial" delay={420}>
            <p class="section-copy mx-auto mt-5 max-w-2xl md:text-[17px]">
              Five short steps. You'll get a clear reply from a real person, not a chatbot.
            </p>
          </FadeIn>

          <FadeIn client:load motion="system" delay={600}>
            <div class="mt-7 flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-[12px] font-medium uppercase tracking-[0.14em] text-[var(--text-secondary)]">
              <span>ABOUT 2 MINUTES</span>
              <span aria-hidden="true" class="text-[var(--text-muted)]">&bull;</span>
              <span>MONTHLY OR OWNERSHIP</span>
              <span aria-hidden="true" class="text-[var(--text-muted)]">&bull;</span>
              <span>REPLY WITHIN ONE BUSINESS DAY</span>
            </div>
          </FadeIn>
        </div>

        <div class="mt-10 md:mt-12">
          <div class="form-cinematic-shell mx-auto w-full max-w-3xl" data-reveal data-motion="depth" style="--reveal-delay: 760ms;">
            <ProjectIntakeWizard client:load sourcePath={sourcePath} />
          </div>
        </div>
      </div>
    </section>
  </main>

  <style is:global>
    .project-intake-wizard [data-step-panel] {
      animation: wizard-step-in 360ms var(--ease-premium-soft);
      transform-origin: top center;
    }

    .project-intake-wizard [data-step-panel].wizard-step-panel-backward {
      animation-name: wizard-step-in-backward;
    }

    @keyframes wizard-step-in {
      from {
        opacity: 0;
        transform: translate3d(0, 10px, 0);
      }

      to {
        opacity: 1;
        transform: translate3d(0, 0, 0);
      }
    }

    @keyframes wizard-step-in-backward {
      from {
        opacity: 0;
        transform: translate3d(0, -8px, 0);
      }

      to {
        opacity: 1;
        transform: translate3d(0, 0, 0);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .project-intake-wizard [data-step-panel] {
        animation: none;
      }
    }
  </style>
</SiteLayout>
