---
import IntakeForm from '../components/site/IntakeForm.astro';
import { FadeIn } from '../components/ui/FadeIn';
import SiteLayout from '../layouts/SiteLayout.astro';
import { SEO_ROUTES } from '../lib/seo';
import { Button } from '../components/ui/button';
import { Card } from '../components/ui/card';
import { Eyebrow } from '../components/ui/Eyebrow';
---

<SiteLayout title={SEO_ROUTES.startProject.title} description={SEO_ROUTES.startProject.description} canonicalPath="/start-a-project">
  <main id="main-content" tabindex="-1" class="-mt-28 pb-24 md:-mt-32 md:pb-32">
    <section class="axiom-container pt-12 md:pt-20">
      <FadeIn client:load className="max-w-3xl">
        <Eyebrow>START A PROJECT</Eyebrow>
        <h1 class="mt-4 max-w-4xl">
          Tell us what the business needs.
        </h1>
        <p class="mt-5 max-w-2xl text-[15px] leading-[1.65] text-[var(--text-secondary)] md:text-[17px]">
          Share the basics. We reply within one business day with the next step.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3 text-[11px] font-medium uppercase tracking-[0.14em] text-[var(--text-secondary)]">
          <span>ONE SHORT FORM</span>
          <span aria-hidden="true" class="text-[var(--text-muted)]">Â·</span>
          <span>REPLY WITHIN ONE BUSINESS DAY</span>
        </div>

        <div class="mt-7">
          <Button asChild size="lg">
            <a href="#project-intake">Start a project</a>
          </Button>
        </div>
      </FadeIn>
    </section>

    <section class="page-section">
      <div class="axiom-container grid gap-6 xl:grid-cols-[minmax(0,1.18fr)_minmax(18rem,0.72fr)] xl:items-start">
        <FadeIn client:load as="div" id="project-intake" className="scroll-mt-32">
          <IntakeForm
            kind="project"
            endpoint="/api/intake"
            title="Let&apos;s get to work."
            eyebrow="PROJECT INTAKE"
            description="Tell us what the business does, what&apos;s broken about the current site, and when you want to move."
            helper="Three short lines is enough. What does the business do, what is wrong with the current site, and when do you want to move?"
            submitLabel="Send it â†’"
            successTitle="Received."
            successText="Received. We will review and reply within one business day."
            noteLinkHref="/contact"
            noteLinkLabel="contact page"
            noteText="Need a question instead? Use the"
          />
        </FadeIn>

        <FadeIn client:load as="div">
          <Card className="self-start p-0 xl:sticky xl:top-28">
            <div class="p-6 sm:p-7">
              <Eyebrow>GENERAL QUESTIONS</Eyebrow>
              <p class="mt-4 max-w-md text-[15px] leading-[1.65] text-[var(--text-secondary)]">
                Use the contact page for a quick note or anything that is not a project.
              </p>
              <div class="mt-6">
                <a
                  href="/contact"
                  class="inline-flex items-center text-[15px] font-medium text-[var(--text-primary)] underline decoration-[color:var(--border-strong)] underline-offset-4 transition-[color,opacity] duration-200 hover:text-[var(--text-primary)]"
                >
                  Contact page â†’
                </a>
              </div>
            </div>
          </Card>
        </FadeIn>
      </div>
    </section>
  </main>
</SiteLayout>
