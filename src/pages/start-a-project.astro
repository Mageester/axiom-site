---
import ProjectIntakeWizard from '../components/site/ProjectIntakeWizard';
import { FadeIn } from '../components/ui/FadeIn';
import SiteLayout from '../layouts/SiteLayout.astro';
import { SEO_ROUTES } from '../lib/seo';
import { Eyebrow } from '../components/ui/Eyebrow';
import { MotionHeading } from '../components/motion/MotionHeading';
import { SectionDivider } from '../components/motion/SectionDivider';

const sourcePath = Astro.url.pathname + Astro.url.search;
---

<SiteLayout
  title={SEO_ROUTES.startProject.title}
  description={SEO_ROUTES.startProject.description}
  canonicalPath="/start-a-project"
>
  <main id="main-content" tabindex="-1" class="-mt-28 pb-20 md:-mt-32 md:pb-24">
    <section class="axiom-container pt-14 md:pt-20">
      <div class="mx-auto max-w-5xl">
        <div class="mx-auto max-w-3xl text-center">
          <FadeIn motion="eyebrow">
            <Eyebrow>START A PROJECT</Eyebrow>
            <SectionDivider className="mx-auto mt-6" />
          </FadeIn>
          <FadeIn motion="sceneOpen" delay={180}>
            <MotionHeading as="h1" text="Tell us about the site. We'll handle the rest." className="mt-4" />
          </FadeIn>
          <FadeIn motion="editorialMaskReveal" delay={460}>
            <p class="section-copy mx-auto mt-5 max-w-2xl md:text-[17px]">
              Five short steps. You'll get a clear reply from a real person, not a chatbot.
            </p>
          </FadeIn>

          <FadeIn motion="formFocusMotion" delay={580}>
            <div class="mt-7 flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-[12px] font-medium uppercase tracking-[0.14em] text-[var(--text-secondary)]">
              <span>ABOUT 2 MINUTES</span>
              <span aria-hidden="true" class="text-[var(--text-muted)]">&bull;</span>
              <span>MONTHLY OR OWNERSHIP</span>
              <span aria-hidden="true" class="text-[var(--text-muted)]">&bull;</span>
              <span>REPLY WITHIN ONE BUSINESS DAY</span>
            </div>
          </FadeIn>
        </div>

        <div class="mt-8 md:mt-10">
          <div class="form-cinematic-shell mx-auto w-full max-w-3xl" data-reveal data-motion="formFocusMotion" style="--reveal-delay: 740ms;">
            <ProjectIntakeWizard client:visible sourcePath={sourcePath} />
          </div>
        </div>

        <FadeIn as="div" motion="formFocusMotion" className="mx-auto mt-5 max-w-3xl">
          <div class="grid gap-3 rounded-[22px] border border-[color:var(--hairline)] bg-[rgba(255,255,255,0.018)] p-5 text-left sm:grid-cols-3">
            {['We review the brief', 'You get a reply within one business day', 'If there is a fit, we scope the path'].map((item, index) => (
              <p class="flex gap-3 text-[14px] leading-[1.6] text-[var(--text-secondary)]">
                <span class="font-mono text-[12px] text-[var(--accent-solid)]">0{index + 1}</span>
                <span>{item}</span>
              </p>
            ))}
          </div>
        </FadeIn>
      </div>
    </section>
  </main>

  <style is:global>
    .project-intake-wizard [data-step-panel] {
      animation: wizard-step-in 360ms var(--ease-premium-soft);
      transform-origin: top center;
    }

    .project-intake-wizard [data-step-panel].wizard-step-panel-backward {
      animation-name: wizard-step-in-backward;
    }

    @keyframes wizard-step-in {
      from {
        opacity: 0;
        transform: translate3d(0, 10px, 0);
      }

      to {
        opacity: 1;
        transform: translate3d(0, 0, 0);
      }
    }

    @keyframes wizard-step-in-backward {
      from {
        opacity: 0;
        transform: translate3d(0, -8px, 0);
      }

      to {
        opacity: 1;
        transform: translate3d(0, 0, 0);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .project-intake-wizard [data-step-panel] {
        animation: none;
      }
    }
  </style>
</SiteLayout>
