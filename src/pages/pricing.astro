---
import SiteLayout from '../layouts/SiteLayout.astro';
import { createStartProjectHref } from '../lib/cta';
import { SEO_ROUTES, PRICING_JSON_LD, PRICING_FAQ_JSON_LD, breadcrumbSchema, SITE_URL } from '../lib/seo';
import { FadeIn } from '../components/ui/FadeIn';
import { Card } from '../components/ui/card';
import { Eyebrow } from '../components/ui/Eyebrow';
import { AxiomButton } from '../components/ui/AxiomButton';
import DrawIcon from '../components/ui/DrawIcon.astro';
import { MotionHeading } from '../components/motion/MotionHeading';
import { SectionDivider } from '../components/motion/SectionDivider';

const isCheckmark = (val: string) => ['Included', String.fromCharCode(10003)].some((k) => val.toLowerCase() === k.toLowerCase());

const pricingTiers = [
  {
    key: 'monthly',
    name: 'Managed Partnership',
    costShape: 'Monthly',
    price: '$200/mo',
    subtext: '$0 down. Comprehensive hosting, security, and ongoing updates included.',
    supportNote: 'Includes priority updates and active maintenance. Full IP transfer automatically at month 12.',
    features: ['Custom page layouts (up to 5)', 'Fully managed enterprise hosting', 'Active content & design updates', '6-month minimum commitment', 'Automatic IP transfer at month 12'],
    cta: 'Start partnership',
    href: createStartProjectHref('monthly'),
    variant: 'primary',
    highlighted: true,
    eyebrow: 'PREFERRED PATH',
    bestFor: 'For established firms seeking continuous optimization and active management with low upfront capital allocation.',
  },
  {
    key: 'ownership',
    name: 'Direct Acquisition',
    costShape: 'Upfront',
    price: 'From $3,500',
    subtext: 'Custom 5-page platform deployment. Complete codebase handoff at launch.',
    supportNote: 'Includes 30 days of launch support. Managed hosting can be configured separately.',
    features: ['Custom page layouts (up to 5)', 'Immediate codebase ownership', '30 days post-launch support', 'Configured to your choice of host', 'SEO & speed optimization foundation'],
    cta: 'Acquire platform',
    href: createStartProjectHref('ownership'),
    variant: 'secondary',
    bestFor: 'For buyers who prefer a single capital expenditure and want immediate, direct custody of their codebase.',
  },
  {
    key: 'ecommerce',
    name: 'Enterprise Custom Scope',
    costShape: 'Fixed Bid',
    price: 'Custom quote',
    subtext: 'Tailored to specific architectural needs, e-commerce, or large-scale migrations.',
    supportNote: 'Milestone-based delivery. Project pricing is fully locked in advance.',
    features: ['Custom page counts and flows', 'E-commerce & database integration', 'Third-party API integrations', 'Post-launch monitoring included', 'Fully audited custom scope'],
    cta: 'Request custom scope',
    href: createStartProjectHref('custom'),
    variant: 'secondary',
    bestFor: 'For legacy migrations, e-commerce stores, or complex integrations requiring a custom scope.',
  },
] as const;

const comparisonRows = [
  {
    key: 'monthly',
    label: 'Capital Structure',
    monthly: '$0 down',
    ownership: 'From $3,500',
    ecommerce: 'Custom scope',
  },
  {
    key: 'ownership',
    label: 'Structural Scale',
    monthly: 'Up to 5 page layouts',
    ownership: 'Up to 5 page layouts',
    ecommerce: 'Fully custom',
  },
  {
    key: 'ecommerce',
    label: 'Cloud Infrastructure',
    monthly: 'Fully managed & included',
    ownership: 'Configured separately',
    ecommerce: 'Configured separately',
  },
  {
    key: 'active-maintenance',
    label: 'Active Maintenance',
    monthly: 'Ongoing updates & support',
    ownership: '30 days post-launch',
    ecommerce: '30 days post-launch',
  },
  {
    key: 'ip-ownership',
    label: 'IP Custody',
    monthly: 'Transfers at month 12',
    ownership: 'Immediate handoff',
    ecommerce: 'Immediate handoff',
  },
] as const;

const comparisonTierOrder = ['monthly', 'ownership', 'ecommerce'] as const;

const mobileComparisonTiers = comparisonTierOrder
  .map((key) => pricingTiers.find((tier) => tier.key === key))
  .filter(Boolean)
  .map((tier) => ({
    ...tier,
    rows: comparisonRows.map((row) => ({
      label: row.label,
      value: row[tier!.key as keyof typeof row],
    })),
  }));

const faqItems = [
  {
    question: 'Why structure this as a Managed Partnership?',
    answer:
      'We align with your commercial needs by removing large upfront capital commitments. Under our partnership model, we deploy your custom platform for $0 down, providing premium hosting, security, and continuous updates. To guarantee your security, full intellectual property ownership transfers automatically after twelve months.',
  },
  {
    question: 'What is included in the Managed Partnership model?',
    answer:
      'The partnership covers everything required to run and maintain your digital presence: custom layout design (up to 5 pages), secure cloud hosting, active content and design updates, and direct partner support. Intellectual property rights transfer automatically at month twelve, after which you can choose to take custody of the code or maintain our managed tier for continuous optimization.',
  },
  {
    question: 'What is the Direct Acquisition path?',
    answer:
      'For firms that prefer a single capital expenditure, you can acquire the platform outright. Starting at $3,500, we design, build, and deploy the site directly to your preferred hosting environment, transferring complete codebase custody to your team at launch.',
  },
  {
    question: 'How is cloud infrastructure managed?',
    answer:
      'Under the Managed Partnership, secure hosting is fully managed and included. For Direct Acquisition projects, we configure the platform to your choice of cloud hosting (such as Netlify, Vercel, or AWS) and provide 30 days of launch monitoring.',
  },
  {
    question: 'How are custom enterprise scopes handled?',
    answer:
      'Custom e-commerce platforms, database-driven applications, and large-scale legacy migrations are scoped on a fixed-bid basis. These projects are structured under milestone-based agreements rather than our monthly partnership model.',
  },
  {
    question: 'What is your project revision protocol?',
    answer:
      'Every project includes structured design and copywriting review phases before engineering begins to ensure complete alignment. For Managed Partnership clients, further design refinements and updates are covered under your monthly agreement.',
  },
  {
    question: 'Can we edit content internally?',
    answer:
      'Yes. We integrate lightweight, secure content management controls. This allows your team to easily update text, project portfolios, and documents without risking layout regressions or breaking code.',
  },
  {
    question: 'What separates Axiom from a traditional digital agency?',
    answer:
      'We operate with zero layers of administrative overhead. You work directly with the partners executing your strategy and code. There are no account managers, no hidden billing hours, and no communication lag.',
  },
] as const;
---

<SiteLayout
  title={SEO_ROUTES.pricing.title}
  description={SEO_ROUTES.pricing.description}
  canonicalPath="/pricing"
  schema={[PRICING_JSON_LD, PRICING_FAQ_JSON_LD, breadcrumbSchema([{ name: 'Home', url: SITE_URL }, { name: 'Pricing', url: `${SITE_URL}/pricing` }])]}
>
  <main id="main-content" tabindex="-1" class="-mt-28 pb-0 md:-mt-32">
    <section class="pricing-hero axiom-container pt-[5.5rem] md:pt-[7.5rem]">
      <div class="max-w-3xl">
        <FadeIn motion="eyebrow">
          <Eyebrow>PRICING</Eyebrow>
          <SectionDivider className="mt-6" />
        </FadeIn>
        <FadeIn motion="sceneOpen" delay={180}>
          <MotionHeading as="h1" text="Real pricing. No sales call required." className="mt-4" />
        </FadeIn>
        <FadeIn motion="editorialMaskReveal" delay={500}>
          <p class="section-copy mt-5 md:text-[17px]">
            Most clients start monthly - $0 down, hosting and support included. If you'd rather own the site outright,
            that option is $3,500 and up. Stores and large rebuilds get scoped separately.
          </p>
        </FadeIn>
        <FadeIn motion="editorialMaskReveal" delay={660}>
          <p class="mt-3 text-[14px] leading-[1.65] text-[var(--text-muted)] md:text-[15px]">
            Typical builds include Home, Services, Work, Pricing, and Contact. Additional pages can be scoped separately.
            The final monthly price depends on page count, integrations, and support needs.
          </p>
        </FadeIn>
      </div>
    </section>

    <section class="page-section-tight section-shell">
      <div class="axiom-container">
        <div class="mt-10 flex snap-x snap-mandatory gap-4 overflow-x-auto pb-2 lg:grid lg:grid-cols-3 lg:gap-5 lg:overflow-visible lg:pb-0">
          {pricingTiers.map((tier, index) => (
            <FadeIn
              motion="precisionPricingReveal"
              delay={Math.min(index * 150, 600)}
              as="div"
              id={tier.key === 'monthly' ? 'monthly-tier' : tier.key === 'ownership' ? 'ownership-tier' : tier.key === 'ecommerce' ? 'ecommerce-tier' : undefined}
              className="flex h-full shrink-0 basis-[84%] snap-start flex-col sm:basis-[68%] md:basis-[56%] lg:basis-auto lg:shrink"
            >
              <Card
                padding="none"
                hoverLift
                className={`pricing-tier-card relative overflow-hidden ${tier.highlighted ? 'pricing-highlight-card border-[color:var(--accent-border)] bg-[var(--surface-2)] shadow-[var(--shadow-card-highlight)]' : 'bg-[var(--surface-1)]'}`}
              >
                {tier.highlighted ? (
                  <div
                    aria-hidden="true"
                    class="pointer-events-none absolute inset-0"
                    style="
                      background:
                        radial-gradient(circle at top, var(--accent-surface-strong) 0%, transparent 42%),
                        linear-gradient(180deg, var(--surface-overlay-strong) 0%, transparent 24%);
                    "
                  />
                ) : null}

                <div class="relative flex h-full flex-col p-6 sm:p-7">
                  <div class="flex flex-wrap items-center justify-between gap-3">
                    <Eyebrow className={tier.highlighted ? 'text-[var(--accent-solid)]' : undefined}>{tier.eyebrow ?? tier.name}</Eyebrow>
                    <span class={`rounded-full border px-3 py-1 text-[11px] font-medium uppercase tracking-[0.14em] ${tier.highlighted ? 'border-white/20 bg-white/[0.04] text-white' : 'border-[color:var(--hairline)] bg-[color:var(--surface-overlay)] text-[var(--text-secondary)]'}`}>
                      {tier.costShape}
                    </span>
                  </div>

                  <p class="mt-4 text-[15px] font-medium uppercase tracking-[0.1em] text-[var(--text-primary)]">
                    {tier.name}
                  </p>

                  <p class="mt-2 text-[14px] leading-[1.65] text-[var(--text-secondary)]">
                    {tier.bestFor}
                  </p>

                  <p class="mt-5 text-[42px] font-[600] leading-[1.05] tracking-[-0.04em] text-[var(--text-primary)] sm:text-[48px]">
                    {tier.price}
                  </p>

                  {tier.subtext ? <p class="mt-3 text-[16px] leading-[1.7] text-[var(--text-secondary)]">{tier.subtext}</p> : null}

                  <ul class="mt-6 space-y-3">
                    {tier.features.map((feature) => (
                      <li class="flex items-start gap-3 text-[16px] leading-[1.7] text-[var(--text-secondary)]">
                        <span class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-[color:var(--hairline)] bg-[color:var(--surface-panel-strong)]">
                          <DrawIcon name="check" size={12} className="text-[var(--accent-solid)]" />
                        </span>
                        <span>{feature}</span>
                      </li>
                    ))}
                  </ul>

                  <div class="mt-auto pt-8">
                    {tier.highlighted ? (
                      <AxiomButton as="a" href={tier.href} variant="primary" size="lg" fullWidth>
                        <span>{tier.cta}</span>
                        <span class="text-[#c8ff00]" aria-hidden="true">&#8599;</span>
                      </AxiomButton>
                    ) : (
                      <AxiomButton as="a" href={tier.href} variant="secondary" size="md" fullWidth>
                        <span>{tier.cta}</span>
                        <span class="text-white/60" aria-hidden="true">&#8599;</span>
                      </AxiomButton>
                    )}
                  </div>
                </div>
              </Card>

              {tier.supportNote ? (
                <p class="mt-3 px-3 text-center text-[14px] font-normal leading-[1.65] text-[var(--text-muted)]">
                  {tier.supportNote}
                </p>
              ) : null}
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section section-shell">
      <div class="axiom-container">
          <FadeIn motion="editorialMaskReveal" className="max-w-3xl">
          <Eyebrow>COMPARE THE PATHS</Eyebrow>
          <SectionDivider className="mt-6" />
          <MotionHeading as="h2" text="What each option includes." className="section-heading mt-4" />
          <p class="section-copy mt-4 md:text-[17px]">
            Same quality on every path. The differences are cost shape, ownership, and scope.
          </p>
        </FadeIn>

        <div class="mt-8 grid gap-4 md:hidden">
          {mobileComparisonTiers.map((tier, index) => (
            <FadeIn motion="precisionPricingReveal" delay={Math.min(index * 140, 560)} as="div">
              <Card
                padding="none"
                className={`overflow-hidden ${tier.highlighted ? 'border-[color:var(--accent-border)] bg-[var(--surface-2)] shadow-[0_0_0_1px_var(--accent-shadow-medium)]' : 'bg-[var(--surface-1)]'}`}
              >
                <div class="p-6">
                  {tier.highlighted ? <Eyebrow className="text-[var(--accent-solid)]">PREFERRED PATH</Eyebrow> : <Eyebrow>{tier.name}</Eyebrow>}
                  <div class="mt-4">
                    <div class="min-w-0">
                      <p class="text-[2.35rem] font-[600] leading-none tracking-[-0.04em] text-[var(--text-primary)] sm:text-[2.75rem]">{tier.price}</p>
                      <p class="mt-2 text-[14px] leading-[1.65] text-[var(--text-secondary)]">{tier.bestFor}</p>
                    </div>
                  </div>

                  <div class="mt-6 space-y-3 border-t border-[color:var(--hairline)] pt-5">
                    {tier.rows.map((row) => (
                      <div class="grid grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] gap-4">
                        <p class="text-[14px] font-medium uppercase tracking-[0.08em] text-[var(--text-secondary)]">{row.label}</p>
                        <div class="text-[16px] leading-[1.7] text-[var(--text-secondary)]">
                          {isCheckmark(row.value) ? (
                            <span class="inline-flex items-center text-[var(--accent-solid)]">
                              <DrawIcon name="check" size={16} className="is-active" />
                              <span class="sr-only">{row.value}</span>
                            </span>
                          ) : (
                            row.value
                          )}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </Card>
            </FadeIn>
          ))}
        </div>

        <FadeIn as="div" motion="precisionPricingReveal" className="pricing-table-shell mt-8 hidden overflow-hidden rounded-[var(--radius-card)] border border-[color:var(--hairline)] bg-[var(--surface-1)] md:block">
          <table class="min-w-full border-collapse text-left">
            <thead class="bg-[color:var(--nav-panel-bg)]">
              <tr class="border-b border-[color:var(--hairline)]">
                <th scope="col" class="px-6 py-4 text-[12px] uppercase tracking-[0.18em] text-[var(--text-secondary)]">
                  Feature
                </th>
                <th scope="col" class="px-6 py-4 text-[12px] uppercase tracking-[0.18em] text-[var(--text-secondary)] bg-[linear-gradient(180deg,var(--accent-surface),transparent)]">
                  <div class="flex flex-col gap-1">
                    <span class="text-[12px] font-semibold uppercase tracking-[0.24em] text-[var(--accent-solid)]">Preferred</span>
                    <span>Partnership</span>
                  </div>
                </th>
                <th scope="col" class="px-6 py-4 text-[12px] uppercase tracking-[0.18em] text-[var(--text-secondary)]">
                  ACQUISITION
                </th>
                <th scope="col" class="px-6 py-4 text-[12px] uppercase tracking-[0.18em] text-[var(--text-secondary)]">
                  ENTERPRISE SCOPE
                </th>
              </tr>
            </thead>
            <tbody>
              {comparisonRows.map((row) => (
                <tr class="pricing-table-row border-b border-[color:var(--hairline)] odd:bg-[#0a0a0a] even:bg-[var(--surface-1)] last:border-b-0">
                  <th scope="row" class="px-6 py-4 text-[16px] font-medium text-[var(--text-primary)]">
                    {row.label}
                  </th>
                  <td class="px-6 py-4 text-[16px] leading-[1.7] text-[var(--text-secondary)] bg-[linear-gradient(180deg,var(--accent-surface),transparent)]">
                    {isCheckmark(row.monthly) ? (
                      <span class="inline-flex items-center text-[var(--accent-solid)]">
                        <DrawIcon name="check" size={18} className="is-active" />
                        <span class="sr-only">{row.monthly}</span>
                      </span>
                    ) : row.monthly}
                  </td>
                  <td class="px-6 py-4 text-[16px] leading-[1.7] text-[var(--text-secondary)]">
                    {isCheckmark(row.ownership) ? (
                      <span class="inline-flex items-center text-[var(--accent-solid)]">
                        <DrawIcon name="check" size={18} className="is-active" />
                        <span class="sr-only">{row.ownership}</span>
                      </span>
                    ) : row.ownership}
                  </td>
                  <td class="px-6 py-4 text-[16px] leading-[1.7] text-[var(--text-secondary)]">
                    {isCheckmark(row.ecommerce) ? (
                      <span class="inline-flex items-center text-[var(--accent-solid)]">
                        <DrawIcon name="check" size={18} className="is-active" />
                        <span class="sr-only">{row.ecommerce}</span>
                      </span>
                    ) : row.ecommerce}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <FadeIn as="div" motion="precisionPricingReveal" className="mt-6">
          <Card className="border-[color:var(--hairline)] bg-[var(--surface-2)]">
            <p class="section-copy mx-auto max-w-4xl text-center md:text-[16px]">
              Managed Partnership includes cloud hosting and active maintenance. Direct Acquisition includes complete codebase handoff at launch. Enterprise Custom Scope is priced by project requirements.
            </p>
          </Card>
        </FadeIn>
      </div>
    </section>

    <section class="page-section section-shell">
      <div class="axiom-container">
        <FadeIn motion="editorialMaskReveal" className="max-w-3xl">
          <Eyebrow>FAQ</Eyebrow>
          <SectionDivider className="mt-6" />
          <MotionHeading as="h2" text="Answers before the call." className="section-heading mt-4" />
        </FadeIn>

        <FadeIn motion="precisionPricingReveal" className="mt-8">
          <div class="overflow-hidden rounded-[var(--radius-card)] border border-[color:var(--hairline)] bg-[var(--surface-1)]">
            {faqItems.map((item, index) => (
              <details class="group" data-faq>
                <summary class={`flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 text-left transition-[background-color] duration-[var(--duration-fast)] hover:bg-[color:var(--surface-overlay)] ${index === 0 ? '' : 'border-t border-[color:var(--hairline)]'}`}>
                  <span class="text-[15px] font-semibold tracking-[-0.01em] text-[var(--text-primary)] md:text-[18px]">
                    {item.question}
                  </span>
                  <span
                    class="faq-toggle relative flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-[color:var(--hairline)] bg-[color:var(--surface-overlay)] text-[var(--text-primary)] transition-transform duration-[200ms] ease-out"
                    aria-hidden="true"
                  >
                    <svg class="faq-toggle-chevron h-4 w-4 transition-transform duration-[200ms] ease-out" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                      <path d="M5 8L10 13L15 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </span>
                </summary>
                <div class="faq-panel max-h-0 overflow-hidden opacity-0 translate-y-1 transition-[max-height,opacity,transform] duration-[var(--duration-medium)] ease-[var(--ease-premium)]">
                  <div class="overflow-hidden">
                    <div class="px-6 pb-5 pt-1 md:pb-6">
                <p class="section-copy md:text-[16px]">
                  {item.answer}
                </p>
                    </div>
                  </div>
                </div>
              </details>
            ))}
          </div>
        </FadeIn>
      </div>
    </section>

    <section class="page-section section-shell">
      <div class="axiom-container">
        <FadeIn motion="editorialMaskReveal" className="max-w-3xl">
          <Eyebrow>QUICK GUIDE</Eyebrow>
        </FadeIn>

        <div class="mt-8 grid gap-4 lg:grid-cols-2">
          <FadeIn motion="precisionPricingReveal" as="div">
            <Card className="h-full border-[color:var(--hairline)] bg-[var(--surface-1)]">
              <div class="flex h-full flex-col">
                <h3 class="text-[24px] font-[600] leading-[1.15] tracking-[-0.02em] text-[var(--text-primary)]">
                  You prioritize operational flexibility.
                </h3>
                <p class="section-copy mt-4 md:text-[16px]">
                  $0 down. Hosting, technical maintenance, and ongoing updates are fully managed. Transfer IP ownership at month 12.
                </p>
                <a href="#monthly-tier" class="mt-6 inline-flex min-h-11 items-center text-[15px] font-medium leading-[1.6] text-[var(--text-primary)] transition-colors duration-200 hover:text-[var(--accent-solid)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--accent-ring)]">
                  See partnership details &uarr;</a>
              </div>
            </Card>
          </FadeIn>

          <FadeIn motion="precisionPricingReveal" delay={140} as="div">
            <Card className="h-full border-[color:var(--hairline)] bg-[var(--surface-1)]">
              <div class="flex h-full flex-col">
                <h3 class="text-[24px] font-[600] leading-[1.15] tracking-[-0.02em] text-[var(--text-primary)]">
                  You prefer direct intellectual property acquisition.
                </h3>
                <p class="section-copy mt-4 md:text-[16px]">
                  A single capital expenditure starting at $3,500. Immediate codebase ownership and flexible hosting deployment at launch.
                </p>
                <a href="#ownership-tier" class="mt-6 inline-flex min-h-11 items-center text-[15px] font-medium leading-[1.6] text-[var(--text-primary)] transition-colors duration-200 hover:text-[var(--accent-solid)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--accent-ring)]">
                  See direct acquisition details &uarr;</a>
              </div>
            </Card>
          </FadeIn>
        </div>
      </div>
    </section>

    <section class="page-section-tight section-shell">
      <div class="axiom-container">
        <FadeIn as="div" motion="finalFrameFooter">
          <Card className="mx-auto max-w-6xl border-[color:var(--hairline)] bg-[var(--surface-2)] p-0">
            <div class="flex flex-col gap-6 px-6 py-8 sm:px-8 sm:py-10 md:px-10 md:py-12 lg:flex-row lg:items-end lg:justify-between">
              <div class="max-w-3xl">
                <SectionDivider className="mb-6" />
                <MotionHeading as="h2" text="Not sure which option is right?" className="section-heading" />
                <p class="section-copy mt-4 md:text-[17px]">
                  Tell us what the business needs. We'll tell you which path fits - monthly, ownership, or lump sum.
                  One business day. No pressure, no pitch deck.
                </p>
              </div>

              <AxiomButton as="a" href={createStartProjectHref('custom')} size="lg" className="w-full lg:w-auto">
                <span>Start a project</span>
                <span class="text-[#c8ff00]" aria-hidden="true">&#8599;</span>
              </AxiomButton>
            </div>
          </Card>
        </FadeIn>
      </div>
    </section>
  </main>

  <style>
    .pricing-hero {
      position: relative;
    }

    .pricing-hero::before {
      content: '';
      position: absolute;
      inset: 0 auto auto 0;
      width: min(28rem, 70vw);
      height: 18rem;
      pointer-events: none;
      background: radial-gradient(circle at 20% 20%, var(--accent-surface), transparent 62%);
      opacity: 0.78;
      filter: blur(24px);
      transform: translate3d(-16%, -18%, 0);
    }

    .pricing-tier-card {
      min-height: 100%;
    }

    .pricing-tier-card::after {
      content: '';
      position: absolute;
      inset: 0 0 auto;
      height: 1px;
      pointer-events: none;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.16), transparent);
      opacity: 0.7;
    }

    .pricing-table-shell {
      box-shadow: var(--shadow-card);
    }

    [data-motion='precisionPricingReveal'][data-reveal-state='visible'] .pricing-highlight-card {
      animation: pricing-glow 2.1s var(--ease-cinematic) 1;
    }

    .pricing-table-row {
      animation: pricing-row-in 0.78s var(--ease-cinematic) both;
