---
import SiteLayout from '../layouts/SiteLayout.astro';
import { CTA_PATHS } from '../lib/cta';
import { SEO_ROUTES, PRICING_JSON_LD, PRICING_FAQ_JSON_LD, breadcrumbSchema, SITE_URL } from '../lib/seo';
import { FadeIn } from '../components/ui/FadeIn';
import { Button } from '../components/ui/button';
import { Card } from '../components/ui/card';
import { Eyebrow } from '../components/ui/Eyebrow';
import DrawIcon from '../components/ui/DrawIcon.astro';
import { MotionHeading } from '../components/motion/MotionHeading';
import { SectionDivider } from '../components/motion/SectionDivider';

const isCheckmark = (val: string) => ['Included', String.fromCharCode(10003)].some((k) => val.toLowerCase() === k.toLowerCase());

const pricingTiers = [
  {
    key: 'monthly',
    name: 'Subscription',
    price: '$0 down',
    subtext: 'From $150-$200/mo. Hosting included. Best when you want to start with less friction.',
    supportNote: 'Ongoing edits and support are included. Full ownership transfers at month 12.',
    features: ['Up to 5 pages', 'Hosting included', 'Ongoing edits and support', '6-month minimum', 'Full ownership available at month 12'],
    cta: 'Start monthly',
    href: CTA_PATHS.startProject,
    variant: 'primary',
    highlighted: true,
    eyebrow: 'PREFERRED PATH',
    bestFor: 'The easiest way to start. Low upfront cost, full support built in.',
  },
  {
    key: 'ownership',
    name: 'One-time ownership',
    price: 'From $3,500',
    subtext: 'For a standard 5-page build. Full handoff at launch. Hosting can be scoped separately.',
    supportNote: 'For buyers who want the code, the site, and the keys at launch.',
    features: ['Up to 5 pages', 'Full code ownership at launch', 'Launch support included', 'Hosting scoped separately', 'SEO foundation'],
    cta: 'Start a project',
    href: CTA_PATHS.startProject,
    variant: 'secondary',
    bestFor: 'One payment. Full ownership at launch.',
  },
  {
    key: 'ecommerce',
    name: 'E-commerce / rebuilds',
    price: 'Custom lump sum',
    subtext: 'Sized to the store, migration, or rebuild scope. E-commerce stays lump sum only.',
    supportNote: 'For projects that need tighter scoping up front.',
    features: ['Store setup or rebuild', 'Migration support', 'Integrations as needed', 'Launch support included', 'Scoped pricing'],
    cta: 'Start a project',
    href: CTA_PATHS.startProject,
    variant: 'secondary',
    bestFor: 'For stores and larger rebuilds. Scoped once, priced once.',
  },
] as const;

const comparisonRows = [
  {
    label: 'Best for',
    monthly: 'Starting with less friction',
    ownership: 'Owning outright from day one',
    ecommerce: 'Stores and larger rebuilds',
  },
  {
    label: 'Upfront cost',
    monthly: '$0 down',
    ownership: 'One-time payment',
    ecommerce: 'One-time payment',
  },
  {
    label: 'Starting price',
    monthly: 'From $150-$200/mo',
    ownership: 'From $3,500',
    ecommerce: 'Custom lump sum',
  },
  {
    label: 'Hosting',
    monthly: 'Included',
    ownership: 'Scoped separately if needed',
    ecommerce: 'Scoped as needed',
  },
  {
    label: 'Support',
    monthly: 'Ongoing edits and support',
    ownership: 'Launch support included',
    ecommerce: 'Launch support included',
  },
  {
    label: 'Ownership',
    monthly: 'Available at month 12',
    ownership: 'Full ownership at launch',
    ecommerce: 'Full ownership at launch',
  },
  {
    label: 'Pages / scope',
    monthly: 'Up to 5 pages',
    ownership: 'Up to 5 pages',
    ecommerce: 'Scoped to the build',
  },
  {
    label: 'Turnaround',
    monthly: 'About 21 days',
    ownership: 'Scoped on intake',
    ecommerce: 'Scoped on intake',
  },
  {
    label: 'Revisions',
    monthly: '3 rounds',
    ownership: '3 rounds',
    ecommerce: 'Scoped with the project',
  },
] as const;

const comparisonTierOrder = ['monthly', 'ownership', 'ecommerce'] as const;

const mobileComparisonTiers = comparisonTierOrder
  .map((key) => pricingTiers.find((tier) => tier.key === key))
  .filter(Boolean)
  .map((tier) => ({
    ...tier,
    rows: comparisonRows.map((row) => ({
      label: row.label,
      value: row[tier!.key as keyof typeof row],
    })),
  }));

const faqItems = [
  {
    question: 'Why lead with monthly pricing?',
    answer:
      'Most businesses do not want a $5K+ hit before they see results. Monthly lets you start for $0 down, get the site live, and pay as it earns.',
  },
  {
    question: 'What is included in the monthly plan?',
    answer:
      'Up to 5 pages, hosting, ongoing edits, and priority support. Full ownership transfers at month 12 if you want it.',
  },
  {
    question: 'What if I want ownership instead?',
    answer:
      'Pick the one-time ownership path. One payment from $3,500, full code handoff at launch, hosting scoped separately if you need it.',
  },
  {
    question: 'How does hosting work?',
    answer:
      'Monthly plans include hosting. Ownership clients can let us host it or move it to their own provider - either works.',
  },
  {
    question: 'What about e-commerce?',
    answer:
      'Stores and large rebuilds get a custom quote. Scope covers setup, migration, and integrations. One lump sum, no monthly.',
  },
  {
    question: 'How are revisions handled?',
    answer:
      'Three rounds per build. Most projects do not use all three. Monthly clients get ongoing edits after launch.',
  },
  {
    question: 'Can I edit the site myself?',
    answer:
      'Yes. We build so basic text, photo, and page edits are easy to do without breaking anything.',
  },
  {
    question: 'What makes Axiom different?',
    answer:
      'Fast sites, real pricing, and support that does not stop at launch. 14 days to live. No 60-day Slack silences.',
  },
] as const;
---

<SiteLayout
  title={SEO_ROUTES.pricing.title}
  description={SEO_ROUTES.pricing.description}
  canonicalPath="/pricing"
  schema={[PRICING_JSON_LD, PRICING_FAQ_JSON_LD, breadcrumbSchema([{ name: 'Home', url: SITE_URL }, { name: 'Pricing', url: `${SITE_URL}/pricing` }])]}
>
  <main id="main-content" tabindex="-1" class="-mt-28 pb-0 md:-mt-32">
    <section class="pricing-hero axiom-container pt-28 md:pt-36">
      <FadeIn client:load className="max-w-3xl">
        <Eyebrow>PRICING</Eyebrow>
        <SectionDivider client:load className="mt-6" />
        <MotionHeading client:load as="h1" text="Real pricing. No sales call required." className="mt-4" />
        <p class="section-copy mt-5 md:text-[17px]">
          Most clients start monthly - $0 down, hosting and support included. If you'd rather own the site outright,
          that option is $3,500 and up. Stores and large rebuilds get scoped separately.
        </p>
        <p class="mt-4 text-[14px] leading-[1.65] text-[var(--text-secondary)] md:text-[15px]">
          Monthly is the default. Ownership and e-commerce stay available when they're the better fit.
        </p>
      </FadeIn>
    </section>

    <section class="page-section-tight section-shell">
      <div class="axiom-container">
        <div class="mt-10 flex snap-x snap-mandatory gap-4 overflow-x-auto pb-2 lg:grid lg:grid-cols-3 lg:gap-5 lg:overflow-visible lg:pb-0">
          {pricingTiers.map((tier, index) => (
            <FadeIn
              client:load
              delay={Math.min(index * 100, 400)}
              as="div"
              id={tier.key === 'monthly' ? 'monthly-tier' : tier.key === 'ownership' ? 'ownership-tier' : tier.key === 'ecommerce' ? 'ecommerce-tier' : undefined}
              className="flex h-full shrink-0 basis-[84%] snap-start flex-col sm:basis-[68%] md:basis-[56%] lg:basis-auto lg:shrink"
            >
              <Card
                padding="none"
                hoverLift
                className={`pricing-tier-card relative overflow-hidden ${tier.highlighted ? 'pricing-highlight-card border-[color:var(--accent-border)] bg-[var(--surface-2)] shadow-[var(--shadow-card-highlight)]' : 'bg-[var(--surface-1)]'}`}
              >
                {tier.highlighted ? (
                  <div
                    aria-hidden="true"
                    class="pointer-events-none absolute inset-0"
                    style="
                      background:
                        radial-gradient(circle at top, var(--accent-surface-strong) 0%, transparent 42%),
                        linear-gradient(180deg, var(--surface-overlay-strong) 0%, transparent 24%);
                    "
                  />
                ) : null}

                <div class="relative flex h-full flex-col p-6 sm:p-7">
                  <Eyebrow className={tier.highlighted ? 'text-[var(--accent-solid)]' : undefined}>{tier.eyebrow ?? tier.name}</Eyebrow>

                  <p class="mt-2 text-[15px] font-medium uppercase tracking-[0.1em] text-[var(--text-primary)]">
                    {tier.name}
                  </p>

                  <p class="mt-2 text-[14px] leading-[1.65] text-[var(--text-secondary)]">
                    {tier.bestFor}
                  </p>

                  <p class="mt-5 text-[42px] font-[600] leading-[1.05] tracking-[-0.04em] text-[var(--text-primary)] sm:text-[48px]">
                    {tier.price}
                  </p>

                  {tier.subtext ? <p class="mt-3 text-[16px] leading-[1.7] text-[var(--text-secondary)]">{tier.subtext}</p> : null}

                  <ul class="mt-6 space-y-3">
                    {tier.features.map((feature) => (
                      <li class="flex items-start gap-3 text-[16px] leading-[1.7] text-[var(--text-secondary)]">
                        <span class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-[color:var(--hairline)] bg-[color:var(--surface-panel-strong)]">
                          <DrawIcon name="check" size={12} className="text-[var(--accent-solid)]" />
                        </span>
                        <span>{feature}</span>
                      </li>
                    ))}
                  </ul>

                  <div class="mt-auto pt-8">
                    <Button asChild variant={tier.variant} className="w-full">
                      <a href={tier.href}>{tier.cta}</a>
                    </Button>
                  </div>
                </div>
              </Card>

              {tier.supportNote ? (
                <p class="mt-3 px-3 text-center text-[14px] font-normal leading-[1.65] text-[var(--text-muted)]">
                  {tier.supportNote}
                </p>
              ) : null}
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section section-shell">
      <div class="axiom-container">
          <FadeIn client:load className="max-w-3xl">
          <Eyebrow>COMPARE THE PATHS</Eyebrow>
          <SectionDivider client:load className="mt-6" />
          <MotionHeading client:load as="h2" text="What each option includes." className="section-heading mt-4" />
          <p class="section-copy mt-4 md:text-[17px]">
            Same quality on every path. The differences are cost shape, ownership, and scope.
          </p>
        </FadeIn>

        <div class="mt-8 grid gap-4 md:hidden">
          {mobileComparisonTiers.map((tier, index) => (
            <FadeIn client:load delay={Math.min(index * 100, 400)} as="div">
              <Card
                padding="none"
                className={`overflow-hidden ${tier.highlighted ? 'border-[color:var(--accent-border)] bg-[var(--surface-2)] shadow-[0_0_0_1px_var(--accent-shadow-medium)]' : 'bg-[var(--surface-1)]'}`}
              >
                <div class="p-6">
                  {tier.highlighted ? <Eyebrow className="text-[var(--accent-solid)]">PREFERRED PATH</Eyebrow> : <Eyebrow>{tier.name}</Eyebrow>}
                  <div class="mt-4 flex items-end justify-between gap-4">
                    <div class="min-w-0">
                      <p class="text-[2.35rem] font-[600] leading-none tracking-[-0.04em] text-[var(--text-primary)] sm:text-[2.75rem]">{tier.price}</p>
                      <p class="mt-2 text-[14px] leading-[1.65] text-[var(--text-secondary)]">{tier.bestFor}</p>
                    </div>
                    <Button asChild variant={tier.variant} size="sm">
                      <a href={tier.href}>{tier.cta}</a>
                    </Button>
                  </div>

                  <div class="mt-6 space-y-3 border-t border-[color:var(--hairline)] pt-5">
                    {tier.rows.map((row) => (
                      <div class="grid grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] gap-4">
                        <p class="text-[14px] font-medium uppercase tracking-[0.08em] text-[var(--text-secondary)]">{row.label}</p>
                        <div class="text-[16px] leading-[1.7] text-[var(--text-secondary)]">
                          {isCheckmark(row.value) ? (
                            <span class="inline-flex items-center text-[var(--accent-solid)]">
                              <DrawIcon name="check" size={16} className="is-active" />
                              <span class="sr-only">{row.value}</span>
                            </span>
                          ) : (
                            row.value
                          )}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </Card>
            </FadeIn>
          ))}
        </div>

        <FadeIn client:load as="div" className="pricing-table-shell mt-8 hidden overflow-hidden rounded-[var(--radius-card)] border border-[color:var(--hairline)] bg-[var(--surface-1)] md:block">
          <table class="min-w-full border-collapse text-left">
            <thead class="bg-[color:var(--nav-panel-bg)]">
              <tr class="border-b border-[color:var(--hairline)]">
                <th scope="col" class="px-6 py-4 text-[12px] uppercase tracking-[0.18em] text-[var(--text-secondary)]">
                  Feature
                </th>
                <th scope="col" class="px-6 py-4 text-[12px] uppercase tracking-[0.18em] text-[var(--text-secondary)]">
                  SUBSCRIPTION
                </th>
                <th scope="col" class="px-6 py-4 text-[12px] uppercase tracking-[0.18em] text-[var(--text-secondary)] bg-[linear-gradient(180deg,var(--accent-surface),transparent)]">
                  <div class="flex flex-col gap-1">
                    <span class="text-[12px] font-semibold uppercase tracking-[0.24em] text-[var(--accent-solid)]">One-time</span>
                    <span>Ownership</span>
                  </div>
                </th>
                <th scope="col" class="px-6 py-4 text-[12px] uppercase tracking-[0.18em] text-[var(--text-secondary)]">
                  E-COMMERCE
                </th>
              </tr>
            </thead>
            <tbody>
              {comparisonRows.map((row) => (
                <tr class="pricing-table-row border-b border-[color:var(--hairline)] odd:bg-[#0a0a0a] even:bg-[var(--surface-1)] last:border-b-0">
                  <th scope="row" class="px-6 py-4 text-[16px] font-medium text-[var(--text-primary)]">
                    {row.label}
                  </th>
                  <td class="px-6 py-4 text-[16px] leading-[1.7] text-[var(--text-secondary)]">
                    {isCheckmark(row.monthly) ? (
                      <span class="inline-flex items-center text-[var(--accent-solid)]">
                        <DrawIcon name="check" size={18} className="is-active" />
                        <span class="sr-only">{row.monthly}</span>
                      </span>
                    ) : row.monthly}
                  </td>
                  <td class="px-6 py-4 text-[16px] leading-[1.7] text-[var(--text-secondary)] bg-[linear-gradient(180deg,var(--accent-surface),transparent)]">
                    {isCheckmark(row.ownership) ? (
                      <span class="inline-flex items-center text-[var(--accent-solid)]">
                        <DrawIcon name="check" size={18} className="is-active" />
                        <span class="sr-only">{row.ownership}</span>
                      </span>
                    ) : row.ownership}
                  </td>
                  <td class="px-6 py-4 text-[16px] leading-[1.7] text-[var(--text-secondary)]">
                    {isCheckmark(row.ecommerce) ? (
                      <span class="inline-flex items-center text-[var(--accent-solid)]">
                        <DrawIcon name="check" size={18} className="is-active" />
                        <span class="sr-only">{row.ecommerce}</span>
                      </span>
                    ) : row.ecommerce}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <FadeIn client:load as="div" className="mt-6">
          <Card className="border-[color:var(--hairline)] bg-[var(--surface-2)]">
            <p class="section-copy mx-auto max-w-4xl text-center md:text-[16px]">
              Monthly includes hosting, ongoing support, and edits. One-time ownership includes launch support, with hosting scoped separately if needed. E-commerce stays lump sum only.
            </p>
          </Card>
        </FadeIn>
      </div>
    </section>

    <section class="page-section section-shell">
      <div class="axiom-container">
        <FadeIn client:load className="max-w-3xl">
          <Eyebrow>FAQ</Eyebrow>
          <SectionDivider client:load className="mt-6" />
          <MotionHeading client:load as="h2" text="Answers before the call." className="section-heading mt-4" />
        </FadeIn>

        <FadeIn client:load className="mt-8">
          <div class="overflow-hidden rounded-[var(--radius-card)] border border-[color:var(--hairline)] bg-[var(--surface-1)]">
            {faqItems.map((item, index) => (
              <details class="group" data-faq>
                <summary class={`flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 text-left transition-[background-color] duration-[var(--duration-fast)] hover:bg-[color:var(--surface-overlay)] ${index === 0 ? '' : 'border-t border-[color:var(--hairline)]'}`}>
                  <span class="text-[15px] font-semibold tracking-[-0.01em] text-[var(--text-primary)] md:text-[18px]">
                    {item.question}
                  </span>
                  <span
                    class="faq-toggle relative flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-[color:var(--hairline)] bg-[color:var(--surface-overlay)] text-[var(--text-primary)] transition-transform duration-[200ms] ease-out"
                    aria-hidden="true"
                  >
                    <svg class="faq-toggle-chevron h-4 w-4 transition-transform duration-[200ms] ease-out" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                      <path d="M5 8L10 13L15 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </span>
                </summary>
                <div class="faq-panel max-h-0 overflow-hidden opacity-0 translate-y-1 transition-[max-height,opacity,transform] duration-[var(--duration-medium)] ease-[var(--ease-premium)]">
                  <div class="overflow-hidden">
                    <div class="px-6 pb-5 pt-1 md:pb-6">
                <p class="section-copy md:text-[16px]">
                  {item.answer}
                </p>
                    </div>
                  </div>
                </div>
              </details>
            ))}
          </div>
        </FadeIn>
      </div>
    </section>

    <section class="page-section section-shell">
      <div class="axiom-container">
        <FadeIn client:load className="max-w-3xl">
          <Eyebrow>QUICK GUIDE</Eyebrow>
        </FadeIn>

        <div class="mt-8 grid gap-4 lg:grid-cols-2">
          <FadeIn client:load as="div">
            <Card className="h-full border-[color:var(--hairline)] bg-[var(--surface-1)]">
              <div class="flex h-full flex-col">
                <h3 class="text-[24px] font-[600] leading-[1.15] tracking-[-0.02em] text-[var(--text-primary)]">
                  You want the easiest way to start.
                </h3>
                <p class="section-copy mt-4 md:text-[16px]">
                  $0 down. Hosting and support included. You can transfer ownership later if you want it.
                </p>
                <a href="#monthly-tier" class="mt-6 inline-flex min-h-11 items-center text-[15px] font-medium leading-[1.6] text-[var(--text-primary)] transition-colors duration-200 hover:text-[var(--accent-solid)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--accent-ring)]">
                  See what monthly costs &uarr;</a>
              </div>
            </Card>
          </FadeIn>

          <FadeIn client:load delay={100} as="div">
            <Card className="h-full border-[color:var(--hairline)] bg-[var(--surface-1)]">
              <div class="flex h-full flex-col">
                <h3 class="text-[24px] font-[600] leading-[1.15] tracking-[-0.02em] text-[var(--text-primary)]">
                  You want full ownership from day one.
                </h3>
                <p class="section-copy mt-4 md:text-[16px]">
                  One payment from $3,500. Full code handoff at launch. Host it with us or on your own stack.
                </p>
                <a href="#ownership-tier" class="mt-6 inline-flex min-h-11 items-center text-[15px] font-medium leading-[1.6] text-[var(--text-primary)] transition-colors duration-200 hover:text-[var(--accent-solid)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--accent-ring)]">
                  See what ownership costs &uarr;</a>
              </div>
            </Card>
          </FadeIn>
        </div>
      </div>
    </section>

    <section class="page-section-tight section-shell">
      <div class="axiom-container">
        <FadeIn client:load as="div">
          <Card className="mx-auto max-w-6xl border-[color:var(--hairline)] bg-[var(--surface-2)] p-0">
            <div class="flex flex-col gap-6 px-6 py-8 sm:px-8 sm:py-10 md:px-10 md:py-12 lg:flex-row lg:items-end lg:justify-between">
              <div class="max-w-3xl">
                <SectionDivider client:load className="mb-6" />
                <MotionHeading client:load as="h2" text="Not sure which tier fits?" className="section-heading" />
                <p class="section-copy mt-4 md:text-[17px]">
                  Tell us what the business needs. We'll tell you which path fits - monthly, ownership, or lump sum.
                  One business day. No pressure, no pitch deck.
                </p>
              </div>

              <Button asChild size="lg" className="w-full lg:w-auto">
                <a href={CTA_PATHS.startProject}>Start a project</a>
              </Button>
            </div>
          </Card>
        </FadeIn>
      </div>
    </section>
  </main>

  <style>
    .pricing-hero {
      position: relative;
    }

    .pricing-hero::before {
      content: '';
      position: absolute;
      inset: 0 auto auto 0;
      width: min(28rem, 70vw);
      height: 18rem;
      pointer-events: none;
      background: radial-gradient(circle at 20% 20%, var(--accent-surface), transparent 62%);
      opacity: 0.78;
      filter: blur(24px);
      transform: translate3d(-16%, -18%, 0);
    }

    .pricing-tier-card {
      min-height: 100%;
    }

    .pricing-tier-card::after {
      content: '';
      position: absolute;
      inset: 0 0 auto;
      height: 1px;
      pointer-events: none;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.16), transparent);
      opacity: 0.7;
    }

    .pricing-table-shell {
      box-shadow: var(--shadow-card);
    }

    .pricing-highlight-card {
      animation: pricing-glow 1.5s ease-out 1;
    }

    .pricing-table-row {
      animation: pricing-row-in 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
      transition: background-color var(--duration-fast) ease;
    }

    .pricing-table-row:hover {
      background: rgba(255,255,255,0.035);
    }

    details[data-faq][open] .faq-panel {
      max-height: 24rem;
      opacity: 1;
      transform: translateY(0);
    }

    details[data-faq][open] .faq-toggle {
      background: var(--surface-overlay-press);
      border-color: var(--accent-border);
    }

    details[data-faq][open] .faq-toggle-chevron {
      transform: rotate(180deg);
    }

    details[data-faq] summary::-webkit-details-marker {
      display: none;
    }

    @media (prefers-reduced-motion: reduce) {
      .pricing-highlight-card,
      .pricing-table-row {
        animation: none !important;
      }
    }

    @keyframes pricing-glow {
      0% {
        box-shadow: 0 0 0 1px rgba(212, 175, 55, 0);
      }

      50% {
        box-shadow: 0 0 0 1px rgba(212, 175, 55, 0.18), 0 0 38px rgba(212, 175, 55, 0.12);
      }

      100% {
        box-shadow: 0 0 0 1px rgba(212, 175, 55, 0);
      }
    }

    @keyframes pricing-row-in {
      from {
        opacity: 0;
        transform: translateY(12px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .pricing-table-row:nth-child(1) { animation-delay: 0.04s; }
