---
import SiteLayout from '../layouts/SiteLayout.astro';
import { CTA_PATHS } from '../lib/cta';
import { SEO_ROUTES, PRICING_JSON_LD } from '../lib/seo';
import { FadeIn } from '../components/ui/FadeIn';
import { Button } from '../components/ui/button';
import { Card } from '../components/ui/card';
import { Eyebrow } from '../components/ui/Eyebrow';
import DrawIcon from '../components/ui/DrawIcon.astro';

const isCheckmark = (val: string) => 
  ['Included', '✓'].some((k) => val.toLowerCase() === k.toLowerCase());

const pricingTiers = [
  {
    key: 'growth',
    name: 'Growth',
    price: '$2,200',
    subtext: '',
    supportNote: '',
    features: ['5 pages', 'SEO foundation', 'Google Business setup', 'Live in 21 days'],
    cta: 'Start a project',
    href: CTA_PATHS.startProject,
    variant: 'secondary',
  },
  {
    key: 'monthly',
    name: 'MONTHLY',
    price: 'From $150/mo',
    subtext: '$0 down. No lock-in after 6 months. Hosting included.',
    supportNote: 'Most clients recover the monthly cost within the first booked call the site generates.',
    features: ['Up to 5 pages', 'Hosting included', 'Unlimited edits', '6-month minimum — protects your timeline', 'Full code ownership at month 12'],
    cta: 'Start a project',
    href: '/start',
    variant: 'primary',
    highlighted: true,
    eyebrow: 'PREFERRED MODEL',
  },
  {
    key: 'signature',
    name: 'Signature',
    price: 'From $3,500',
    subtext: '',
    supportNote: '',
    features: ['Unlimited pages', 'Integrations & automations', 'Post-launch support', 'Timeline scoped on intake'],
    cta: 'Start a project',
    href: CTA_PATHS.startProject,
    variant: 'secondary',
  },
  {
    key: 'rebuild',
    name: 'Rebuild',
    price: 'From $6,500',
    subtext: '',
    supportNote: '',
    features: ['Full site migration', 'Integrations & automations', 'SEO preservation', 'Support through launch'],
    cta: 'Start a project',
    href: CTA_PATHS.startProject,
    variant: 'secondary',
  },
] as const;

const comparisonRows = [
  {
    label: 'Pages included',
    monthly: 'Up to 5 pages',
    growth: '5 pages',
    signature: 'Unlimited pages',
    rebuild: 'Full migration scope',
  },
  {
    label: 'Turnaround',
    monthly: '21 days',
    growth: '21 days',
    signature: 'Scoped on intake',
    rebuild: 'Scoped on intake',
  },
  {
    label: 'Revision rounds',
    monthly: '3 rounds',
    growth: '3 rounds',
    signature: 'Scoped with the project',
    rebuild: 'Scoped with the project',
  },
  {
    label: 'SEO setup',
    monthly: 'SEO foundation',
    growth: 'SEO foundation',
    signature: 'Custom strategy',
    rebuild: 'SEO preservation',
  },
  {
    label: 'Google Business setup',
    monthly: '✓',
    growth: 'Included',
    signature: 'Included if needed',
    rebuild: 'Included if needed',
  },
  {
    label: 'Hosting guidance',
    monthly: 'Included',
    growth: 'Included',
    signature: 'Included',
    rebuild: 'Included',
  },
  {
    label: 'Editing workflow',
    monthly: 'Editable content flow',
    growth: 'Editable content flow',
    signature: 'Custom setup',
    rebuild: 'Custom setup',
  },
  {
    label: 'Post-launch support',
    monthly: 'Ongoing support',
    growth: 'Post-launch support',
    signature: 'Scoped support',
    rebuild: 'Support through launch',
  },
  {
    label: 'Ownership',
    monthly: 'Full ownership at month 12',
    growth: 'Full ownership',
    signature: 'Full ownership',
    rebuild: 'Full ownership',
  },
  {
    label: 'Recurring fees',
    monthly: '$150/mo · 6-month minimum',
    growth: 'None',
    signature: 'None',
    rebuild: 'None',
  },
] as const;

const comparisonTierOrder = ['monthly', 'growth', 'signature', 'rebuild'] as const;

const mobileComparisonTiers = comparisonTierOrder
  .map((key) => pricingTiers.find((tier) => tier.key === key))
  .filter(Boolean)
  .map((tier) => ({
  ...tier,
  rows: comparisonRows.map((row) => ({
    label: row.label,
    value: row[tier!.key as keyof typeof row],
  })),
}));

const faqItems = [
  {
    question: 'Do I own the code?',
    answer:
      'Yes. You own the site, the source files, and the final handoff. There are no lease-style terms or hidden licensing fees.',
  },
  {
    question: 'How does the monthly plan work?',
    answer:
      'You pay nothing upfront. We build the site, handle hosting, and stay available for edits throughout the month. The minimum commitment is 6 months — that keeps the project moving and gives the site time to actually perform. After 12 months, full code ownership transfers to you. Cancel after the minimum with 30 days notice.',
  },
  {
    question: 'Can I edit the site myself?',
    answer:
      'If self-editing matters, we set up a simple workflow and show you how to use it. If you want us to handle updates instead, we can do that too.',
  },
  {
    question: 'What if I need changes after launch?',
    answer:
      'Small launch fixes are included after go-live. Larger changes or new pages are scoped clearly before any work starts.',
  },
  {
    question: 'Is hosting included?',
    answer:
      'We handle the deployment setup and tell you exactly what the site needs. If a separate hosting account is required, we make that clear before launch.',
  },
  {
    question: 'How do revisions work?',
    answer:
      'Each package includes a set number of revision rounds. We collect feedback in batches so the project keeps moving instead of stalling.',
  },
  {
    question: "What's the payment schedule?",
    answer:
      "Projects start with a deposit before any work begins. The remainder is due at launch, or split across milestones on larger builds. We don't start work without payment in place — that keeps the timeline clean for both sides.",
  },
  {
    question: 'Do you work with businesses outside your area?',
    answer:
      'Yes. We work with the right fit wherever the project makes sense, as long as the scope matches our approach.',
  },
  {
    question: 'What makes Axiom different?',
    answer:
      'The process is built around clarity, speed, and ownership. You get a site that is easy to understand, fast to load, and built to turn visitors into calls.',
  },
] as const;
---

<SiteLayout title={SEO_ROUTES.pricing.title} description={SEO_ROUTES.pricing.description} canonicalPath="/pricing" schema={PRICING_JSON_LD}>
  <main id="main-content" tabindex="-1" class="-mt-28 md:-mt-32 pb-24 md:pb-32">
    <section class="axiom-container pt-12 md:pt-20">
      <FadeIn client:load className="max-w-3xl">
        <Eyebrow>PRICING</Eyebrow>
        <h1 class="mt-4">Flexible structure. Full ownership.</h1>
        <p class="section-copy mt-5 md:text-[17px]">
          One investment. No lock-in. You own the site, the code, and the domain. Monthly plans also available.
        </p>
      </FadeIn>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <div class="mt-10 flex snap-x snap-mandatory gap-4 overflow-x-auto pb-2 lg:grid lg:grid-cols-4 lg:gap-5 lg:overflow-visible lg:pb-0">
          {pricingTiers.map((tier, index) => (
            <FadeIn
              client:load
              delay={Math.min(index * 100, 400)}
              as="div"
              id={tier.key === 'monthly' ? 'monthly-tier' : tier.key === 'growth' ? 'growth-tier' : undefined}
              className="flex h-full shrink-0 basis-[84%] snap-start flex-col sm:basis-[68%] md:basis-[56%] lg:basis-auto lg:shrink"
            >
              <Card
                padding="none"
                hoverLift
                className={`relative overflow-hidden ${tier.highlighted ? 'border-[color:var(--accent-border)] bg-[var(--surface-2)] shadow-[var(--shadow-card-highlight)]' : 'bg-[var(--surface-1)]'}`}
              >
                {tier.highlighted ? (
                  <div
                    aria-hidden="true"
                    class="pointer-events-none absolute inset-0"
                    style="
                      background:
                        radial-gradient(circle at top, var(--accent-surface-strong) 0%, transparent 42%),
                        linear-gradient(180deg, var(--surface-overlay-strong) 0%, transparent 24%);
                    "
                  />
                ) : null}

                <div class="relative flex h-full flex-col p-6 sm:p-7">
                  {tier.highlighted ? <Eyebrow className="text-[var(--accent-solid)]">MOST CHOSEN</Eyebrow> : <Eyebrow>{tier.eyebrow ?? tier.name}</Eyebrow>}

                  {!tier.highlighted ? <p class="mt-2 text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--text-secondary)]">{tier.name}</p> : null}

                  <p class="mt-5 text-[56px] font-[600] leading-none tracking-[-0.04em] text-[var(--text-primary)]">
                    {tier.price}
                  </p>

                  {tier.key === 'monthly' ? (
                    <p class="mt-2 text-[56px] font-[600] leading-none tracking-[-0.04em] text-[#b89a5e]">
                      $0 to start.
                    </p>
                  ) : null}

                  {tier.subtext ? <p class="mt-3 text-[15px] leading-[1.65] text-white/60">{tier.subtext}</p> : null}

                  <ul class="mt-6 space-y-3">
                    {tier.features.map((feature) => (
                        <li class="flex items-start gap-3 text-[15px] leading-[1.65] text-white/60">
                        <span class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-[color:var(--hairline)] bg-[color:var(--surface-panel-strong)]">
                          <DrawIcon name="check" size={12} className="text-[#C9A96E]" />
                        </span>
                        <span>{feature}</span>
                      </li>
                    ))}
                  </ul>

                  <div class="mt-auto pt-8">
                    <Button asChild variant={tier.variant} className="w-full">
                      <a href={tier.href}>{tier.cta}</a>
                    </Button>
                  </div>
                </div>
              </Card>

              {tier.supportNote ? (
                <p class="mt-3 px-3 text-center text-[13px] font-normal leading-[1.6] text-[rgba(255,255,255,0.45)]">
                  {tier.supportNote}
                </p>
              ) : null}
            </FadeIn>
          ))}
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <FadeIn client:load className="max-w-3xl">
          <Eyebrow>COMPARE THE TIERS</Eyebrow>
          <h2 class="section-heading mt-4">What each package includes.</h2>
          <p class="section-copy mt-4 md:text-[17px]">
            Use this to compare the structure, support, and ownership before you book a call.
          </p>
        </FadeIn>

        <div class="mt-8 grid gap-4 md:hidden">
          {mobileComparisonTiers.map((tier, index) => (
            <FadeIn client:load delay={Math.min(index * 100, 400)} as="div">
              <Card
                padding="none"
                className={`overflow-hidden ${tier.highlighted ? 'border-[color:var(--accent-border)] bg-[var(--surface-2)] shadow-[0_0_0_1px_var(--accent-shadow-medium)]' : 'bg-[var(--surface-1)]'}`}
              >
                <div class="p-6">
                  {tier.highlighted ? <Eyebrow className="text-[var(--accent-solid)]">MOST CHOSEN</Eyebrow> : <Eyebrow>{tier.name}</Eyebrow>}
                  <div class="mt-4 flex items-end justify-between gap-4">
                    <p class="text-[2.75rem] font-[600] leading-none tracking-[-0.04em] text-[var(--text-primary)]">{tier.price}</p>
                    <Button asChild variant={tier.variant} size="sm">
                      <a href={tier.href}>{tier.cta}</a>
                    </Button>
                  </div>

                  <div class="mt-6 space-y-3 border-t border-[color:var(--hairline)] pt-5">
                    {tier.rows.map((row) => (
                      <div class="grid grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] gap-4">
                        <p class="text-[13px] font-medium uppercase tracking-[0.08em] text-[var(--text-secondary)]">{row.label}</p>
                        <div class="text-[15px] leading-[1.65] text-white/60">
                          {isCheckmark(row.value) ? (
                            <span class="inline-flex items-center text-[#C9A96E]">
                              <DrawIcon name="check" size={16} className="is-active" />
                              <span class="sr-only">{row.value}</span>
                            </span>
                          ) : (
                            row.value
                          )}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              </Card>
            </FadeIn>
          ))}
        </div>

        <FadeIn client:load as="div" className="mt-8 hidden overflow-hidden rounded-[var(--radius-card)] border border-[color:var(--hairline)] bg-[var(--surface-1)] md:block">
          <table class="min-w-full border-collapse text-left">
            <thead class="bg-[color:var(--nav-panel-bg)]">
              <tr class="border-b border-[color:var(--hairline)]">
                <th scope="col" class="px-6 py-4 text-[11px] uppercase tracking-[0.18em] text-[var(--text-secondary)]">
                  Feature
                </th>
                <th scope="col" class="px-6 py-4 text-[11px] uppercase tracking-[0.18em] text-[var(--text-secondary)]">
                  MONTHLY
                </th>
                <th scope="col" class="px-6 py-4 text-[11px] uppercase tracking-[0.18em] text-[var(--text-secondary)] bg-[linear-gradient(180deg,rgba(232,162,123,0.04),transparent)]">
                  <div class="flex flex-col gap-1">
                    <span class="text-[10px] font-semibold uppercase tracking-[0.24em] text-[var(--accent-solid)]">Most Chosen</span>
                    <span>Growth</span>
                  </div>
                </th>
                <th scope="col" class="px-6 py-4 text-[11px] uppercase tracking-[0.18em] text-[var(--text-secondary)]">
                  Signature
                </th>
                <th scope="col" class="px-6 py-4 text-[11px] uppercase tracking-[0.18em] text-[var(--text-secondary)]">
                  Rebuild
                </th>
              </tr>
            </thead>
            <tbody>
              {comparisonRows.map((row) => (
                <tr class="border-b border-[rgba(255,255,255,0.06)] odd:bg-[#0f0f0f] even:bg-[#111111] last:border-b-0">
                  <th scope="row" class="px-6 py-4 text-[15px] font-medium text-[var(--text-primary)]">
                    {row.label}
                  </th>
                  <td class="px-6 py-4 text-[15px] leading-[1.65] text-white/60">
                    {isCheckmark(row.monthly) ? (
                      <span class="inline-flex items-center text-[#C9A96E]">
                        <DrawIcon name="check" size={18} className="is-active" />
                        <span class="sr-only">{row.monthly}</span>
                      </span>
                    ) : row.monthly}
                  </td>
                  <td class="px-6 py-4 text-[15px] leading-[1.65] text-white/60 bg-[linear-gradient(180deg,rgba(232,162,123,0.02),transparent)]">
                    {isCheckmark(row.growth) ? (
                      <span class="inline-flex items-center text-[#C9A96E]">
                        <DrawIcon name="check" size={18} className="is-active" />
                        <span class="sr-only">{row.growth}</span>
                      </span>
                    ) : row.growth}
                  </td>
                  <td class="px-6 py-4 text-[15px] leading-[1.65] text-white/60">
                    {isCheckmark(row.signature) ? (
                      <span class="inline-flex items-center text-[#C9A96E]">
                        <DrawIcon name="check" size={18} className="is-active" />
                        <span class="sr-only">{row.signature}</span>
                      </span>
                    ) : row.signature}
                  </td>
                  <td class="px-6 py-4 text-[15px] leading-[1.65] text-white/60">
                    {isCheckmark(row.rebuild) ? (
                      <span class="inline-flex items-center text-[#C9A96E]">
                        <DrawIcon name="check" size={18} className="is-active" />
                        <span class="sr-only">{row.rebuild}</span>
                      </span>
                    ) : row.rebuild}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <FadeIn client:load className="max-w-3xl">
          <Eyebrow>FAQ</Eyebrow>
          <h2 class="section-heading mt-4">Answers before the call.</h2>
        </FadeIn>

        <FadeIn client:load className="mt-8">
          <div class="overflow-hidden rounded-[var(--radius-card)] border border-[color:var(--hairline)] bg-[var(--surface-1)]">
            {faqItems.map((item, index) => (
              <details class="group" data-faq>
                <summary class={`flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 text-left ${index === 0 ? '' : 'border-t border-[color:var(--hairline)]'}`}>
                  <span class="text-[15px] font-semibold tracking-[-0.01em] text-[var(--text-primary)] md:text-[18px]">
                    {item.question}
                  </span>
                  <span
                    class="faq-toggle relative flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-[color:var(--hairline)] bg-[color:var(--surface-overlay)] text-[var(--text-primary)] transition-transform duration-[200ms] ease-out"
                    aria-hidden="true"
                  >
                    <svg class="faq-toggle-chevron h-4 w-4 transition-transform duration-[200ms] ease-out" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                      <path d="M5 8L10 13L15 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </span>
                </summary>
                <div class="faq-panel max-h-0 overflow-hidden opacity-0 translate-y-1 transition-[max-height,opacity,transform] duration-[300ms] ease-out">
                  <div class="overflow-hidden">
                    <div class="px-6 pb-5 pt-1 md:pb-6">
                <p class="section-copy md:text-[16px]">
                  {item.answer}
                </p>
                    </div>
                  </div>
                </div>
              </details>
            ))}
          </div>
        </FadeIn>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <FadeIn client:load className="max-w-3xl">
          <Eyebrow>QUICK GUIDE</Eyebrow>
        </FadeIn>

        <div class="mt-8 grid gap-4 lg:grid-cols-2">
          <FadeIn client:load as="div">
            <Card className="h-full border-[color:var(--hairline)] bg-[var(--surface-1)]">
              <div class="flex h-full flex-col">
                <h3 class="text-[24px] font-[600] leading-[1.15] tracking-[-0.02em] text-[var(--text-primary)]">
                  You want to start without a large upfront cost.
                </h3>
                <p class="section-copy mt-4 md:text-[16px]">
                  The monthly plan puts a complete site live for $0 down. Hosting, edits, and support are included. You own the code at month 12.
                </p>
                <a href="#monthly-tier" class="mt-6 text-[15px] font-medium leading-[1.6] text-[var(--text-primary)] transition-colors duration-200 hover:text-white/70">
                  See monthly pricing ↑
                </a>
              </div>
            </Card>
          </FadeIn>

          <FadeIn client:load delay={100} as="div">
            <Card className="h-full border-[color:var(--hairline)] bg-[var(--surface-1)]">
              <div class="flex h-full flex-col">
                <h3 class="text-[24px] font-[600] leading-[1.15] tracking-[-0.02em] text-[var(--text-primary)]">
                  You want to own the asset outright from day one.
                </h3>
                <p class="section-copy mt-4 md:text-[16px]">
                  A one-time investment with full code handoff at launch. No monthly fees beyond $25/mo hosting.
                </p>
                <a href="#growth-tier" class="mt-6 text-[15px] font-medium leading-[1.6] text-[var(--text-primary)] transition-colors duration-200 hover:text-white/70">
                  See ownership tiers ↑
                </a>
              </div>
            </Card>
          </FadeIn>
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="axiom-container">
        <FadeIn client:load as="div">
          <Card className="mx-auto max-w-6xl border-[color:var(--hairline)] bg-[var(--surface-2)] p-0">
            <div class="flex flex-col gap-6 px-6 py-8 sm:px-8 sm:py-10 md:px-10 md:py-12 lg:flex-row lg:items-end lg:justify-between">
              <div class="max-w-3xl">
                <h2 class="section-heading">
                  Not sure which tier fits?
                </h2>
                <p class="section-copy mt-4 md:text-[17px]">
                  Start a project and we&apos;ll tell you exactly what the business needs. One business day, no pressure.
                </p>
              </div>

              <Button asChild size="lg" className="w-full lg:w-auto">
                <a href={CTA_PATHS.startProject}>Start a project</a>
              </Button>
            </div>
          </Card>
        </FadeIn>
      </div>
    </section>
  </main>

  <style>
    details[data-faq][open] .faq-panel {
      max-height: 24rem;
      opacity: 1;
      transform: translateY(0);
    }

    details[data-faq][open] .faq-toggle {
      background: var(--surface-overlay-press);
    }

    details[data-faq][open] .faq-toggle-chevron {
      transform: rotate(180deg);
    }

    details[data-faq] summary::-webkit-details-marker {
      display: none;
    }
  </style>
</SiteLayout>
