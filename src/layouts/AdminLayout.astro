---
import BaseLayout from './BaseLayout.astro';

type Props = {
  title?: string;
  description?: string;
  noIndex?: boolean;
};

const {
  title = 'Axiom Admin',
  description = 'Private admin area for Axiom Infrastructure.',
  noIndex = true,
} = Astro.props as Props;
---

<BaseLayout title={title} description={description} noIndex={noIndex} showNav={false} showFooter={false}>
  <div class="relative flex min-h-screen items-center justify-center px-6 py-10">
    <div class="w-full max-w-6xl">
      <slot />
    </div>
  </div>
</BaseLayout>
