---
import '../styles/globals.css';
import { Footer } from '../components/layout/Footer';
import NavBar from '../components/layout/NavBar.astro';
import {
  DEFAULT_OG_IMAGE,
  DEFAULT_SEO_DESCRIPTION,
  SITE_NAME,
  SITE_URL,
  formatSeoTitle,
  toCanonicalUrl,
} from '../lib/seo';

type Props = {
  title?: string;
  description?: string;
  canonicalPath?: string;
  image?: string;
  ogImageAlt?: string;
  noIndex?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  hidePrimaryCta?: boolean;
  showNav?: boolean;
  showFooter?: boolean;
};

const {
  title,
  description,
  canonicalPath,
  image,
  ogImageAlt,
  noIndex = false,
  schema,
  hidePrimaryCta = false,
  showNav = true,
  showFooter = true,
} = Astro.props as Props;

const resolvedTitle = formatSeoTitle(title);
const resolvedDescription = description?.trim() || DEFAULT_SEO_DESCRIPTION;
const resolvedCanonical = toCanonicalUrl(canonicalPath || Astro.url.pathname);
const resolvedImage = image || DEFAULT_OG_IMAGE;
const resolvedImageUrl = resolvedImage.startsWith('http') ? resolvedImage : `${SITE_URL}${resolvedImage}`;
const shellPaddingClass = showNav ? 'pt-28 md:pt-32' : 'pt-0';
---

<!doctype html>
<html lang="en" class="scroll-smooth text-[var(--text-primary)]">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#000000" />
    <meta name="generator" content="Astro" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <title>{resolvedTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <meta name="robots" content={noIndex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large'} />
    <link rel="canonical" href={resolvedCanonical} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_CA" />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:image" content={resolvedImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content={resolvedImage.endsWith('.png') ? 'image/png' : resolvedImage.endsWith('.jpg') || resolvedImage.endsWith('.jpeg') ? 'image/jpeg' : 'image/webp'} />
    <meta property="og:image:alt" content={ogImageAlt || `${SITE_NAME} – custom web design and development in Kitchener-Waterloo`} />
    <meta property="og:site_name" content={SITE_NAME} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={resolvedImageUrl} />

    {schema && (
      Array.isArray(schema)
        ? schema.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)
        : <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
    <script is:inline>
        (() => {
          const html = document.documentElement;
          const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

          if (reduced) {
            html.dataset.motionReduced = 'true';
          } else {
            html.dataset.motionActive = 'true';
          }

          const boot = () => {
            const markLink = (link) => {
              if (!(link instanceof HTMLElement)) return;
              if (link.classList.contains('btn-primary') || link.classList.contains('btn-secondary') || link.classList.contains('btn-ghost') || link.classList.contains('skip-link')) {
                return;
              }
              if (link.getAttribute('href') === '/start-a-project' || link.getAttribute('href') === '/start') return;
              if (link.closest('astro-island')) return;
              if (link.closest('.site-logo')) return;
              if (link.querySelector('img, svg')) return;
              link.classList.add('motion-link-accent');
            };

            try {
              Array.from(document.querySelectorAll('a[href]')).forEach(markLink);
            } catch {
              // Link accents are decorative; never block content reveal.
            }

            const observeReveal = (selector, options = {}) => {
              const targets = Array.from(document.querySelectorAll(selector)).filter((el) => {
                if (!(el instanceof HTMLElement)) return false;
                if (el.hasAttribute('data-reveal')) return true;
                return !el.closest('[data-reveal]');
              });

              if (!targets.length) return () => undefined;

              html.dataset.motionReady = 'true';
              const show = (el) => {
                if (el.hasAttribute('data-reveal')) {
                  el.setAttribute('data-reveal-state', 'visible');
                  el.querySelectorAll('[data-reveal-item]').forEach((item) => {
                    item.setAttribute('data-reveal-state', 'visible');
                  });
                }
                el.setAttribute('data-motion-visible', 'true');
              };

              if (reduced || typeof IntersectionObserver === 'undefined') {
                targets.forEach(show);
                return () => undefined;
              }

              const observer = new IntersectionObserver(
                (entries) => {
                  entries.forEach((entry) => {
                    if (!entry.isIntersecting || !(entry.target instanceof HTMLElement)) return;
                    show(entry.target);
                    observer.unobserve(entry.target);
                  });
                },
                {
                  threshold: 0.08,
                  rootMargin: '0px 0px -12% 0px',
                  ...options,
                }
              );

              targets.forEach((el) => observer.observe(el));
              window.requestAnimationFrame(() => {
                targets.forEach((el) => {
                  if (!(el instanceof HTMLElement) || el.getAttribute('data-motion-visible') === 'true') return;
                  const rect = el.getBoundingClientRect();
                  const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
                  if (rect.top < viewportHeight * 0.92 && rect.bottom > viewportHeight * 0.02) {
                    show(el);
                    observer.unobserve(el);
                  }
                });
              });
              const fallback = window.setTimeout(() => {
                targets.forEach((el) => {
                  if (!(el instanceof HTMLElement) || el.getAttribute('data-motion-visible') === 'true') return;
                  const rect = el.getBoundingClientRect();
                  const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
                  if (rect.top < viewportHeight * 1.1 && rect.bottom > viewportHeight * -0.1) {
                    show(el);
                    observer.unobserve(el);
                  }
                });
              }, 2400);

              return () => {
                window.clearTimeout(fallback);
                observer.disconnect();
              };
            };

          observeReveal('[data-reveal], .section-block');

            const observeIcons = () => {
              const icons = document.querySelectorAll('[data-draw-icon]');
              const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                  if (entry.isIntersecting) {
                    entry.target.classList.add('is-active');
                    observer.unobserve(entry.target);
                  }
                });
              }, { threshold: 0.15 });
              icons.forEach((icon) => observer.observe(icon));
            };
            observeIcons();

            const animateCounter = (element) => {
              if (!(element instanceof HTMLElement)) return;
              if (element.dataset.motionAnimated === 'true') return;

              const original = element.textContent?.trim() ?? '';
              const match = original.match(/-?\\d[\\d,]*(?:\\.\\d+)?/);
              if (!match || match.index == null) return;

              const prefix = original.slice(0, match.index);
              const suffix = original.slice(match.index + match[0].length);
              const finalValue = Number(match[0].replace(/,/g, ''));
              if (!Number.isFinite(finalValue)) return;

              const decimals = (match[0].split('.')[1] || '').length;
              const formatter = new Intl.NumberFormat('en-US', {
                minimumFractionDigits: decimals,
                maximumFractionDigits: decimals,
              });

              element.dataset.motionAnimated = 'true';
              element.dataset.motionVisible = 'true';
              element.textContent = `${prefix}${formatter.format(0)}${suffix}`;

              const duration = 1200;
              const start = performance.now();

              const tick = (now) => {
                const progress = Math.min((now - start) / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 3);
                const value = finalValue * eased;
                const rounded = decimals > 0 ? Number(value.toFixed(decimals)) : Math.round(value);
                element.textContent = `${prefix}${formatter.format(rounded)}${suffix}`;

                if (progress < 1) {
                  window.requestAnimationFrame(tick);
                }
              };

              window.requestAnimationFrame(tick);
            };

            const counterTargets = Array.from(document.querySelectorAll('.counter')).filter(
              (el) => el instanceof HTMLElement
            );

            if (reduced || typeof IntersectionObserver === 'undefined') {
              counterTargets.forEach(animateCounter);
            } else if (counterTargets.length) {
              const counterObserver = new IntersectionObserver(
                (entries) => {
                  entries.forEach((entry) => {
                    if (!entry.isIntersecting || !(entry.target instanceof HTMLElement)) return;
                    animateCounter(entry.target);
                    counterObserver.unobserve(entry.target);
                  });
                },
                { threshold: 0.15, rootMargin: '-30% 0px -60% 0px' }
              );

              counterTargets.forEach((el) => counterObserver.observe(el));
            }

            window.requestAnimationFrame(() => {
              html.dataset.motionBooted = 'true';
            });
          };

          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', boot, { once: true });
          } else {
            boot();
          }
        })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>

    {showNav ? <NavBar hidePrimaryCta={hidePrimaryCta} /> : null}

    <div class={`site-page-shell relative z-10 ${shellPaddingClass}`}>
      <slot />
    </div>

    {showFooter ? <Footer pathname={Astro.url.pathname} /> : null}
  </body>
</html>
