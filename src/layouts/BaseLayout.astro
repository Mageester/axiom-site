---
import '../styles/globals.css';
import { Footer } from '../components/layout/Footer';
import { ScrollProgressBar } from '../components/layout/ScrollProgressBar';
import NavBar from '../components/layout/NavBar.astro';
import {
  DEFAULT_OG_IMAGE,
  DEFAULT_SEO_DESCRIPTION,
  SITE_NAME,
  SITE_URL,
  formatSeoTitle,
  toCanonicalUrl,
} from '../lib/seo';

type Props = {
  title?: string;
  description?: string;
  canonicalPath?: string;
  image?: string;
  ogImageAlt?: string;
  noIndex?: boolean;
  schema?: Record<string, unknown>;
  hidePrimaryCta?: boolean;
  showNav?: boolean;
  showFooter?: boolean;
};

const {
  title,
  description,
  canonicalPath,
  image,
  ogImageAlt,
  noIndex = false,
  schema,
  hidePrimaryCta = false,
  showNav = true,
  showFooter = true,
} = Astro.props as Props;

const resolvedTitle = formatSeoTitle(title);
const resolvedDescription = description?.trim() || DEFAULT_SEO_DESCRIPTION;
const resolvedCanonical = toCanonicalUrl(canonicalPath || Astro.url.pathname);
const resolvedImage = image || DEFAULT_OG_IMAGE;
const resolvedImageUrl = resolvedImage.startsWith('http') ? resolvedImage : `${SITE_URL}${resolvedImage}`;
const shellPaddingClass = showNav ? 'pt-28 md:pt-32' : 'pt-0';
---

<!doctype html>
<html lang="en" class="scroll-smooth text-[var(--text-primary)]">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#000000" />
    <meta name="generator" content="Astro" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Fraunces:ital,wght@0,400;1,400&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700,800&display=swap"
    />

    <title>{resolvedTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <meta name="robots" content={noIndex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large'} />
    <link rel="canonical" href={resolvedCanonical} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_CA" />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:image" content={resolvedImageUrl} />
    {ogImageAlt ? <meta property="og:image:alt" content={ogImageAlt} /> : null}
    <meta property="og:site_name" content={SITE_NAME} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={resolvedImageUrl} />

    {schema ? <script type="application/ld+json" set:html={JSON.stringify(schema)} /> : null}
    <script is:inline>
        (() => {
          const html = document.documentElement;
          const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

          if (reduced) {
            html.dataset.motionReduced = 'true';
          } else {
            html.dataset.motionActive = 'true';
            html.dataset.motionLoading = 'true';
          }

          const boot = () => {
            const markLink = (link) => {
              if (!(link instanceof HTMLElement)) return;
              if (link.classList.contains('btn-primary') || link.classList.contains('btn-secondary') || link.classList.contains('btn-ghost') || link.classList.contains('skip-link')) {
                return;
              }
              if (link.closest('.site-logo')) return;
              if (link.querySelector('img, svg')) return;
              link.classList.add('motion-link-accent');
            };

            Array.from(document.querySelectorAll('a[href]')).forEach(markLink);

            const observeReveal = (selector, options = {}) => {
              const targets = Array.from(document.querySelectorAll(selector)).filter((el) => {
                if (!(el instanceof HTMLElement)) return false;
                if (el.hasAttribute('data-reveal')) return true;
                return !el.closest('[data-reveal]');
              });

              if (!targets.length) return () => undefined;

              const show = (el) => {
                if (el.hasAttribute('data-reveal')) {
                  el.setAttribute('data-reveal-state', 'visible');
                  el.querySelectorAll('[data-reveal-item]').forEach((item) => {
                    item.setAttribute('data-reveal-state', 'visible');
                  });
                }
                el.setAttribute('data-motion-visible', 'true');
              };

              if (reduced || typeof IntersectionObserver === 'undefined') {
                targets.forEach(show);
                return () => undefined;
              }

              const observer = new IntersectionObserver(
                (entries) => {
                  entries.forEach((entry) => {
                    if (!entry.isIntersecting || !(entry.target instanceof HTMLElement)) return;
                    show(entry.target);
                    observer.unobserve(entry.target);
                  });
                },
                {
                  threshold: 0.15,
                  rootMargin: '-30% 0px -60% 0px',
                  ...options,
                }
              );

              targets.forEach((el) => observer.observe(el));
              return () => observer.disconnect();
            };

          observeReveal('[data-reveal], .section-block');

            const observeIcons = () => {
              const icons = document.querySelectorAll('[data-draw-icon]');
              const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                  if (entry.isIntersecting) {
                    entry.target.classList.add('is-active');
                    observer.unobserve(entry.target);
                  }
                });
              }, { threshold: 0.15 });
              icons.forEach((icon) => observer.observe(icon));
            };
            observeIcons();

            const animateCounter = (element) => {
              if (!(element instanceof HTMLElement)) return;
              if (element.dataset.motionAnimated === 'true') return;

              const original = element.textContent?.trim() ?? '';
              const match = original.match(/-?\\d[\\d,]*(?:\\.\\d+)?/);
              if (!match || match.index == null) return;

              const prefix = original.slice(0, match.index);
              const suffix = original.slice(match.index + match[0].length);
              const finalValue = Number(match[0].replace(/,/g, ''));
              if (!Number.isFinite(finalValue)) return;

              const decimals = (match[0].split('.')[1] || '').length;
              const formatter = new Intl.NumberFormat('en-US', {
                minimumFractionDigits: decimals,
                maximumFractionDigits: decimals,
              });

              element.dataset.motionAnimated = 'true';
              element.dataset.motionVisible = 'true';
              element.textContent = `${prefix}${formatter.format(0)}${suffix}`;

              const duration = 1200;
              const start = performance.now();

              const tick = (now) => {
                const progress = Math.min((now - start) / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 3);
                const value = finalValue * eased;
                const rounded = decimals > 0 ? Number(value.toFixed(decimals)) : Math.round(value);
                element.textContent = `${prefix}${formatter.format(rounded)}${suffix}`;

                if (progress < 1) {
                  window.requestAnimationFrame(tick);
                }
              };

              window.requestAnimationFrame(tick);
            };

            const counterTargets = Array.from(document.querySelectorAll('.counter')).filter(
              (el) => el instanceof HTMLElement
            );

            if (reduced || typeof IntersectionObserver === 'undefined') {
              counterTargets.forEach(animateCounter);
            } else if (counterTargets.length) {
              const counterObserver = new IntersectionObserver(
                (entries) => {
                  entries.forEach((entry) => {
                    if (!entry.isIntersecting || !(entry.target instanceof HTMLElement)) return;
                    animateCounter(entry.target);
                    counterObserver.unobserve(entry.target);
                  });
                },
                { threshold: 0.15, rootMargin: '-30% 0px -60% 0px' }
              );

              counterTargets.forEach((el) => counterObserver.observe(el));
            }

            const buttons = Array.from(document.querySelectorAll('.btn-primary')).filter(
              (el) => el instanceof HTMLElement
            );

            if (!reduced) {
              buttons.forEach((button) => {
                const updateGlow = (event) => {
                  if (!(event instanceof PointerEvent) || event.pointerType === 'touch') return;
                  const rect = button.getBoundingClientRect();
                  button.style.setProperty('--btn-glow-x', `${event.clientX - rect.left}px`);
                  button.style.setProperty('--btn-glow-y', `${event.clientY - rect.top}px`);
                  button.style.setProperty('--btn-glow-opacity', '1');
                };

                button.addEventListener('pointerenter', updateGlow);
                button.addEventListener('pointermove', updateGlow);
                button.addEventListener('pointerleave', () => {
                  button.style.setProperty('--btn-glow-opacity', '0');
                });
              });
            }

            const cursorAccent = document.querySelector('[data-cursor-accent]');
            const isTouchDevice =
              window.matchMedia('(hover: none), (pointer: coarse)').matches ||
              navigator.maxTouchPoints > 0 ||
              'ontouchstart' in window;

            if (cursorAccent instanceof HTMLElement && isTouchDevice) {
              cursorAccent.remove();
            } else if (cursorAccent instanceof HTMLElement) {
              let currentX = window.innerWidth / 2;
              let currentY = window.innerHeight / 2;
              let targetX = currentX;
              let targetY = currentY;
              let currentScale = 1;
              let targetScale = 1;
              let visible = false;

              const interactiveSelector = 'a[href], button, [role="button"], input, select, textarea, label, summary, .card, .glass-card, .glass-card-hover';

              const updateScale = (event) => {
                if (!(event.target instanceof Element)) return;
                targetScale = event.target.closest(interactiveSelector) ? 2 : 1;
              };

              document.addEventListener('pointermove', (event) => {
                if (!(event instanceof PointerEvent) || event.pointerType === 'touch') return;
                targetX = event.clientX;
                targetY = event.clientY;
                if (!visible) {
                  cursorAccent.style.opacity = '1';
                  visible = true;
                }
              });

              document.addEventListener('pointerover', updateScale, true);
              document.addEventListener('pointerout', updateScale, true);

              const animateCursor = () => {
                currentX += (targetX - currentX) * 0.15;
                currentY += (targetY - currentY) * 0.15;
                currentScale += (targetScale - currentScale) * 0.15;
                cursorAccent.style.transform = `translate3d(${currentX}px, ${currentY}px, 0) translate(-50%, -50%) scale(${currentScale})`;
                window.requestAnimationFrame(animateCursor);
              };

              window.requestAnimationFrame(animateCursor);
            }

            const clearLeaving = () => {
              delete html.dataset.motionLeaving;
            };

            window.addEventListener('pageshow', clearLeaving);
            window.addEventListener('pagehide', clearLeaving);

            document.addEventListener('click', (event) => {
              if (reduced || !(event.target instanceof Element)) return;
              if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;

              const link = event.target.closest('a[href]');
              if (!(link instanceof HTMLAnchorElement)) return;
              if (link.target || link.hasAttribute('download')) return;

              const url = new URL(link.href, window.location.href);
              if (url.origin !== window.location.origin) return;
              if (url.pathname === window.location.pathname && url.hash) return;

              event.preventDefault();
              html.dataset.motionLeaving = 'true';
              window.setTimeout(() => {
                window.location.href = link.href;
              }, 300);
            });

            window.requestAnimationFrame(() => {
              if (!reduced) {
                delete html.dataset.motionLoading;
              }
            });
          };

          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', boot, { once: true });
          } else {
            boot();
          }
        })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>

    <ScrollProgressBar client:load />
    <div
      aria-hidden="true"
      data-cursor-accent
      class="pointer-events-none fixed left-0 top-0 z-[70] block h-6 w-6 -translate-x-1/2 -translate-y-1/2 rounded-full border border-[color:rgba(212,175,55,0.55)] opacity-0 mix-blend-screen"
    />

    {showNav ? <NavBar hidePrimaryCta={hidePrimaryCta} /> : null}

    <div class={`relative z-10 ${shellPaddingClass}`}>
      <slot />
    </div>

    {showFooter ? <Footer pathname={Astro.url.pathname} /> : null}
  </body>
</html>
